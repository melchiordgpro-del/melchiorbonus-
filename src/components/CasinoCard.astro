---
import type { Casino } from '../data/casinos';
interface Props {
  casino: Casino;
  rank: number;
}
const { casino, rank } = Astro.props;

const isFirst = rank === 1;
const borderColor = rank === 1 ? 'border-yellow-500/60' : rank === 2 ? 'border-gray-400/40' : rank === 3 ? 'border-amber-600/40' : 'border-bg-border';
const topLineClass = rank === 1 ? 'card-top-gold' : rank === 2 ? 'card-top-silver' : rank === 3 ? 'card-top-bronze' : '';

// Extract the "offert" amount from bonusDescription (e.g. "25€ offert")
const offertMatch = casino.bonusDescription.match(/(\d+€)\s*(offert|gratuit)/i);
const offertAmount = offertMatch ? offertMatch[1] : null;
---

<div class:list={["group relative bg-bg-card border rounded-2xl overflow-hidden transition-all duration-300 hover:shadow-xl flex flex-col", borderColor, topLineClass, isFirst ? "hover:shadow-yellow-500/15" : "hover:shadow-primary/10 card-hover"]}>
  <!-- Top badges -->
  <div class="flex items-center justify-between px-4 pt-3">
    <div class="flex items-center gap-2">
      <span class:list={["text-[10px] font-extrabold px-2.5 py-1 rounded-full", rank === 1 ? "bg-yellow-500 text-black" : rank === 2 ? "bg-gray-400 text-black" : rank === 3 ? "bg-amber-600 text-white" : "bg-primary/20 text-primary"]}>
        #{rank}
      </span>
      <span class="text-[10px] font-bold px-2.5 py-1 rounded-full bg-accent-green/10 text-accent-green border border-accent-green/20">
        OFFRE EXCLUSIVE
      </span>
    </div>
    <div class="flex items-center gap-1.5">
      {casino.promoCode && (
        <span class="text-[10px] font-bold px-2.5 py-1 rounded-full bg-accent-green/20 text-accent-green animate-pulse">
          CODE ACTIF
        </span>
      )}
      {casino.maxBet && (
        <span class="text-[10px] font-bold px-2.5 py-1 rounded-full bg-gold/10 text-gold border border-gold/20">
          Max bet {casino.maxBet}
        </span>
      )}
    </div>
  </div>

  <!-- Casino Name + Logo -->
  <div class="px-4 pt-3 pb-2">
    <div class="flex items-center gap-3">
      <div class:list={["w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 border overflow-hidden", rank === 1 ? "bg-yellow-500/10 border-yellow-500/30" : "bg-bg-surface border-bg-border"]}>
        <img src={casino.logoUrl} alt={casino.name} class="w-9 h-9 object-contain" loading="lazy" onerror={`this.style.display='none';this.parentElement.innerHTML='<span class="text-2xl">${casino.logo}</span>'`} />
      </div>
      <div>
        <h3 class="text-white font-extrabold text-lg">{casino.name}</h3>
      </div>
    </div>
  </div>

  <!-- Big Offer Box -->
  <div class="mx-4 mb-3">
    <div class:list={["rounded-xl p-4 text-center border-2", rank === 1 ? "bg-yellow-500/5 border-yellow-500/40" : "bg-bg-surface border-bg-border"]}>
      <p class:list={["font-black uppercase tracking-wider text-2xl", "text-accent-green"]}>
        {offertAmount ? offertAmount + ' OFFERTS*' : casino.bonusAmount}
      </p>
      <p class="text-gray-300 text-xs mt-2" set:html={casino.bonusDescription.replace(/—.*/, '').trim().replace(/(\d+%)/g, '<strong class="text-gold font-extrabold">$1</strong>').replace(/(\d+\s*€)/g, '<strong class="text-gold font-extrabold">$1</strong>').replace(/(Free Spins|FS)/gi, '<strong class="text-gold font-extrabold">$1</strong>')} />
      <p class:list={["text-xs font-bold mt-2 uppercase tracking-wide", casino.wager.includes("FREE") ? "text-accent-green" : "text-gold"]}>
        {casino.wager.includes("FREE") ? '✅ WAGER FREE — Aucun wager !' : '⚡ Wager ' + casino.wager}
      </p>
    </div>
    <p class="text-gray-600 text-[9px] mt-1 text-center">*Sous dépôt minimum de {casino.slug === 'betify' ? '30€' : '25€'}</p>
  </div>

  <!-- Payment Methods + Tags -->
  <div class="px-4 mb-3">
    <div class="flex flex-wrap gap-1.5">
      {casino.paymentMethods.slice(0, 3).map((m) => (
        <span class="text-[10px] font-bold px-2 py-1 rounded-lg bg-bg-surface border border-bg-border text-gray-300 flex items-center gap-1">
          {m === 'Visa' || m === 'Mastercard' || m === 'Carte bancaire' ? '💳' : m === 'Crypto' ? '₿' : '💸'} {m}
        </span>
      ))}
      {casino.discordBonus && (
        <span class="text-[10px] font-bold px-2 py-1 rounded-lg bg-[#5865F2]/10 border border-[#5865F2]/20 text-[#5865F2] flex items-center gap-1">
          🎁 {casino.discordBonus}
        </span>
      )}
    </div>
  </div>

  <!-- Promo Code -->
  {casino.promoCode && (
    <div class="mx-4 mb-3 flex items-center gap-2 bg-bg-surface border border-bg-border rounded-lg px-3 py-2">
      <span class="text-gray-500 text-[10px] uppercase font-bold">Code</span>
      <span class="text-white font-mono font-extrabold tracking-widest text-sm flex-1">{casino.promoCode}</span>
    </div>
  )}

  <!-- Trust badges -->
  <div class="px-4 mb-3">
    <div class="flex items-center gap-3 text-[10px] text-gray-500">
      <span class="flex items-center gap-1"><span class="text-accent-green">✓</span> Retrait {casino.withdrawalTime}</span>
      <span class="flex items-center gap-1"><span class="text-accent-green">✓</span> Vérifié</span>
      {casino.promoCode && <span class="flex items-center gap-1"><span class="text-accent-green">✓</span> Code exclusif</span>}
    </div>
  </div>

  <!-- CTA -->
  <div class="px-4 pb-4 mt-auto">
    <a
      href={casino.affiliateUrl}
      target="_blank"
      rel="nofollow noopener"
      class="btn-glow block text-center font-extrabold py-3.5 rounded-xl transition-all duration-200 text-sm uppercase tracking-wider bg-accent-green hover:bg-accent-green/80 text-white shadow-lg shadow-accent-green/20"
    >
      🎁 Récupère ton bonus →
    </a>
  </div>
</div>
