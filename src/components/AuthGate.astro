---
// Shows content with an overlay prompt if not logged in.
// Content is always visible but interaction is blocked.
---

<div class="relative">
  <!-- Content always visible -->
  <div id="auth-gate-content">
    <slot />
  </div>

  <!-- Overlay if not logged in -->
  <div id="auth-gate-overlay" class="hidden">
    <div class="absolute inset-0 bg-bg-dark/60 backdrop-blur-[2px] z-50 flex items-start justify-center pt-8 sm:pt-16">
      <div class="bg-bg-card border border-bg-border rounded-2xl p-6 sm:p-8 max-w-md mx-4 shadow-2xl shadow-black/50 text-center">
        <div class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
        </div>
        <h2 class="text-xl font-extrabold text-white mb-2">Connecte-toi pour continuer</h2>
        <p class="text-gray-400 text-sm mb-5">Inscris-toi ou connecte-toi gratuitement pour accéder à cette fonctionnalité !</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href="/login" class="w-full sm:w-auto bg-primary hover:bg-primary-light text-white font-bold px-6 py-3 rounded-xl transition-all hover:shadow-lg hover:shadow-primary/20 text-sm">
            Se connecter
          </a>
          <a href="/inscription" class="w-full sm:w-auto border border-bg-border hover:border-primary/30 text-gray-300 hover:text-white font-medium px-6 py-3 rounded-xl transition-all text-sm">
            Créer un compte
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    var isLoggedIn = localStorage.getItem('melchior_logged_in') === 'true';
    if (!isLoggedIn) {
      document.getElementById('auth-gate-overlay').classList.remove('hidden');
    }
  })();
</script>
