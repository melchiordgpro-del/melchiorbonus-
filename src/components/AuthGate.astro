---
// This component wraps protected content.
// If user is not logged in, shows login prompt instead.
---

<div id="auth-gate-locked" class="hidden">
  <div class="max-w-lg mx-auto text-center py-20 px-4">
    <div class="w-20 h-20 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
      <svg class="w-10 h-10 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
      </svg>
    </div>
    <h2 class="text-2xl font-extrabold text-white mb-3">Connexion requise</h2>
    <p class="text-gray-400 mb-6">Tu dois être connecté pour accéder à cette page. Connecte-toi ou crée un compte gratuitement !</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/login" class="bg-primary hover:bg-primary-light text-white font-bold px-8 py-3.5 rounded-xl transition-all duration-200 hover:shadow-lg hover:shadow-primary/20">
        Se connecter
      </a>
      <a href="/inscription" class="border border-bg-border hover:border-primary/30 text-gray-300 hover:text-white font-medium px-8 py-3.5 rounded-xl transition-all">
        Créer un compte
      </a>
    </div>
  </div>
</div>

<div id="auth-gate-content" class="hidden">
  <slot />
</div>

<script is:inline>
  (function() {
    var isLoggedIn = localStorage.getItem('melchior_logged_in') === 'true';
    if (isLoggedIn) {
      document.getElementById('auth-gate-content').classList.remove('hidden');
      document.getElementById('auth-gate-locked').classList.add('hidden');
    } else {
      document.getElementById('auth-gate-locked').classList.remove('hidden');
      document.getElementById('auth-gate-content').classList.add('hidden');
    }
  })();
</script>
