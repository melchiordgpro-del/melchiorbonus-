---
import Layout from '../layouts/Layout.astro';
import AuthGate from '../components/AuthGate.astro';
import { casinos } from '../data/casinos';
---

<Layout title="Bonus Hunt — Ouvre tes bonus slots | MelchiorBonus" description="Participe au Bonus Hunt de MelchiorBonus. Ouvre des bonus sur les meilleurs slots et gagne gros !">
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-10">
      <div class="inline-flex items-center gap-2 bg-accent/10 border border-accent/20 text-accent text-sm font-medium px-4 py-1.5 rounded-full mb-4">
        <span>🔥</span>
        <span>En direct</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-4 flex items-center justify-center gap-3">
        <svg class="w-10 h-10 text-primary-light" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 5h2v14H4zM18 5h2v14h-2zM8 3h8v4H8zM8 17h8v4H8zM9 7h6v10H9z" /></svg>
        Bonus Hunt
      </h1>
      <p class="text-gray-400 text-lg max-w-xl mx-auto">
        Ouvre des bonus sur les meilleurs slots et suis les résultats en temps réel !
      </p>
    </div>

    <AuthGate>
      <!-- Hunt Status -->
      <div class="bg-bg-card border border-bg-border rounded-2xl p-6 mb-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mb-6">
          <div>
            <h2 class="text-xl font-extrabold text-white">Bonus Hunt en cours</h2>
            <p class="text-gray-400 text-sm mt-1">Session du jour — Mars 2026</p>
          </div>
          <div class="flex items-center gap-3">
            <div class="bg-accent-green/10 text-accent-green font-bold text-sm px-4 py-2 rounded-lg border border-accent-green/20">
              EN COURS
            </div>
          </div>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          <div class="bg-bg-surface border border-bg-border rounded-xl p-4 text-center">
            <p class="text-gray-500 text-xs mb-1">Total Investi</p>
            <p class="text-white font-extrabold text-xl" id="total-invested">0€</p>
          </div>
          <div class="bg-bg-surface border border-bg-border rounded-xl p-4 text-center">
            <p class="text-gray-500 text-xs mb-1">Total Gagné</p>
            <p class="text-accent-green font-extrabold text-xl" id="total-won">0€</p>
          </div>
          <div class="bg-bg-surface border border-bg-border rounded-xl p-4 text-center">
            <p class="text-gray-500 text-xs mb-1">Bonus Ouverts</p>
            <p class="text-primary-light font-extrabold text-xl" id="bonus-opened">0</p>
          </div>
          <div class="bg-bg-surface border border-bg-border rounded-xl p-4 text-center">
            <p class="text-gray-500 text-xs mb-1">Multiplicateur Moyen</p>
            <p class="text-gold font-extrabold text-xl" id="avg-multi">0x</p>
          </div>
        </div>
      </div>

      <!-- Bonus Slots Table -->
      <div class="bg-bg-card border border-bg-border rounded-2xl overflow-hidden">
        <div class="p-5 border-b border-bg-border flex items-center justify-between">
          <h3 class="text-white font-bold text-lg">Slots du Bonus Hunt</h3>
          <button id="add-slot-btn" class="bg-primary hover:bg-primary-light text-white font-bold text-sm px-4 py-2 rounded-lg transition-all">
            + Ajouter un slot
          </button>
        </div>

        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-bg-border bg-bg-surface">
                <th class="text-left text-gray-500 text-xs uppercase tracking-wider py-3 px-5">#</th>
                <th class="text-left text-gray-500 text-xs uppercase tracking-wider py-3 px-5">Slot</th>
                <th class="text-left text-gray-500 text-xs uppercase tracking-wider py-3 px-5">Mise</th>
                <th class="text-left text-gray-500 text-xs uppercase tracking-wider py-3 px-5">Résultat</th>
                <th class="text-left text-gray-500 text-xs uppercase tracking-wider py-3 px-5">Multi</th>
                <th class="text-left text-gray-500 text-xs uppercase tracking-wider py-3 px-5">Statut</th>
              </tr>
            </thead>
            <tbody id="slots-table">
              <tr class="border-b border-bg-border/30">
                <td class="py-4 px-5 text-primary font-bold">1</td>
                <td class="py-4 px-5 text-white font-medium">Gates of Olympus</td>
                <td class="py-4 px-5 text-gray-300">2€</td>
                <td class="py-4 px-5 text-accent-green font-bold">—</td>
                <td class="py-4 px-5 text-gold font-bold">—</td>
                <td class="py-4 px-5"><span class="bg-gold/10 text-gold text-xs font-bold px-2 py-1 rounded">En attente</span></td>
              </tr>
              <tr class="border-b border-bg-border/30">
                <td class="py-4 px-5 text-primary font-bold">2</td>
                <td class="py-4 px-5 text-white font-medium">Sweet Bonanza</td>
                <td class="py-4 px-5 text-gray-300">1€</td>
                <td class="py-4 px-5 text-accent-green font-bold">—</td>
                <td class="py-4 px-5 text-gold font-bold">—</td>
                <td class="py-4 px-5"><span class="bg-gold/10 text-gold text-xs font-bold px-2 py-1 rounded">En attente</span></td>
              </tr>
              <tr class="border-b border-bg-border/30">
                <td class="py-4 px-5 text-primary font-bold">3</td>
                <td class="py-4 px-5 text-white font-medium">Wanted Dead or a Wild</td>
                <td class="py-4 px-5 text-gray-300">2€</td>
                <td class="py-4 px-5 text-accent-green font-bold">—</td>
                <td class="py-4 px-5 text-gold font-bold">—</td>
                <td class="py-4 px-5"><span class="bg-gold/10 text-gold text-xs font-bold px-2 py-1 rounded">En attente</span></td>
              </tr>
              <tr class="border-b border-bg-border/30">
                <td class="py-4 px-5 text-primary font-bold">4</td>
                <td class="py-4 px-5 text-white font-medium">Mental</td>
                <td class="py-4 px-5 text-gray-300">0.50€</td>
                <td class="py-4 px-5 text-accent-green font-bold">—</td>
                <td class="py-4 px-5 text-gold font-bold">—</td>
                <td class="py-4 px-5"><span class="bg-gold/10 text-gold text-xs font-bold px-2 py-1 rounded">En attente</span></td>
              </tr>
              <tr>
                <td class="py-4 px-5 text-primary font-bold">5</td>
                <td class="py-4 px-5 text-white font-medium">Book of Dead</td>
                <td class="py-4 px-5 text-gray-300">1€</td>
                <td class="py-4 px-5 text-accent-green font-bold">—</td>
                <td class="py-4 px-5 text-gold font-bold">—</td>
                <td class="py-4 px-5"><span class="bg-gold/10 text-gold text-xs font-bold px-2 py-1 rounded">En attente</span></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Casino Partners for Bonus Hunt -->
      <div class="mt-8">
        <h3 class="text-white font-bold text-lg mb-4">Joue le Bonus Hunt sur nos casinos partenaires</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {casinos.slice(0, 3).map((casino) => (
            <a href={casino.affiliateUrl} target="_blank" rel="nofollow noopener" class="group bg-bg-card border border-bg-border rounded-xl p-4 hover:border-primary/30 transition-all flex items-center gap-3">
              <span class="text-2xl">{casino.logo}</span>
              <div>
                <p class="text-white font-bold group-hover:text-primary transition-colors">{casino.name}</p>
                <p class="text-gray-500 text-xs">{casino.bonusAmount}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </AuthGate>
  </section>
</Layout>
