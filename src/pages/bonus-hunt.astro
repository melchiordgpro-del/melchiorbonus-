---
import Layout from '../layouts/Layout.astro';
import AuthGate from '../components/AuthGate.astro';
import { casinos } from '../data/casinos';
---

<Layout title="Bonus Hunt — Ouvre tes bonus slots | MelchiorBonus" description="Participe au Bonus Hunt de MelchiorBonus. Ouvre des bonus sur les meilleurs slots et gagne gros !">
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-10">
      <div class="inline-flex items-center gap-2 bg-accent/10 border border-accent/20 text-accent text-sm font-medium px-4 py-1.5 rounded-full mb-4">
        <span>🔥</span>
        <span>Bonus Hunt Tracker</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-4 flex items-center justify-center gap-3">
        🎰 Bonus Hunt
      </h1>
      <p class="text-gray-400 text-lg max-w-xl mx-auto">
        Ajoute tes bonus, suis les résultats et calcule ton break even en temps réel !
      </p>
    </div>

    <AuthGate>
      <!-- Hunt Controls -->
      <div class="flex flex-wrap items-center gap-3 mb-6">
        <button id="new-hunt-btn" class="bg-primary hover:bg-primary-light text-white font-bold text-sm px-5 py-2.5 rounded-lg transition-all">
          + Nouveau Bonus Hunt
        </button>
        <button id="save-hunt-btn" class="bg-accent-green/20 border border-accent-green/30 text-accent-green hover:bg-accent-green/30 font-bold text-sm px-5 py-2.5 rounded-lg transition-all">
          💾 Sauvegarder
        </button>
        <button id="delete-hunt-btn" class="bg-accent-red/20 border border-accent-red/30 text-accent-red hover:bg-accent-red/30 font-bold text-sm px-5 py-2.5 rounded-lg transition-all">
          🗑️ Supprimer
        </button>
        <select id="load-hunt-select" class="bg-bg-surface border border-bg-border text-white text-sm px-3 py-2.5 rounded-lg outline-none ml-auto">
          <option value="">-- Charger un hunt --</option>
        </select>
      </div>

      <!-- Stats -->
      <div class="bg-bg-card border border-bg-border rounded-2xl p-6 mb-6">
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
          <div class="bg-bg-surface border border-bg-border rounded-xl p-3 text-center">
            <p class="text-gray-500 text-[10px] uppercase">Nb Bonus</p>
            <p class="text-primary-light font-extrabold text-xl" id="stat-count">0</p>
          </div>
          <div class="bg-bg-surface border border-bg-border rounded-xl p-3 text-center">
            <p class="text-gray-500 text-[10px] uppercase">Total Investi</p>
            <p class="text-white font-extrabold text-xl" id="stat-invested">0€</p>
          </div>
          <div class="bg-bg-surface border border-bg-border rounded-xl p-3 text-center">
            <p class="text-gray-500 text-[10px] uppercase">Total Gagné</p>
            <p class="text-accent-green font-extrabold text-xl" id="stat-won">0€</p>
          </div>
          <div class="bg-bg-surface border border-bg-border rounded-xl p-3 text-center">
            <p class="text-gray-500 text-[10px] uppercase">Profit</p>
            <p class="font-extrabold text-xl" id="stat-profit">0€</p>
          </div>
          <div class="bg-bg-surface border border-bg-border rounded-xl p-3 text-center">
            <p class="text-gray-500 text-[10px] uppercase">Multi Moyen</p>
            <p class="text-gold font-extrabold text-xl" id="stat-avg-multi">0×</p>
          </div>
          <div class="bg-bg-surface border border-bg-border rounded-xl p-3 text-center">
            <p class="text-gray-500 text-[10px] uppercase">Break Even</p>
            <p class="text-accent font-extrabold text-xl" id="stat-breakeven">0×</p>
          </div>
        </div>

        <!-- Progress bar -->
        <div class="mt-4">
          <div class="flex items-center justify-between text-xs text-gray-500 mb-1">
            <span>Progression</span>
            <span id="stat-progress-text">0/0 ouverts</span>
          </div>
          <div class="w-full bg-bg-surface rounded-full h-2.5 border border-bg-border">
            <div id="stat-progress-bar" class="bg-primary h-full rounded-full transition-all duration-500" style="width: 0%"></div>
          </div>
        </div>

        <!-- Open Bonus Hunt Button -->
        <div class="mt-4">
          <button id="open-hunt-btn" class="w-full btn-glow bg-gradient-to-r from-accent via-accent-light to-gold text-white font-extrabold py-4 rounded-xl text-lg transition-all hover:shadow-xl hover:shadow-accent/20 cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed" disabled>
            🎰 Ouvrir le Bonus Hunt
          </button>
        </div>
      </div>

      <!-- Opening Overlay -->
      <div id="opening-overlay" class="hidden fixed inset-0 bg-black/80 z-[100] flex items-center justify-center">
        <div class="bg-[#1a1d23] border border-[#2a2d35] rounded-2xl p-8 max-w-md w-full mx-4 text-center shadow-2xl">
          <p class="text-gray-400 text-sm mb-2" id="opening-counter">Bonus 1 / 5</p>
          <h2 class="text-white font-extrabold text-2xl mb-1" id="opening-slot-name">Gates of Olympus</h2>
          <p class="text-gray-500 text-sm mb-6">Mise: <span id="opening-bet" class="text-white font-bold">2.00€</span></p>

          <div id="opening-card" class="bg-[#0e1015] border-2 border-[#2a2d35] rounded-xl p-8 mb-6 relative overflow-hidden">
            <div id="opening-spinner" class="text-6xl font-extrabold text-primary animate-pulse">?</div>
            <div id="opening-result-display" class="hidden">
              <p class="text-5xl font-extrabold" id="opening-amount">0€</p>
              <p class="text-2xl font-bold mt-2" id="opening-multi">0×</p>
            </div>
          </div>

          <div id="opening-input-area">
            <input id="opening-result-input" type="number" step="0.01" min="0" placeholder="Combien ça a payé ? (€)" class="w-full bg-[#0e1015] border border-[#2a2d35] text-white text-center text-lg font-bold px-4 py-3 rounded-xl outline-none focus:border-primary/50 mb-3" />
            <button id="opening-confirm-btn" class="w-full bg-primary hover:bg-primary-light text-white font-extrabold py-3 rounded-xl transition-all text-sm cursor-pointer">
              Confirmer le résultat
            </button>
          </div>

          <div id="opening-next-area" class="hidden">
            <button id="opening-next-btn" class="w-full bg-accent hover:bg-accent-light text-white font-extrabold py-3 rounded-xl transition-all text-sm cursor-pointer">
              Bonus suivant →
            </button>
          </div>

          <div id="opening-done-area" class="hidden">
            <div class="mb-4">
              <p class="text-gray-400 text-sm">Résultat final</p>
              <p class="text-3xl font-extrabold" id="opening-final-profit">+0€</p>
            </div>
            <button id="opening-close-btn" class="w-full bg-[#2a2d35] hover:bg-[#3a3d45] text-white font-bold py-3 rounded-xl transition-all text-sm cursor-pointer">
              Fermer
            </button>
          </div>

          <button id="opening-skip-btn" class="mt-3 text-gray-600 hover:text-gray-400 text-xs cursor-pointer transition-colors">
            Fermer l'ouverture
          </button>
        </div>
      </div>

      <!-- Add Slot Form -->
      <div id="add-form" class="bg-bg-card border border-bg-border rounded-2xl p-5 mb-6">
        <h3 class="text-white font-bold mb-4">Ajouter un bonus</h3>
        <!-- Provider filter -->
        <div class="flex flex-wrap gap-1.5 mb-3">
          <button data-provider="all" class="provider-btn bg-primary text-white text-[10px] font-bold px-3 py-1.5 rounded-full cursor-pointer transition-all">Tous</button>
          <button data-provider="Pragmatic Play" class="provider-btn bg-bg-surface text-gray-400 text-[10px] font-bold px-3 py-1.5 rounded-full cursor-pointer transition-all border border-bg-border hover:border-primary/30">Pragmatic</button>
          <button data-provider="Hacksaw Gaming" class="provider-btn bg-bg-surface text-gray-400 text-[10px] font-bold px-3 py-1.5 rounded-full cursor-pointer transition-all border border-bg-border hover:border-primary/30">Hacksaw</button>
          <button data-provider="Nolimit City" class="provider-btn bg-bg-surface text-gray-400 text-[10px] font-bold px-3 py-1.5 rounded-full cursor-pointer transition-all border border-bg-border hover:border-primary/30">Nolimit</button>
          <button data-provider="Push Gaming" class="provider-btn bg-bg-surface text-gray-400 text-[10px] font-bold px-3 py-1.5 rounded-full cursor-pointer transition-all border border-bg-border hover:border-primary/30">Push</button>
          <button data-provider="Play'n GO" class="provider-btn bg-bg-surface text-gray-400 text-[10px] font-bold px-3 py-1.5 rounded-full cursor-pointer transition-all border border-bg-border hover:border-primary/30">Play'n GO</button>
          <button data-provider="Relax Gaming" class="provider-btn bg-bg-surface text-gray-400 text-[10px] font-bold px-3 py-1.5 rounded-full cursor-pointer transition-all border border-bg-border hover:border-primary/30">Relax</button>
          <button data-provider="NetEnt" class="provider-btn bg-bg-surface text-gray-400 text-[10px] font-bold px-3 py-1.5 rounded-full cursor-pointer transition-all border border-bg-border hover:border-primary/30">NetEnt</button>
          <button data-provider="Big Time Gaming" class="provider-btn bg-bg-surface text-gray-400 text-[10px] font-bold px-3 py-1.5 rounded-full cursor-pointer transition-all border border-bg-border hover:border-primary/30">BTG</button>
          <button data-provider="ELK Studios" class="provider-btn bg-bg-surface text-gray-400 text-[10px] font-bold px-3 py-1.5 rounded-full cursor-pointer transition-all border border-bg-border hover:border-primary/30">ELK</button>
          <button data-provider="Novomatic" class="provider-btn bg-bg-surface text-gray-400 text-[10px] font-bold px-3 py-1.5 rounded-full cursor-pointer transition-all border border-bg-border hover:border-primary/30">Novomatic</button>
        </div>
        <div class="flex flex-wrap gap-3 items-end">
          <div class="flex-1 min-w-[180px] relative">
            <label class="text-gray-500 text-xs block mb-1">Nom du slot</label>
            <input id="slot-name" type="text" placeholder="Tape 3 lettres..." autocomplete="off" class="w-full bg-bg-surface border border-bg-border text-white text-sm px-3 py-2.5 rounded-lg outline-none focus:border-primary/50" />
            <div id="autocomplete-list" class="hidden absolute left-0 right-0 top-full mt-1 bg-[#1a1d23] border border-[#2a2d35] rounded-lg shadow-2xl shadow-black/50 z-50 max-h-48 overflow-y-auto"></div>
          </div>
          <div class="w-28">
            <label class="text-gray-500 text-xs block mb-1">Mise (€)</label>
            <input id="slot-bet" type="number" step="0.01" value="1" min="0.01" class="w-full bg-bg-surface border border-bg-border text-white text-sm px-3 py-2.5 rounded-lg outline-none focus:border-primary/50" />
          </div>
          <button id="add-slot-btn" class="bg-primary hover:bg-primary-light text-white font-bold text-sm px-6 py-2.5 rounded-lg transition-all">
            + Ajouter
          </button>
          <button id="random-slot-btn" class="bg-gold/20 border border-gold/30 text-gold hover:bg-gold/30 font-bold text-sm px-4 py-2.5 rounded-lg transition-all" title="Slot aléatoire">
            🎲
          </button>
        </div>
      </div>

      <!-- Slots Table -->
      <div class="bg-bg-card border border-bg-border rounded-2xl overflow-hidden mb-8">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-bg-border bg-bg-surface">
                <th class="text-left text-gray-500 text-xs uppercase tracking-wider py-3 px-4">#</th>
                <th class="text-left text-gray-500 text-xs uppercase tracking-wider py-3 px-4">Slot</th>
                <th class="text-left text-gray-500 text-xs uppercase tracking-wider py-3 px-4">Mise</th>
                <th class="text-left text-gray-500 text-xs uppercase tracking-wider py-3 px-4">Résultat (€)</th>
                <th class="text-left text-gray-500 text-xs uppercase tracking-wider py-3 px-4">Multi</th>
                <th class="text-left text-gray-500 text-xs uppercase tracking-wider py-3 px-4">Statut</th>
                <th class="text-left text-gray-500 text-xs uppercase tracking-wider py-3 px-4"></th>
              </tr>
            </thead>
            <tbody id="slots-table">
              <!-- Dynamic rows -->
            </tbody>
          </table>
        </div>
        <div id="empty-state" class="p-8 text-center text-gray-500">
          <span class="text-4xl block mb-3">🎰</span>
          <p class="font-medium">Aucun bonus ajouté</p>
          <p class="text-sm">Ajoute un slot pour commencer ton Bonus Hunt !</p>
        </div>
      </div>

      <!-- Casino Partners -->
      <div>
        <h3 class="text-white font-bold text-lg mb-4">Joue le Bonus Hunt sur nos casinos partenaires</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {casinos.slice(0, 3).map((casino) => (
            <a href={casino.affiliateUrl} target="_blank" rel="nofollow noopener" class="group bg-bg-card border border-bg-border rounded-xl p-4 hover:border-primary/30 transition-all flex items-center gap-3 card-hover">
              <span class="text-2xl">{casino.logo}</span>
              <div>
                <p class="text-white font-bold group-hover:text-primary transition-colors">{casino.name}</p>
                <p class="text-gray-500 text-xs">{casino.bonusAmount}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </AuthGate>
  </section>
</Layout>

<script is:inline>
(function() {
  // ========== SLOTS DATABASE ==========
  var SLOTS_DB = [
    // Pragmatic Play
    {n:"Gates of Olympus",p:"Pragmatic Play"},{n:"Sweet Bonanza",p:"Pragmatic Play"},{n:"Sugar Rush",p:"Pragmatic Play"},
    {n:"Starlight Princess",p:"Pragmatic Play"},{n:"The Dog House Megaways",p:"Pragmatic Play"},{n:"Big Bass Bonanza",p:"Pragmatic Play"},
    {n:"Fruit Party",p:"Pragmatic Play"},{n:"Madame Destiny Megaways",p:"Pragmatic Play"},{n:"Wild West Gold",p:"Pragmatic Play"},
    {n:"John Hunter and the Tomb of the Scarab Queen",p:"Pragmatic Play"},{n:"Great Rhino Megaways",p:"Pragmatic Play"},
    {n:"Gates of Olympus 1000",p:"Pragmatic Play"},{n:"Sweet Bonanza 1000",p:"Pragmatic Play"},{n:"Bigger Bass Bonanza",p:"Pragmatic Play"},
    {n:"Zeus vs Hades",p:"Pragmatic Play"},{n:"Gems Bonanza",p:"Pragmatic Play"},{n:"Power of Thor Megaways",p:"Pragmatic Play"},
    {n:"Big Bass Splash",p:"Pragmatic Play"},{n:"Floating Dragon",p:"Pragmatic Play"},{n:"Release the Kraken 2",p:"Pragmatic Play"},
    {n:"5 Lions Megaways",p:"Pragmatic Play"},{n:"Cleocatra",p:"Pragmatic Play"},{n:"Cash Bonanza",p:"Pragmatic Play"},
    {n:"Hot Pepper",p:"Pragmatic Play"},{n:"Sugar Supreme Powernudge",p:"Pragmatic Play"},{n:"Barn Festival",p:"Pragmatic Play"},
    {n:"Fire Strike 2",p:"Pragmatic Play"},{n:"Candy Village",p:"Pragmatic Play"},{n:"Curse of the Werewolf Megaways",p:"Pragmatic Play"},
    {n:"Bronco Spirit",p:"Pragmatic Play"},{n:"Pirate Gold Deluxe",p:"Pragmatic Play"},{n:"Magic Money Maze",p:"Pragmatic Play"},
    // Hacksaw Gaming
    {n:"Wanted Dead or a Wild",p:"Hacksaw Gaming"},{n:"Chaos Crew",p:"Hacksaw Gaming"},{n:"Chaos Crew 2",p:"Hacksaw Gaming"},
    {n:"IteroClassic Dream Drop",p:"Hacksaw Gaming"},{n:"Dork Unit",p:"Hacksaw Gaming"},{n:"Xpander",p:"Hacksaw Gaming"},
    {n:"Stick 'Em",p:"Hacksaw Gaming"},{n:"RIP City",p:"Hacksaw Gaming"},{n:"Hand of Anubis",p:"Hacksaw Gaming"},
    {n:"Rex the Hunt",p:"Hacksaw Gaming"},{n:"Om Nom",p:"Hacksaw Gaming"},{n:"Fruit Duel",p:"Hacksaw Gaming"},
    {n:"Gladiator Legends",p:"Hacksaw Gaming"},{n:"Stack 'Em",p:"Hacksaw Gaming"},{n:"Hawks of Prey",p:"Hacksaw Gaming"},
    {n:"Toshi Video Club",p:"Hacksaw Gaming"},{n:"Blade & Fangs",p:"Hacksaw Gaming"},{n:"Le Bandit",p:"Hacksaw Gaming"},
    // Nolimit City
    {n:"Mental",p:"Nolimit City"},{n:"Tombstone RIP",p:"Nolimit City"},{n:"San Quentin xWays",p:"Nolimit City"},
    {n:"Fire in the Hole",p:"Nolimit City"},{n:"Punk Rocker",p:"Nolimit City"},{n:"True Grit Redemption",p:"Nolimit City"},
    {n:"Misery Mining",p:"Nolimit City"},{n:"Warrior Graveyard",p:"Nolimit City"},{n:"Remember Gulag",p:"Nolimit City"},
    {n:"Walk of Shame",p:"Nolimit City"},{n:"xWays Hoarder",p:"Nolimit City"},{n:"Infectious 5 xWays",p:"Nolimit City"},
    {n:"Serial",p:"Nolimit City"},{n:"Mango Man",p:"Nolimit City"},{n:"Tombstone",p:"Nolimit City"},
    {n:"El Paso Gunfight",p:"Nolimit City"},{n:"Karen Maneater",p:"Nolimit City"},{n:"Roadkill",p:"Nolimit City"},
    // Push Gaming
    {n:"Jammin' Jars",p:"Push Gaming"},{n:"Jammin' Jars 2",p:"Push Gaming"},{n:"Razor Shark",p:"Push Gaming"},
    {n:"Fat Rabbit",p:"Push Gaming"},{n:"Fire Hopper",p:"Push Gaming"},{n:"Bison Battle",p:"Push Gaming"},
    {n:"Joker Troupe",p:"Push Gaming"},{n:"Big Bamboo",p:"Push Gaming"},{n:"Nightfall",p:"Push Gaming"},
    {n:"Razor Returns",p:"Push Gaming"},{n:"Space Stacks",p:"Push Gaming"},{n:"Generous Jack",p:"Push Gaming"},
    // Play'n GO
    {n:"Book of Dead",p:"Play'n GO"},{n:"Reactoonz",p:"Play'n GO"},{n:"Reactoonz 2",p:"Play'n GO"},
    {n:"Rise of Olympus",p:"Play'n GO"},{n:"Moon Princess",p:"Play'n GO"},{n:"Fire Joker",p:"Play'n GO"},
    {n:"Rich Wilde and the Amulet of Dead",p:"Play'n GO"},{n:"Tome of Madness",p:"Play'n GO"},
    {n:"Legacy of Dead",p:"Play'n GO"},{n:"Hugo 2",p:"Play'n GO"},{n:"Gemix",p:"Play'n GO"},
    {n:"Contact",p:"Play'n GO"},{n:"Cat Wilde and the Doom of Dead",p:"Play'n GO"},{n:"Honey Rush",p:"Play'n GO"},
    // Relax Gaming
    {n:"Money Train",p:"Relax Gaming"},{n:"Money Train 2",p:"Relax Gaming"},{n:"Money Train 3",p:"Relax Gaming"},
    {n:"Money Train 4",p:"Relax Gaming"},{n:"Dream Drop Jackpot",p:"Relax Gaming"},{n:"Temple Tumble Megaways",p:"Relax Gaming"},
    {n:"Snake Arena",p:"Relax Gaming"},{n:"TNT Tumble",p:"Relax Gaming"},{n:"Hellcatraz",p:"Relax Gaming"},
    // NetEnt
    {n:"Starburst",p:"NetEnt"},{n:"Gonzo's Quest",p:"NetEnt"},{n:"Dead or Alive 2",p:"NetEnt"},
    {n:"Divine Fortune",p:"NetEnt"},{n:"Narcos",p:"NetEnt"},{n:"Twin Spin",p:"NetEnt"},
    {n:"Jack and the Beanstalk",p:"NetEnt"},{n:"Blood Suckers",p:"NetEnt"},{n:"Asgardian Stones",p:"NetEnt"},
    {n:"Gordon Ramsay Hell's Kitchen",p:"NetEnt"},{n:"Street Fighter II",p:"NetEnt"},
    // Big Time Gaming
    {n:"Bonanza Megaways",p:"Big Time Gaming"},{n:"Extra Chilli",p:"Big Time Gaming"},{n:"White Rabbit",p:"Big Time Gaming"},
    {n:"Lil Devil",p:"Big Time Gaming"},{n:"Opal Fruits",p:"Big Time Gaming"},{n:"Kingmaker",p:"Big Time Gaming"},
    {n:"Royal Mint Megaways",p:"Big Time Gaming"},{n:"Donuts",p:"Big Time Gaming"},
    // ELK Studios
    {n:"Cygnus",p:"ELK Studios"},{n:"Kaiju",p:"ELK Studios"},{n:"Bloopers",p:"ELK Studios"},
    {n:"Ecuador Gold",p:"ELK Studios"},{n:"Poltava",p:"ELK Studios"},{n:"Toro",p:"ELK Studios"},
    {n:"Valkyrie",p:"ELK Studios"},{n:"Cygnus 2",p:"ELK Studios"},{n:"O'Reilly's Fortune",p:"ELK Studios"},
    // Novomatic
    {n:"Book of Ra",p:"Novomatic"},{n:"Book of Ra Deluxe",p:"Novomatic"},{n:"Lucky Lady's Charm",p:"Novomatic"},
    {n:"Sizzling Hot",p:"Novomatic"},{n:"Dolphin's Pearl",p:"Novomatic"},{n:"Columbus",p:"Novomatic"},
    {n:"Lord of the Ocean",p:"Novomatic"},{n:"Pharaoh's Ring",p:"Novomatic"},{n:"Ultra Hot",p:"Novomatic"},
    // Thunderkick
    {n:"Beat the Beast: Griffin's Gold",p:"Thunderkick"},{n:"Pink Elephants",p:"Thunderkick"},
    {n:"Pink Elephants 2",p:"Thunderkick"},{n:"Esqueleto Explosivo 2",p:"Thunderkick"},{n:"1429 Uncharted Seas",p:"Thunderkick"},
    // Red Tiger
    {n:"Gonzo's Quest Megaways",p:"Red Tiger"},{n:"Mystery Reels Megaways",p:"Red Tiger"},
    {n:"Dragon's Fire Megaways",p:"Red Tiger"},{n:"Piggy Riches Megaways",p:"Red Tiger"},
    // Yggdrasil
    {n:"Valley of the Gods",p:"Yggdrasil"},{n:"Vikings Go Berzerk",p:"Yggdrasil"},
    {n:"Champions of Rome",p:"Yggdrasil"},{n:"Hades Gigablox",p:"Yggdrasil"},
    // Microgaming
    {n:"Mega Moolah",p:"Microgaming"},{n:"Immortal Romance",p:"Microgaming"},{n:"Thunderstruck II",p:"Microgaming"},
    {n:"Break da Bank Again",p:"Microgaming"},{n:"Avalon II",p:"Microgaming"},
  ];

  var selectedProvider = 'all';

  // ========== AUTOCOMPLETE ==========
  var slotInput = document.getElementById('slot-name');
  var autoList = document.getElementById('autocomplete-list');

  function getFilteredSlots(query) {
    var q = query.toLowerCase();
    var filtered = SLOTS_DB;
    if (selectedProvider !== 'all') {
      filtered = filtered.filter(function(s) { return s.p === selectedProvider; });
    }
    if (q.length < 2) return [];
    return filtered.filter(function(s) {
      return s.n.toLowerCase().indexOf(q) !== -1;
    }).slice(0, 10);
  }

  function showAutocomplete() {
    var query = slotInput.value;
    var matches = getFilteredSlots(query);
    if (matches.length === 0) {
      autoList.classList.add('hidden');
      return;
    }
    autoList.innerHTML = '';
    matches.forEach(function(s) {
      var item = document.createElement('div');
      item.className = 'px-3 py-2 hover:bg-[#2a2d35] cursor-pointer transition-colors flex items-center justify-between';
      item.innerHTML = '<span class="text-white text-sm font-medium">' + highlightMatch(s.n, query) + '</span><span class="text-gray-600 text-[10px]">' + s.p + '</span>';
      item.addEventListener('mousedown', function(e) {
        e.preventDefault();
        slotInput.value = s.n;
        autoList.classList.add('hidden');
      });
      autoList.appendChild(item);
    });
    autoList.classList.remove('hidden');
  }

  function highlightMatch(text, query) {
    var idx = text.toLowerCase().indexOf(query.toLowerCase());
    if (idx === -1) return text;
    return text.substring(0, idx) + '<span class="text-primary font-bold">' + text.substring(idx, idx + query.length) + '</span>' + text.substring(idx + query.length);
  }

  slotInput.addEventListener('input', showAutocomplete);
  slotInput.addEventListener('focus', function() { if (slotInput.value.length >= 2) showAutocomplete(); });
  slotInput.addEventListener('blur', function() { setTimeout(function() { autoList.classList.add('hidden'); }, 150); });

  // Provider filter
  document.querySelectorAll('.provider-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      selectedProvider = btn.dataset.provider;
      document.querySelectorAll('.provider-btn').forEach(function(b) {
        b.className = 'provider-btn bg-bg-surface text-gray-400 text-[10px] font-bold px-3 py-1.5 rounded-full cursor-pointer transition-all border border-bg-border hover:border-primary/30';
      });
      btn.className = 'provider-btn bg-primary text-white text-[10px] font-bold px-3 py-1.5 rounded-full cursor-pointer transition-all';
      // Re-trigger autocomplete if input has text
      if (slotInput.value.length >= 2) showAutocomplete();
    });
  });

  // Random slot
  document.getElementById('random-slot-btn').addEventListener('click', function() {
    var pool = SLOTS_DB;
    if (selectedProvider !== 'all') {
      pool = pool.filter(function(s) { return s.p === selectedProvider; });
    }
    var random = pool[Math.floor(Math.random() * pool.length)];
    slotInput.value = random.n;
    autoList.classList.add('hidden');
  });

  // ========== BONUS HUNT LOGIC ==========
  var slots = []; // [{name, bet, result, multi, status}]
  var huntName = 'Bonus Hunt ' + new Date().toLocaleDateString('fr-FR');

  function updateStats() {
    var count = slots.length;
    var invested = 0, won = 0, opened = 0;

    slots.forEach(function(s) {
      invested += s.bet;
      if (s.result !== null) {
        won += s.result;
        opened++;
      }
    });

    var profit = won - invested;
    var avgMulti = opened > 0 ? (won / slots.filter(function(s){return s.result !== null}).reduce(function(a,s){return a + s.bet}, 0)) : 0;
    var breakeven = invested > 0 ? (invested / (count > 0 ? slots.reduce(function(a,s){return a + s.bet}, 0) / count : 1)) : 0;
    // Break even = total invested / average bet per slot => needed avg multi
    var avgBet = count > 0 ? invested / count : 0;
    var breakEvenMulti = avgBet > 0 ? invested / (avgBet * count) * count : 0;
    // Simpler: breakeven multi = total invested / total bet of remaining unopened
    var remainingBet = slots.filter(function(s){return s.result === null}).reduce(function(a,s){return a + s.bet}, 0);
    var neededFromRemaining = invested - won;
    var beMulti = remainingBet > 0 ? neededFromRemaining / remainingBet : 0;
    if (beMulti < 0) beMulti = 0;

    document.getElementById('stat-count').textContent = count;
    document.getElementById('stat-invested').textContent = invested.toFixed(2) + '€';
    document.getElementById('stat-won').textContent = won.toFixed(2) + '€';

    var profitEl = document.getElementById('stat-profit');
    profitEl.textContent = (profit >= 0 ? '+' : '') + profit.toFixed(2) + '€';
    profitEl.style.color = profit >= 0 ? '#22c55e' : '#ef4444';

    document.getElementById('stat-avg-multi').textContent = avgMulti > 0 ? avgMulti.toFixed(2) + '×' : '—';

    var beEl = document.getElementById('stat-breakeven');
    if (opened >= count && count > 0) {
      beEl.textContent = profit >= 0 ? '✅' : '❌';
    } else if (remainingBet > 0 && neededFromRemaining > 0) {
      beEl.textContent = beMulti.toFixed(2) + '×';
    } else {
      beEl.textContent = profit >= 0 ? '✅' : '—';
    }

    var progress = count > 0 ? Math.round(opened / count * 100) : 0;
    document.getElementById('stat-progress-bar').style.width = progress + '%';
    document.getElementById('stat-progress-text').textContent = opened + '/' + count + ' ouverts';
  }

  function renderTable() {
    var tbody = document.getElementById('slots-table');
    var empty = document.getElementById('empty-state');

    if (slots.length === 0) {
      tbody.innerHTML = '';
      empty.style.display = 'block';
      updateStats();
      updateOpenBtn();
      return;
    }

    empty.style.display = 'none';
    var html = '';

    slots.forEach(function(s, i) {
      var multi = (s.result !== null && s.bet > 0) ? (s.result / s.bet).toFixed(2) : '—';
      var statusClass, statusText;
      if (s.result === null) {
        statusClass = 'bg-gold/10 text-gold';
        statusText = 'En attente';
      } else if (s.result >= s.bet) {
        statusClass = 'bg-accent-green/10 text-accent-green';
        statusText = 'Gagné';
      } else {
        statusClass = 'bg-accent-red/10 text-accent-red';
        statusText = 'Perdu';
      }

      html += '<tr class="border-b border-bg-border/30 hover:bg-bg-surface/50 transition-colors">';
      html += '<td class="py-3 px-4 text-primary font-bold text-sm">' + (i + 1) + '</td>';
      html += '<td class="py-3 px-4 text-white font-medium text-sm">' + escapeHtml(s.name) + '</td>';
      html += '<td class="py-3 px-4 text-gray-300 text-sm">' + s.bet.toFixed(2) + '€</td>';
      html += '<td class="py-3 px-4">';
      if (s.result === null) {
        html += '<input type="number" step="0.01" min="0" placeholder="Résultat" data-idx="' + i + '" class="result-input bg-bg-surface border border-bg-border text-white text-sm px-2 py-1.5 rounded-lg w-24 outline-none focus:border-primary/50" />';
        html += '<button data-idx="' + i + '" class="confirm-result-btn bg-accent-green/20 text-accent-green text-xs font-bold px-2 py-1.5 rounded-lg ml-1 hover:bg-accent-green/30">✓</button>';
      } else {
        html += '<span class="' + (s.result >= s.bet ? 'text-accent-green' : 'text-accent-red') + ' font-bold text-sm">' + s.result.toFixed(2) + '€</span>';
      }
      html += '</td>';
      html += '<td class="py-3 px-4 text-gold font-bold text-sm">' + (multi !== '—' ? multi + '×' : '—') + '</td>';
      html += '<td class="py-3 px-4"><span class="' + statusClass + ' text-xs font-bold px-2 py-1 rounded">' + statusText + '</span></td>';
      html += '<td class="py-3 px-4"><button data-idx="' + i + '" class="delete-slot-btn text-gray-600 hover:text-accent-red text-sm transition-colors">✕</button></td>';
      html += '</tr>';
    });

    tbody.innerHTML = html;

    // Bind result confirm buttons
    document.querySelectorAll('.confirm-result-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var idx = parseInt(btn.dataset.idx);
        var input = document.querySelector('.result-input[data-idx="' + idx + '"]');
        var val = parseFloat(input.value);
        if (isNaN(val) || val < 0) return;
        slots[idx].result = val;
        renderTable();
      });
    });

    // Bind result inputs (enter key)
    document.querySelectorAll('.result-input').forEach(function(inp) {
      inp.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
          var idx = parseInt(inp.dataset.idx);
          var val = parseFloat(inp.value);
          if (isNaN(val) || val < 0) return;
          slots[idx].result = val;
          renderTable();
        }
      });
    });

    // Bind delete buttons
    document.querySelectorAll('.delete-slot-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var idx = parseInt(btn.dataset.idx);
        slots.splice(idx, 1);
        renderTable();
      });
    });

    updateStats();
    updateOpenBtn();
  }

  function escapeHtml(str) {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  // Add slot
  document.getElementById('add-slot-btn').addEventListener('click', function() {
    var name = document.getElementById('slot-name').value.trim();
    var bet = parseFloat(document.getElementById('slot-bet').value);
    if (!name || isNaN(bet) || bet <= 0) return;

    slots.push({ name: name, bet: bet, result: null });
    document.getElementById('slot-name').value = '';
    renderTable();
  });

  // Enter key on slot name
  document.getElementById('slot-name').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') document.getElementById('add-slot-btn').click();
  });

  // Save hunt
  document.getElementById('save-hunt-btn').addEventListener('click', function() {
    var hunts = JSON.parse(localStorage.getItem('bonus_hunts') || '{}');
    var name = prompt('Nom du Bonus Hunt :', huntName);
    if (!name) return;
    huntName = name;
    hunts[name] = { slots: slots, date: new Date().toISOString() };
    localStorage.setItem('bonus_hunts', JSON.stringify(hunts));
    updateHuntSelect();
    alert('Bonus Hunt "' + name + '" sauvegardé !');
  });

  // Delete hunt
  document.getElementById('delete-hunt-btn').addEventListener('click', function() {
    if (!confirm('Supprimer ce Bonus Hunt ?')) return;
    var sel = document.getElementById('load-hunt-select').value;
    if (sel) {
      var hunts = JSON.parse(localStorage.getItem('bonus_hunts') || '{}');
      delete hunts[sel];
      localStorage.setItem('bonus_hunts', JSON.stringify(hunts));
      updateHuntSelect();
    }
    slots = [];
    renderTable();
  });

  // New hunt
  document.getElementById('new-hunt-btn').addEventListener('click', function() {
    if (slots.length > 0 && !confirm('Commencer un nouveau Bonus Hunt ? (Les données non sauvegardées seront perdues)')) return;
    slots = [];
    huntName = 'Bonus Hunt ' + new Date().toLocaleDateString('fr-FR');
    document.getElementById('load-hunt-select').value = '';
    renderTable();
  });

  // Load hunt
  document.getElementById('load-hunt-select').addEventListener('change', function() {
    var name = this.value;
    if (!name) return;
    var hunts = JSON.parse(localStorage.getItem('bonus_hunts') || '{}');
    if (hunts[name]) {
      huntName = name;
      slots = hunts[name].slots;
      renderTable();
    }
  });

  function updateHuntSelect() {
    var sel = document.getElementById('load-hunt-select');
    var hunts = JSON.parse(localStorage.getItem('bonus_hunts') || '{}');
    sel.innerHTML = '<option value="">-- Charger un hunt --</option>';
    Object.keys(hunts).forEach(function(name) {
      var opt = document.createElement('option');
      opt.value = name;
      opt.textContent = name + ' (' + hunts[name].slots.length + ' bonus)';
      sel.appendChild(opt);
    });
  }

  // ========== OPEN BONUS HUNT ==========
  var openIdx = 0;
  var openingActive = false;

  function updateOpenBtn() {
    var btn = document.getElementById('open-hunt-btn');
    var unopened = slots.filter(function(s) { return s.result === null; }).length;
    if (unopened > 0) {
      btn.disabled = false;
      btn.textContent = '🎰 Ouvrir le Bonus Hunt (' + unopened + ' bonus)';
    } else if (slots.length > 0) {
      btn.disabled = true;
      btn.textContent = '✅ Tous les bonus sont ouverts !';
    } else {
      btn.disabled = true;
      btn.textContent = '🎰 Ouvrir le Bonus Hunt';
    }
  }

  document.getElementById('open-hunt-btn').addEventListener('click', function() {
    var unopened = [];
    slots.forEach(function(s, i) { if (s.result === null) unopened.push(i); });
    if (unopened.length === 0) return;

    openingActive = true;
    openIdx = 0;
    showOpeningOverlay(unopened);
  });

  function showOpeningOverlay(unopenedIndices) {
    var overlay = document.getElementById('opening-overlay');
    overlay.classList.remove('hidden');

    var currentOpenList = unopenedIndices.slice();
    var currentPos = 0;

    function showSlot() {
      if (currentPos >= currentOpenList.length) {
        // All done
        showFinalResult();
        return;
      }

      var idx = currentOpenList[currentPos];
      var s = slots[idx];

      document.getElementById('opening-counter').textContent = 'Bonus ' + (currentPos + 1) + ' / ' + currentOpenList.length;
      document.getElementById('opening-slot-name').textContent = s.name;
      document.getElementById('opening-bet').textContent = s.bet.toFixed(2) + '€';

      // Reset card to spinner
      document.getElementById('opening-spinner').classList.remove('hidden');
      document.getElementById('opening-result-display').classList.add('hidden');
      document.getElementById('opening-input-area').style.display = 'block';
      document.getElementById('opening-next-area').classList.add('hidden');
      document.getElementById('opening-done-area').classList.add('hidden');
      document.getElementById('opening-result-input').value = '';
      document.getElementById('opening-result-input').focus();

      // Animate card border
      var card = document.getElementById('opening-card');
      card.style.borderColor = '#2a2d35';
      card.style.animation = 'none';
    }

    function confirmResult() {
      var val = parseFloat(document.getElementById('opening-result-input').value);
      if (isNaN(val) || val < 0) return;

      var idx = currentOpenList[currentPos];
      slots[idx].result = val;
      var multi = slots[idx].bet > 0 ? val / slots[idx].bet : 0;

      // Show result with animation
      document.getElementById('opening-spinner').classList.add('hidden');
      var resultDisplay = document.getElementById('opening-result-display');
      resultDisplay.classList.remove('hidden');

      var amountEl = document.getElementById('opening-amount');
      var multiEl = document.getElementById('opening-multi');
      amountEl.textContent = val.toFixed(2) + '€';
      multiEl.textContent = multi.toFixed(2) + '×';

      var card = document.getElementById('opening-card');
      if (val >= slots[idx].bet) {
        amountEl.style.color = '#22c55e';
        multiEl.style.color = '#22c55e';
        card.style.borderColor = '#22c55e';
      } else {
        amountEl.style.color = '#ef4444';
        multiEl.style.color = '#ef4444';
        card.style.borderColor = '#ef4444';
      }

      // Play sound
      try {
        var ctx = new (window.AudioContext || window.webkitAudioContext)();
        var osc = ctx.createOscillator(); var gain = ctx.createGain();
        osc.connect(gain); gain.connect(ctx.destination);
        if (val >= slots[idx].bet) {
          osc.frequency.value = 800; osc.type = 'sine'; gain.gain.value = 0.1;
          gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.3);
          osc.start(); osc.stop(ctx.currentTime + 0.3);
        } else {
          osc.frequency.value = 200; osc.type = 'sawtooth'; gain.gain.value = 0.08;
          gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.3);
          osc.start(); osc.stop(ctx.currentTime + 0.3);
        }
      } catch(e) {}

      document.getElementById('opening-input-area').style.display = 'none';

      if (currentPos < currentOpenList.length - 1) {
        document.getElementById('opening-next-area').classList.remove('hidden');
      } else {
        // Last one — show final
        setTimeout(showFinalResult, 800);
      }

      renderTable();
    }

    function showFinalResult() {
      document.getElementById('opening-spinner').classList.add('hidden');
      document.getElementById('opening-result-display').classList.add('hidden');
      document.getElementById('opening-input-area').style.display = 'none';
      document.getElementById('opening-next-area').classList.add('hidden');
      document.getElementById('opening-done-area').classList.remove('hidden');

      var invested = 0, won = 0;
      slots.forEach(function(s) {
        invested += s.bet;
        if (s.result !== null) won += s.result;
      });
      var profit = won - invested;
      var el = document.getElementById('opening-final-profit');
      el.textContent = (profit >= 0 ? '+' : '') + profit.toFixed(2) + '€';
      el.style.color = profit >= 0 ? '#22c55e' : '#ef4444';

      document.getElementById('opening-counter').textContent = 'Bonus Hunt terminé !';
      document.getElementById('opening-slot-name').textContent = profit >= 0 ? '🎉 Profit !' : '😢 Perte';
      document.getElementById('opening-bet').textContent = won.toFixed(2) + '€ gagnés sur ' + invested.toFixed(2) + '€ investis';
    }

    // Bind events
    var confirmBtn = document.getElementById('opening-confirm-btn');
    var nextBtn = document.getElementById('opening-next-btn');
    var closeBtn = document.getElementById('opening-close-btn');
    var skipBtn = document.getElementById('opening-skip-btn');
    var resultInput = document.getElementById('opening-result-input');

    // Remove old listeners by cloning
    var newConfirm = confirmBtn.cloneNode(true);
    confirmBtn.parentNode.replaceChild(newConfirm, confirmBtn);
    var newNext = nextBtn.cloneNode(true);
    nextBtn.parentNode.replaceChild(newNext, nextBtn);
    var newClose = closeBtn.cloneNode(true);
    closeBtn.parentNode.replaceChild(newClose, closeBtn);
    var newSkip = skipBtn.cloneNode(true);
    skipBtn.parentNode.replaceChild(newSkip, skipBtn);

    newConfirm.addEventListener('click', confirmResult);
    resultInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') confirmResult(); });
    newNext.addEventListener('click', function() { currentPos++; showSlot(); });
    newClose.addEventListener('click', function() { overlay.classList.add('hidden'); openingActive = false; renderTable(); });
    newSkip.addEventListener('click', function() { overlay.classList.add('hidden'); openingActive = false; renderTable(); });

    showSlot();
  }

  // Init
  updateHuntSelect();
  renderTable();
})();
</script>
