---
import Layout from '../layouts/Layout.astro';
import { casinos, discordUrl } from '../data/casinos';
---

<Layout title="Giveaway | MelchiorBonus" description="Participe aux giveaways MelchiorBonus et gagne des bonus gratuits, des free spins et du cash !">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-10">
      <div class="inline-flex items-center gap-2 bg-[#5865F2]/10 border border-[#5865F2]/20 text-[#5865F2] text-sm font-medium px-4 py-1.5 rounded-full mb-4">
        <span>🎁</span>
        <span>Giveaway en cours</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-4">
        🎉 <span class="gradient-text">Giveaways</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-xl mx-auto">
        Gagne des bonus gratuits, des free spins et du cash chaque jour sur notre Discord !
      </p>
    </div>

    <!-- Current Giveaway -->
    <div class="bg-bg-card border border-bg-border rounded-2xl p-8 mb-8 text-center fade-in">
      <div class="w-20 h-20 bg-[#5865F2]/10 rounded-2xl flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-[#5865F2]" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
      </div>
      <h2 class="text-2xl font-extrabold text-white mb-3">Rejoins le Discord pour participer</h2>
      <p class="text-gray-400 mb-6 max-w-md mx-auto">
        Tous nos giveaways se font sur Discord. Rejoins la communauté MelchiorCorp pour ne rien rater !
      </p>
      <a href={discordUrl} target="_blank" rel="noopener" class="btn-glow inline-flex items-center gap-2 bg-[#5865F2] hover:bg-[#4752C4] text-white font-bold px-8 py-4 rounded-xl transition-all text-lg">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
        Rejoindre le Discord →
      </a>
    </div>

    <!-- How it works -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-10 fade-in">
      <div class="bg-bg-card border border-bg-border rounded-2xl p-6 text-center card-hover">
        <span class="text-3xl block mb-3">1️⃣</span>
        <h3 class="text-white font-bold mb-2">Rejoins le Discord</h3>
        <p class="text-gray-500 text-sm">Clique sur le bouton ci-dessus et rejoins le serveur MelchiorCorp</p>
      </div>
      <div class="bg-bg-card border border-bg-border rounded-2xl p-6 text-center card-hover">
        <span class="text-3xl block mb-3">2️⃣</span>
        <h3 class="text-white font-bold mb-2">Participe au giveaway</h3>
        <p class="text-gray-500 text-sm">Va dans le salon #giveaway et clique sur le bouton pour participer</p>
      </div>
      <div class="bg-bg-card border border-bg-border rounded-2xl p-6 text-center card-hover">
        <span class="text-3xl block mb-3">3️⃣</span>
        <h3 class="text-white font-bold mb-2">Gagne ton prix</h3>
        <p class="text-gray-500 text-sm">Le gagnant est tiré au sort et reçoit son bonus directement !</p>
      </div>
    </div>

    <!-- Past Giveaways -->
    <div class="bg-bg-card border border-bg-border rounded-2xl p-6 mb-8 fade-in">
      <h3 class="text-white font-bold text-lg mb-4">Giveaways récents</h3>
      <div class="space-y-3" id="giveaway-list">
        <div class="flex items-center justify-between bg-bg-surface border border-bg-border rounded-xl p-4">
          <div class="flex items-center gap-3">
            <span class="text-2xl">🎁</span>
            <div>
              <p class="text-white font-bold text-sm">50€ de bonus gratuit</p>
              <p class="text-gray-500 text-xs">Hugo Bets — Mars 2026</p>
            </div>
          </div>
          <span class="bg-accent-green/10 text-accent-green text-xs font-bold px-3 py-1 rounded-full">Terminé</span>
        </div>
        <div class="flex items-center justify-between bg-bg-surface border border-bg-border rounded-xl p-4">
          <div class="flex items-center gap-3">
            <span class="text-2xl">🎰</span>
            <div>
              <p class="text-white font-bold text-sm">100 Free Spins Sweet Bonanza</p>
              <p class="text-gray-500 text-xs">ShinyWilds — Mars 2026</p>
            </div>
          </div>
          <span class="bg-accent-green/10 text-accent-green text-xs font-bold px-3 py-1 rounded-full">Terminé</span>
        </div>
        <div class="flex items-center justify-between bg-bg-surface border border-bg-border rounded-xl p-4">
          <div class="flex items-center gap-3">
            <span class="text-2xl">💰</span>
            <div>
              <p class="text-white font-bold text-sm">25€ cash offert</p>
              <p class="text-gray-500 text-xs">Grandz Bet — Février 2026</p>
            </div>
          </div>
          <span class="bg-accent-green/10 text-accent-green text-xs font-bold px-3 py-1 rounded-full">Terminé</span>
        </div>
      </div>
    </div>

    <!-- Casinos partenaires -->
    <div class="fade-in">
      <h3 class="text-white font-bold text-lg mb-4">Nos casinos partenaires</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {casinos.slice(0, 3).map((casino) => (
          <a href={casino.affiliateUrl} target="_blank" rel="nofollow noopener" class="group bg-bg-card border border-bg-border rounded-xl p-4 hover:border-primary/30 transition-all flex items-center gap-3 card-hover">
            <span class="text-2xl">{casino.logo}</span>
            <div>
              <p class="text-white font-bold group-hover:text-primary transition-colors">{casino.name}</p>
              <p class="text-gray-500 text-xs">{casino.bonusAmount}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
