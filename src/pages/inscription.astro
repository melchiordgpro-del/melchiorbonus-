---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Inscription | MelchiorBonus" description="Créez votre compte MelchiorBonus gratuitement.">
  <section class="max-w-md mx-auto px-4 sm:px-6 py-20">
    <div class="text-center mb-8">
      <a href="/" class="inline-flex items-center gap-2 text-2xl font-extrabold mb-6">
        <span class="text-primary text-3xl">♠</span>
        <span class="text-white">Melchior<span class="text-primary">Bonus</span></span>
      </a>
      <h1 class="text-2xl font-extrabold text-white mb-2">Créer un compte</h1>
      <p class="text-gray-400 text-sm">Rejoins la communauté MelchiorBonus gratuitement</p>
    </div>

    <div class="bg-bg-card border border-bg-border rounded-2xl p-8">
      <!-- Social signup buttons first -->
      <div class="space-y-3 mb-6">
        <button id="btn-google" class="w-full flex items-center justify-center gap-3 bg-white hover:bg-gray-100 text-gray-800 font-bold py-3.5 rounded-xl transition-all cursor-pointer">
          <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          S'inscrire avec Google
        </button>
        <button id="btn-discord" class="w-full flex items-center justify-center gap-3 bg-[#5865F2] hover:bg-[#4752C4] text-white font-bold py-3.5 rounded-xl transition-all cursor-pointer">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
          S'inscrire avec Discord
        </button>
      </div>

      <div class="relative mb-6">
        <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-bg-border"></div></div>
        <div class="relative flex justify-center"><span class="bg-bg-card px-4 text-sm text-gray-500">ou par e-mail</span></div>
      </div>

      <form id="signup-form" class="space-y-5">
        <div>
          <label for="username" class="block text-sm font-medium text-gray-300 mb-2">Pseudo</label>
          <input type="text" id="username" name="username" required placeholder="Ton pseudo" class="w-full bg-bg-surface border border-bg-border rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all" />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-gray-300 mb-2">Adresse e-mail</label>
          <input type="email" id="email" name="email" required placeholder="votre@email.com" class="w-full bg-bg-surface border border-bg-border rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all" />
        </div>
        <div>
          <div class="flex items-center justify-between mb-2">
            <label for="password" class="block text-sm font-medium text-gray-300">Mot de passe</label>
            <button type="button" id="generate-pw" class="text-xs text-primary hover:text-primary-light font-medium cursor-pointer">
              🔑 Générer automatiquement
            </button>
          </div>
          <div class="relative">
            <input type="password" id="password" name="password" required minlength="6" placeholder="Min. 6 caractères" class="w-full bg-bg-surface border border-bg-border rounded-xl px-4 py-3 pr-12 text-white placeholder-gray-500 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all" />
            <button type="button" id="toggle-pw" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-500 hover:text-white text-sm">👁</button>
          </div>
          <p id="pw-strength" class="text-xs mt-1 hidden"></p>
        </div>
        <div>
          <label for="password2" class="block text-sm font-medium text-gray-300 mb-2">Confirmer le mot de passe</label>
          <input type="password" id="password2" name="password2" required minlength="6" placeholder="Confirme ton mot de passe" class="w-full bg-bg-surface border border-bg-border rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all" />
        </div>
        <div>
          <label class="flex items-start gap-2 cursor-pointer">
            <input type="checkbox" required class="w-4 h-4 mt-0.5 rounded bg-bg-surface border-bg-border text-primary focus:ring-primary" />
            <span class="text-sm text-gray-400">J'accepte les <a href="#" class="text-primary hover:text-primary-light">conditions d'utilisation</a> et la <a href="#" class="text-primary hover:text-primary-light">politique de confidentialité</a></span>
          </label>
        </div>
        <button type="submit" class="w-full bg-primary hover:bg-primary-light text-white font-bold py-3.5 rounded-xl transition-all duration-200 hover:shadow-lg hover:shadow-primary/20">
          Créer mon compte
        </button>
        <div id="error-msg" class="text-accent-red text-sm text-center hidden"></div>
      </form>
    </div>

    <p class="text-center text-sm text-gray-500 mt-6">
      Déjà un compte ?
      <a href="/login" class="text-primary hover:text-primary-light font-medium">Se connecter</a>
    </p>
  </section>

  <script is:inline>
    if (localStorage.getItem('melchior_logged_in') === 'true') { window.location.href = '/'; }

    function signupAs(name, method) {
      localStorage.setItem('melchior_logged_in', 'true');
      localStorage.setItem('melchior_user_name', name);
      localStorage.setItem('melchior_login_method', method);
      // Give 3000 MelchiorCoins to new users
      if (!localStorage.getItem('melchior_coins')) {
        localStorage.setItem('melchior_coins', '3000.00');
      }
      window.location.href = '/';
    }

    document.getElementById('signup-form').addEventListener('submit', function(e) {
      e.preventDefault();
      var username = document.getElementById('username').value;
      var email = document.getElementById('email').value;
      var pw = document.getElementById('password').value;
      var pw2 = document.getElementById('password2').value;
      var err = document.getElementById('error-msg');

      if (pw !== pw2) {
        err.textContent = 'Les mots de passe ne correspondent pas.';
        err.classList.remove('hidden');
        return;
      }
      err.classList.add('hidden');
      localStorage.setItem('melchior_user_email', email);
      signupAs(username, 'email');
    });

    // Generate password
    document.getElementById('generate-pw').addEventListener('click', function() {
      var chars = 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnpqrstuvwxyz23456789!@#$%&*';
      var pw = '';
      for (var i = 0; i < 16; i++) pw += chars.charAt(Math.floor(Math.random() * chars.length));
      document.getElementById('password').value = pw;
      document.getElementById('password2').value = pw;
      document.getElementById('password').type = 'text';
      document.getElementById('password2').type = 'text';
      var strength = document.getElementById('pw-strength');
      strength.textContent = '✓ Mot de passe généré — copie-le avant de continuer !';
      strength.className = 'text-xs mt-1 text-accent-green';
    });

    // Toggle password visibility
    document.getElementById('toggle-pw').addEventListener('click', function() {
      var pw = document.getElementById('password');
      pw.type = pw.type === 'password' ? 'text' : 'password';
    });

    // Supabase OAuth
    var SUPABASE_URL = 'https://kmgnjlugleunrhjcqrii.supabase.co';
    var SUPABASE_ANON = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImttZ25qbHVnbGV1bnJoamNxcmlpIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQxMDE3NTgsImV4cCI6MjA4OTY3Nzc1OH0.GTwyl2TSIcGIFUdwu6neN4X0HFmu1tjI32WMqLmRBRo';

    function supabaseOAuth(provider) {
      var redirectTo = window.location.origin + '/auth/callback';
      var url = SUPABASE_URL + '/auth/v1/authorize?provider=' + provider + '&redirect_to=' + encodeURIComponent(redirectTo);
      window.location.href = url;
    }

    document.getElementById('btn-discord').addEventListener('click', function() {
      supabaseOAuth('discord');
    });
    document.getElementById('btn-google').addEventListener('click', function() {
      supabaseOAuth('google');
    });
  </script>
</Layout>
