---
import Layout from '../../layouts/Layout.astro';
import AuthGate from '../../components/AuthGate.astro';
---

<Layout title="Roulette Première Personne | MelchiorBonus" description="Joue à la Roulette première personne sur MelchiorBonus.">
  <AuthGate>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <h1 class="text-2xl font-extrabold text-white mb-4 flex items-center gap-2">🎡 Roulette Européenne</h1>

    <div class="flex flex-col lg:flex-row gap-4">
      <!-- LEFT: Controls -->
      <div class="lg:w-72 flex-shrink-0 bg-bg-card border border-bg-border rounded-2xl p-5 flex flex-col gap-4">
        <div>
          <p class="text-gray-500 text-[10px] uppercase tracking-wider mb-1">Solde</p>
          <p class="text-gold font-extrabold text-2xl" id="balance">1000 Ⓜ</p>
        </div>
        <div class="border-t border-bg-border"></div>
        <div>
          <p class="text-gray-500 text-[10px] uppercase tracking-wider mb-1">Mise</p>
          <p class="text-primary-light font-extrabold text-xl" id="current-bet-display">10 Ⓜ</p>
        </div>

        <div>
          <p class="text-gray-500 text-[10px] uppercase tracking-wider mb-2">Jetons</p>
          <div class="grid grid-cols-3 gap-2">
            <div data-bet="1" class="chip w-full aspect-square rounded-full font-bold text-xs text-white flex items-center justify-center cursor-pointer select-none hover:scale-110 transition-transform" style="background:radial-gradient(circle at 35% 35%,#9ca3af,#4b5563);box-shadow:0 3px 6px rgba(0,0,0,0.4);border:3px dashed rgba(255,255,255,0.3);">1</div>
            <div data-bet="5" class="chip w-full aspect-square rounded-full font-bold text-xs text-white flex items-center justify-center cursor-pointer select-none hover:scale-110 transition-transform" style="background:radial-gradient(circle at 35% 35%,#ef4444,#991b1b);box-shadow:0 3px 6px rgba(0,0,0,0.4);border:3px dashed rgba(255,255,255,0.3);">5</div>
            <div data-bet="10" class="chip w-full aspect-square rounded-full font-bold text-xs text-white flex items-center justify-center cursor-pointer select-none hover:scale-110 transition-transform ring-2 ring-primary" style="background:radial-gradient(circle at 35% 35%,#3b82f6,#1e3a8a);box-shadow:0 3px 6px rgba(0,0,0,0.4);border:3px dashed rgba(255,255,255,0.3);">10</div>
            <div data-bet="25" class="chip w-full aspect-square rounded-full font-bold text-xs text-white flex items-center justify-center cursor-pointer select-none hover:scale-110 transition-transform" style="background:radial-gradient(circle at 35% 35%,#22c55e,#15803d);box-shadow:0 3px 6px rgba(0,0,0,0.4);border:3px dashed rgba(255,255,255,0.3);">25</div>
            <div data-bet="50" class="chip w-full aspect-square rounded-full font-bold text-xs text-black flex items-center justify-center cursor-pointer select-none hover:scale-110 transition-transform" style="background:radial-gradient(circle at 35% 35%,#facc15,#a16207);box-shadow:0 3px 6px rgba(0,0,0,0.4);border:3px dashed rgba(255,255,255,0.3);">50</div>
            <div data-bet="100" class="chip w-full aspect-square rounded-full font-bold text-xs text-white flex items-center justify-center cursor-pointer select-none hover:scale-110 transition-transform" style="background:radial-gradient(circle at 35% 35%,#a855f7,#581c87);box-shadow:0 3px 6px rgba(0,0,0,0.4);border:3px dashed rgba(255,255,255,0.3);">100</div>
          </div>
        </div>
        <div class="border-t border-bg-border"></div>

        <div>
          <p class="text-gray-500 text-[10px] uppercase tracking-wider mb-2">Pari</p>
          <div class="grid grid-cols-2 gap-2">
            <button data-type="rouge" class="type-btn bg-red-700 text-white font-bold py-2.5 rounded-lg text-xs ring-2 ring-primary transition-all hover:brightness-125">🔴 Rouge</button>
            <button data-type="noir" class="type-btn bg-gray-900 border border-gray-500 text-white font-bold py-2.5 rounded-lg text-xs transition-all hover:brightness-125">⚫ Noir</button>
            <button data-type="pair" class="type-btn bg-bg-surface border border-bg-border text-gray-300 font-bold py-2.5 rounded-lg text-xs transition-all hover:border-primary/30">Pair</button>
            <button data-type="impair" class="type-btn bg-bg-surface border border-bg-border text-gray-300 font-bold py-2.5 rounded-lg text-xs transition-all hover:border-primary/30">Impair</button>
            <button data-type="1-18" class="type-btn bg-bg-surface border border-bg-border text-gray-300 font-bold py-2.5 rounded-lg text-xs transition-all hover:border-primary/30">1-18</button>
            <button data-type="19-36" class="type-btn bg-bg-surface border border-bg-border text-gray-300 font-bold py-2.5 rounded-lg text-xs transition-all hover:border-primary/30">19-36</button>
          </div>
        </div>

        <button id="btn-spin" class="btn-glow bg-accent-green hover:bg-accent-green/80 text-white font-bold py-3.5 rounded-xl transition-all text-sm uppercase tracking-wider w-full">🎡 Lancer la roulette !</button>

        <div class="border-t border-bg-border pt-3">
          <p class="text-gray-500 text-[10px] uppercase tracking-wider mb-2">Derniers résultats</p>
          <div id="history" class="flex items-center gap-1.5 flex-wrap"></div>
        </div>
      </div>

      <!-- RIGHT: Wheel + Result -->
      <div class="flex-1 flex flex-col gap-4">
        <div class="bg-bg-card border border-bg-border rounded-2xl p-8 flex flex-col items-center" style="background: radial-gradient(ellipse at 50% 60%, #1a2e1a, #0c0b1e 70%);">
          <!-- Pointer -->
          <div class="relative mb-2">
            <div class="w-0 h-0 border-l-[12px] border-r-[12px] border-b-[22px] border-l-transparent border-r-transparent border-b-gold mx-auto" style="filter: drop-shadow(0 0 6px rgba(245,184,61,0.5));"></div>
          </div>
          <canvas id="roulette-wheel" width="340" height="340"></canvas>

          <!-- Last number display -->
          <div id="last-number" class="mt-4 hidden">
            <div id="last-number-circle" class="w-20 h-20 rounded-full flex items-center justify-center text-white font-extrabold text-3xl shadow-2xl mx-auto" style="box-shadow: 0 0 30px rgba(0,0,0,0.5);">
              <span id="last-number-text">0</span>
            </div>
          </div>

          <div id="result" class="text-center mt-4 min-h-[40px] flex items-center justify-center"></div>
        </div>
      </div>
    </div>
  </section>
  </AuthGate>

  <script is:inline>
    var REDS = [1,3,5,7,9,12,14,16,18,19,21,23,25,27,30,32,34,36];
    // European roulette wheel order
    var WHEEL_ORDER = [0,32,15,19,4,21,2,25,17,34,6,27,13,36,11,30,8,23,10,5,24,16,33,1,20,14,31,9,22,18,29,7,28,12,35,3,26];
    var balance = 1000, currentBet = 10, betType = 'rouge', spinning = false;
    var historyArr = [];

    function isRed(n) { return REDS.indexOf(n) !== -1; }

    var canvas = document.getElementById('roulette-wheel');
    var ctx = canvas.getContext('2d');
    var CX = 170, CY = 170, R = 155;

    function drawWheel(angle) {
      ctx.clearRect(0, 0, 340, 340);
      var total = WHEEL_ORDER.length;
      var arc = (Math.PI * 2) / total;

      // Outer wooden rim
      ctx.beginPath(); ctx.arc(CX, CY, R + 12, 0, Math.PI * 2);
      var rimGrad = ctx.createRadialGradient(CX, CY, R, CX, CY, R + 12);
      rimGrad.addColorStop(0, '#5c3a1e');
      rimGrad.addColorStop(0.5, '#8b6914');
      rimGrad.addColorStop(1, '#3d2411');
      ctx.fillStyle = rimGrad;
      ctx.fill();

      // Metal dividers ring
      ctx.beginPath(); ctx.arc(CX, CY, R + 2, 0, Math.PI * 2);
      ctx.strokeStyle = '#c0a060';
      ctx.lineWidth = 2;
      ctx.stroke();

      // Number segments
      for (var i = 0; i < total; i++) {
        var num = WHEEL_ORDER[i];
        var startA = angle + i * arc;

        // Colored segment
        ctx.beginPath();
        ctx.moveTo(CX, CY);
        ctx.arc(CX, CY, R, startA, startA + arc);
        ctx.closePath();

        if (num === 0) {
          ctx.fillStyle = '#15803d';
        } else if (isRed(num)) {
          ctx.fillStyle = '#b91c1c';
        } else {
          ctx.fillStyle = '#171717';
        }
        ctx.fill();

        // Divider lines
        ctx.strokeStyle = '#c0a060';
        ctx.lineWidth = 0.8;
        ctx.beginPath();
        ctx.moveTo(CX + Math.cos(startA) * 60, CY + Math.sin(startA) * 60);
        ctx.lineTo(CX + Math.cos(startA) * R, CY + Math.sin(startA) * R);
        ctx.stroke();

        // Number text
        ctx.save();
        ctx.translate(CX, CY);
        ctx.rotate(startA + arc / 2);
        ctx.fillStyle = '#ffffff';
        ctx.font = 'bold 11px Inter, sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(num.toString(), R * 0.82, 0);
        ctx.restore();
      }

      // Inner ring (gold)
      ctx.beginPath(); ctx.arc(CX, CY, 58, 0, Math.PI * 2);
      ctx.strokeStyle = '#c0a060';
      ctx.lineWidth = 2;
      ctx.stroke();

      // Center hub
      ctx.beginPath(); ctx.arc(CX, CY, 55, 0, Math.PI * 2);
      var hubGrad = ctx.createRadialGradient(CX - 10, CY - 10, 5, CX, CY, 55);
      hubGrad.addColorStop(0, '#2a2848');
      hubGrad.addColorStop(0.7, '#15132e');
      hubGrad.addColorStop(1, '#0c0b1e');
      ctx.fillStyle = hubGrad;
      ctx.fill();

      // Center cross/diamond pattern
      ctx.strokeStyle = '#c0a06044';
      ctx.lineWidth = 1;
      for (var j = 0; j < 8; j++) {
        var a = (Math.PI * 2 / 8) * j;
        ctx.beginPath();
        ctx.moveTo(CX + Math.cos(a) * 15, CY + Math.sin(a) * 15);
        ctx.lineTo(CX + Math.cos(a) * 50, CY + Math.sin(a) * 50);
        ctx.stroke();
      }

      // Center circle
      ctx.beginPath(); ctx.arc(CX, CY, 14, 0, Math.PI * 2);
      var centerGrad = ctx.createRadialGradient(CX - 3, CY - 3, 2, CX, CY, 14);
      centerGrad.addColorStop(0, '#d4a017');
      centerGrad.addColorStop(1, '#8b6914');
      ctx.fillStyle = centerGrad;
      ctx.fill();
    }

    drawWheel(0);

    // Chips
    document.querySelectorAll('.chip').forEach(function(c) {
      c.addEventListener('click', function() {
        if (spinning) return;
        currentBet = parseInt(c.dataset.bet);
        document.querySelectorAll('.chip').forEach(function(b) { b.classList.remove('ring-2', 'ring-primary'); });
        c.classList.add('ring-2', 'ring-primary');
        document.getElementById('current-bet-display').textContent = currentBet + ' Ⓜ';
      });
    });

    // Bet type
    document.querySelectorAll('.type-btn').forEach(function(b) {
      b.addEventListener('click', function() {
        betType = b.dataset.type;
        document.querySelectorAll('.type-btn').forEach(function(x) { x.classList.remove('ring-2', 'ring-primary'); });
        b.classList.add('ring-2', 'ring-primary');
      });
    });

    // Spin
    document.getElementById('btn-spin').addEventListener('click', function() {
      if (spinning || balance < currentBet) return;
      spinning = true;
      balance -= currentBet;
      document.getElementById('balance').textContent = balance + ' Ⓜ';
      document.getElementById('result').innerHTML = '';
      document.getElementById('last-number').classList.add('hidden');

      // Pick winning number
      var winIndex = Math.floor(Math.random() * WHEEL_ORDER.length);
      var finalNum = WHEEL_ORDER[winIndex];

      // Calculate exact angle so pointer (top, -PI/2) lands on winning segment
      var arc = (Math.PI * 2) / WHEEL_ORDER.length;
      // The segment center angle for winIndex should align with -PI/2 (top)
      var segmentCenter = winIndex * arc + arc / 2;
      // We need: angle + segmentCenter = -PI/2 + 2*PI*k
      // angle = -PI/2 - segmentCenter
      var targetAngle = -Math.PI / 2 - segmentCenter;
      // Add full rotations
      var spins = 5 + Math.random() * 4; // 5-9 full rotations
      var finalAngle = targetAngle - spins * Math.PI * 2; // negative = clockwise

      var startTime = null;
      var duration = 5000; // 5 seconds

      function animSpin(ts) {
        if (!startTime) startTime = ts;
        var p = Math.min((ts - startTime) / duration, 1);
        // Ease out quart for realistic deceleration
        var eased = 1 - Math.pow(1 - p, 4);
        var currentAngle = eased * finalAngle;
        drawWheel(currentAngle);

        if (p < 1) {
          requestAnimationFrame(animSpin);
        } else {
          // Show result after a brief pause
          setTimeout(function() { showResult(finalNum); }, 500);
        }
      }
      requestAnimationFrame(animSpin);
    });

    function showResult(num) {
      spinning = false;
      var color = num === 0 ? 'vert' : isRed(num) ? 'rouge' : 'noir';
      var parity = num === 0 ? 'zero' : num % 2 === 0 ? 'pair' : 'impair';
      var half = num === 0 ? 'zero' : num <= 18 ? '1-18' : '19-36';

      // Show big number
      var lastNum = document.getElementById('last-number');
      var lastCircle = document.getElementById('last-number-circle');
      var lastText = document.getElementById('last-number-text');
      lastText.textContent = num;
      lastCircle.style.background = num === 0 ? '#15803d' : isRed(num) ? '#b91c1c' : '#171717';
      lastCircle.style.border = '4px solid ' + (num === 0 ? '#22c55e' : isRed(num) ? '#ef4444' : '#6b7280');
      lastNum.classList.remove('hidden');

      var won = false;
      if (betType === 'rouge' && color === 'rouge') won = true;
      if (betType === 'noir' && color === 'noir') won = true;
      if (betType === 'pair' && parity === 'pair') won = true;
      if (betType === 'impair' && parity === 'impair') won = true;
      if (betType === '1-18' && half === '1-18') won = true;
      if (betType === '19-36' && half === '19-36') won = true;

      var resEl = document.getElementById('result');
      if (won) {
        balance += currentBet * 2;
        var mc = parseInt(localStorage.getItem('melchior_coins') || '0') + 3;
        localStorage.setItem('melchior_coins', mc.toString());
        resEl.innerHTML = '<div class="bg-gradient-to-r from-green-500 to-green-600 text-white font-extrabold text-lg px-8 py-3 rounded-2xl shadow-xl animate-bounce">Gagné ! +' + currentBet + ' Ⓜ <span class="text-sm">+3⭐</span></div>';
      } else {
        resEl.innerHTML = '<div class="bg-gradient-to-r from-red-500 to-red-600 text-white font-extrabold text-lg px-8 py-3 rounded-2xl shadow-xl">Perdu !</div>';
      }
      document.getElementById('balance').textContent = balance + ' Ⓜ';

      // History
      historyArr.unshift(num);
      if (historyArr.length > 15) historyArr.pop();
      document.getElementById('history').innerHTML = historyArr.map(function(n) {
        var c = n === 0 ? 'bg-green-600' : isRed(n) ? 'bg-red-600' : 'bg-gray-700';
        return '<span class="' + c + ' text-white text-[10px] font-bold w-7 h-7 rounded-full flex items-center justify-center shadow">' + n + '</span>';
      }).join('');
    }
  </script>
</Layout>
