---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Roulette Virtuelle — Joue gratuitement | MelchiorBonus" description="Joue à la Roulette virtuelle gratuitement sur MelchiorBonus.">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-8">
      <h1 class="text-4xl font-extrabold text-white mb-2">🎡 Roulette</h1>
      <p class="text-gray-400">Place ta mise et tente ta chance !</p>
    </div>

    <div class="bg-bg-card border border-bg-border rounded-2xl p-8">
      <!-- Roulette Wheel Display -->
      <div class="text-center mb-8">
        <div id="wheel" class="w-40 h-40 mx-auto rounded-full border-4 border-primary/30 bg-bg-surface flex items-center justify-center mb-4 transition-all duration-500">
          <span id="wheel-number" class="text-5xl font-extrabold text-white">?</span>
        </div>
        <p id="wheel-color" class="text-gray-500 text-sm font-medium">Lance la roulette !</p>
      </div>

      <!-- Result -->
      <div id="result" class="text-center text-2xl font-extrabold mb-6 min-h-[40px]"></div>

      <!-- Balance -->
      <div class="flex items-center justify-center gap-6 mb-6">
        <div class="bg-bg-surface border border-bg-border rounded-xl px-5 py-3 text-center">
          <p class="text-gray-500 text-xs">Solde virtuel</p>
          <p class="text-gold font-extrabold text-xl" id="balance">1000</p>
        </div>
        <div class="bg-bg-surface border border-bg-border rounded-xl px-5 py-3 text-center">
          <p class="text-gray-500 text-xs">Mise</p>
          <p class="text-primary-light font-extrabold text-xl" id="current-bet">10</p>
        </div>
      </div>

      <!-- Bet controls -->
      <div class="flex items-center justify-center gap-3 mb-6">
        <button data-bet="5" class="bet-btn bg-bg-surface border border-bg-border text-white font-bold px-4 py-2 rounded-lg hover:border-primary/30 transition-all">5€</button>
        <button data-bet="10" class="bet-btn bg-primary/20 border border-primary/30 text-primary font-bold px-4 py-2 rounded-lg">10€</button>
        <button data-bet="25" class="bet-btn bg-bg-surface border border-bg-border text-white font-bold px-4 py-2 rounded-lg hover:border-primary/30 transition-all">25€</button>
        <button data-bet="50" class="bet-btn bg-bg-surface border border-bg-border text-white font-bold px-4 py-2 rounded-lg hover:border-primary/30 transition-all">50€</button>
      </div>

      <!-- Bet Type -->
      <p class="text-center text-gray-500 text-sm mb-3">Choisis ton pari :</p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
        <button data-type="rouge" class="type-btn bg-red-600/20 border border-red-500/30 text-red-400 font-bold py-3 rounded-xl hover:bg-red-600/30 transition-all">🔴 Rouge</button>
        <button data-type="noir" class="type-btn bg-gray-800 border border-gray-600 text-white font-bold py-3 rounded-xl hover:bg-gray-700 transition-all">⚫ Noir</button>
        <button data-type="pair" class="type-btn bg-bg-surface border border-bg-border text-gray-300 font-bold py-3 rounded-xl hover:border-primary/30 transition-all">Pair</button>
        <button data-type="impair" class="type-btn bg-bg-surface border border-bg-border text-gray-300 font-bold py-3 rounded-xl hover:border-primary/30 transition-all">Impair</button>
      </div>

      <!-- Spin -->
      <div class="text-center">
        <button id="btn-spin" class="bg-accent-green hover:bg-accent-green/80 text-white font-bold px-10 py-4 rounded-xl transition-all hover:shadow-lg hover:shadow-accent-green/20 text-lg">
          Lancer la roulette !
        </button>
      </div>

      <!-- History -->
      <div class="mt-8 pt-6 border-t border-bg-border">
        <p class="text-gray-500 text-xs uppercase tracking-wider mb-3">Derniers résultats</p>
        <div id="history" class="flex items-center gap-2 flex-wrap"></div>
      </div>
    </div>
  </section>

  <script>
    const redNumbers = [1,3,5,7,9,12,14,16,18,19,21,23,25,27,30,32,34,36];
    let balance = 1000, currentBet = 10, betType = 'rouge', spinning = false;
    const history: number[] = [];

    function isRed(n: number) { return redNumbers.includes(n); }

    document.querySelectorAll('.bet-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        if (spinning) return;
        currentBet = parseInt((btn as HTMLElement).dataset.bet!);
        document.querySelectorAll('.bet-btn').forEach(b => b.className = 'bet-btn bg-bg-surface border border-bg-border text-white font-bold px-4 py-2 rounded-lg hover:border-primary/30 transition-all');
        btn.className = 'bet-btn bg-primary/20 border border-primary/30 text-primary font-bold px-4 py-2 rounded-lg';
        document.getElementById('current-bet')!.textContent = currentBet.toString();
      });
    });

    document.querySelectorAll('.type-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        betType = (btn as HTMLElement).dataset.type!;
        document.querySelectorAll('.type-btn').forEach(b => b.classList.remove('ring-2', 'ring-primary'));
        btn.classList.add('ring-2', 'ring-primary');
      });
    });
    document.querySelector('[data-type="rouge"]')!.classList.add('ring-2', 'ring-primary');

    document.getElementById('btn-spin')!.addEventListener('click', () => {
      if (spinning || balance < currentBet) return;
      spinning = true;
      balance -= currentBet;
      document.getElementById('balance')!.textContent = balance.toString();

      const wheel = document.getElementById('wheel')!;
      const numEl = document.getElementById('wheel-number')!;
      const colorEl = document.getElementById('wheel-color')!;
      const resultEl = document.getElementById('result')!;

      let count = 0;
      const finalNumber = Math.floor(Math.random() * 37);
      const interval = setInterval(() => {
        const rnd = Math.floor(Math.random() * 37);
        numEl.textContent = rnd.toString();
        wheel.style.borderColor = rnd === 0 ? '#22c55e' : isRed(rnd) ? '#ef4444' : '#374151';
        count++;
        if (count > 20) {
          clearInterval(interval);
          numEl.textContent = finalNumber.toString();
          const color = finalNumber === 0 ? 'vert' : isRed(finalNumber) ? 'rouge' : 'noir';
          const parity = finalNumber === 0 ? 'zero' : finalNumber % 2 === 0 ? 'pair' : 'impair';
          wheel.style.borderColor = finalNumber === 0 ? '#22c55e' : isRed(finalNumber) ? '#ef4444' : '#374151';
          colorEl.textContent = `${finalNumber} — ${color.charAt(0).toUpperCase() + color.slice(1)}`;

          let won = false;
          if (betType === 'rouge' && color === 'rouge') won = true;
          if (betType === 'noir' && color === 'noir') won = true;
          if (betType === 'pair' && parity === 'pair') won = true;
          if (betType === 'impair' && parity === 'impair') won = true;

          if (won) {
            balance += currentBet * 2;
            resultEl.innerHTML = '<span class="text-accent-green">Gagné ! +' + currentBet + '€</span>';
          } else {
            resultEl.innerHTML = '<span class="text-accent-red">Perdu !</span>';
          }
          document.getElementById('balance')!.textContent = balance.toString();

          history.unshift(finalNumber);
          if (history.length > 15) history.pop();
          document.getElementById('history')!.innerHTML = history.map(n => {
            const c = n === 0 ? 'bg-accent-green' : isRed(n) ? 'bg-red-600' : 'bg-gray-700';
            return `<span class="${c} text-white text-xs font-bold w-8 h-8 rounded-full flex items-center justify-center">${n}</span>`;
          }).join('');

          spinning = false;
        }
      }, 80);
    });
  </script>
</Layout>
