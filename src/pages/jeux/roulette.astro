---
import Layout from '../../layouts/Layout.astro';
import AuthGate from '../../components/AuthGate.astro';
---

<Layout title="Roulette Première Personne | MelchiorBonus" description="Joue à la Roulette première personne sur MelchiorBonus.">
  <AuthGate>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <h1 class="text-2xl font-extrabold text-white mb-4 flex items-center gap-2">🎡 Roulette</h1>

    <div class="flex flex-col lg:flex-row gap-4">
      <!-- LEFT: Controls -->
      <div class="lg:w-72 flex-shrink-0 bg-bg-card border border-bg-border rounded-2xl p-5 flex flex-col gap-4">
        <div>
          <p class="text-gray-500 text-[10px] uppercase tracking-wider mb-1">Solde</p>
          <p class="text-gold font-extrabold text-2xl" id="balance">1000€</p>
        </div>
        <div class="border-t border-bg-border"></div>
        <div>
          <p class="text-gray-500 text-[10px] uppercase tracking-wider mb-1">Mise</p>
          <p class="text-primary-light font-extrabold text-xl" id="current-bet-display">10€</p>
        </div>

        <!-- Chips -->
        <div>
          <p class="text-gray-500 text-[10px] uppercase tracking-wider mb-2">Jetons</p>
          <div class="grid grid-cols-3 gap-2">
            <div data-bet="1" class="chip w-full aspect-square rounded-full font-bold text-xs text-white flex items-center justify-center cursor-pointer select-none hover:scale-110 transition-transform" style="background:radial-gradient(circle at 35% 35%,#9ca3af,#4b5563);box-shadow:0 3px 6px rgba(0,0,0,0.4);border:3px dashed rgba(255,255,255,0.3);">1</div>
            <div data-bet="5" class="chip w-full aspect-square rounded-full font-bold text-xs text-white flex items-center justify-center cursor-pointer select-none hover:scale-110 transition-transform" style="background:radial-gradient(circle at 35% 35%,#ef4444,#991b1b);box-shadow:0 3px 6px rgba(0,0,0,0.4);border:3px dashed rgba(255,255,255,0.3);">5</div>
            <div data-bet="10" class="chip w-full aspect-square rounded-full font-bold text-xs text-white flex items-center justify-center cursor-pointer select-none hover:scale-110 transition-transform ring-2 ring-primary" style="background:radial-gradient(circle at 35% 35%,#3b82f6,#1e3a8a);box-shadow:0 3px 6px rgba(0,0,0,0.4);border:3px dashed rgba(255,255,255,0.3);">10</div>
            <div data-bet="25" class="chip w-full aspect-square rounded-full font-bold text-xs text-white flex items-center justify-center cursor-pointer select-none hover:scale-110 transition-transform" style="background:radial-gradient(circle at 35% 35%,#22c55e,#15803d);box-shadow:0 3px 6px rgba(0,0,0,0.4);border:3px dashed rgba(255,255,255,0.3);">25</div>
            <div data-bet="50" class="chip w-full aspect-square rounded-full font-bold text-xs text-black flex items-center justify-center cursor-pointer select-none hover:scale-110 transition-transform" style="background:radial-gradient(circle at 35% 35%,#facc15,#a16207);box-shadow:0 3px 6px rgba(0,0,0,0.4);border:3px dashed rgba(255,255,255,0.3);">50</div>
            <div data-bet="100" class="chip w-full aspect-square rounded-full font-bold text-xs text-white flex items-center justify-center cursor-pointer select-none hover:scale-110 transition-transform" style="background:radial-gradient(circle at 35% 35%,#a855f7,#581c87);box-shadow:0 3px 6px rgba(0,0,0,0.4);border:3px dashed rgba(255,255,255,0.3);">100</div>
          </div>
        </div>
        <div class="border-t border-bg-border"></div>

        <!-- Bet Type -->
        <div>
          <p class="text-gray-500 text-[10px] uppercase tracking-wider mb-2">Type de pari</p>
          <div class="grid grid-cols-2 gap-2">
            <button data-type="rouge" class="type-btn bg-red-600 text-white font-bold py-2.5 rounded-xl text-xs ring-2 ring-primary">🔴 Rouge</button>
            <button data-type="noir" class="type-btn bg-gray-800 border border-gray-600 text-white font-bold py-2.5 rounded-xl text-xs">⚫ Noir</button>
            <button data-type="pair" class="type-btn bg-bg-surface border border-bg-border text-gray-300 font-bold py-2.5 rounded-xl text-xs">Pair</button>
            <button data-type="impair" class="type-btn bg-bg-surface border border-bg-border text-gray-300 font-bold py-2.5 rounded-xl text-xs">Impair</button>
            <button data-type="1-18" class="type-btn bg-bg-surface border border-bg-border text-gray-300 font-bold py-2.5 rounded-xl text-xs">1-18</button>
            <button data-type="19-36" class="type-btn bg-bg-surface border border-bg-border text-gray-300 font-bold py-2.5 rounded-xl text-xs">19-36</button>
          </div>
        </div>
        <div class="border-t border-bg-border"></div>

        <button id="btn-spin" class="bg-accent-green hover:bg-accent-green/80 text-white font-bold py-3 rounded-xl transition-all text-sm uppercase tracking-wider w-full">Lancer !</button>

        <!-- History -->
        <div>
          <p class="text-gray-500 text-[10px] uppercase tracking-wider mb-2">Derniers résultats</p>
          <div id="history" class="flex items-center gap-1.5 flex-wrap"></div>
        </div>
      </div>

      <!-- RIGHT: Roulette Wheel + Table -->
      <div class="flex-1 flex flex-col gap-4">
        <!-- Wheel -->
        <div class="bg-bg-card border border-bg-border rounded-2xl p-6 flex flex-col items-center">
          <div class="relative">
            <canvas id="roulette-wheel" width="300" height="300"></canvas>
            <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1 w-0 h-0 border-l-[10px] border-r-[10px] border-t-[18px] border-l-transparent border-r-transparent border-t-gold z-10"></div>
          </div>
          <div id="result" class="text-center mt-4 min-h-[40px] flex items-center justify-center"></div>
        </div>

        <!-- Betting Table Grid -->
        <div class="bg-bg-card border border-bg-border rounded-2xl p-4 overflow-x-auto">
          <div class="grid grid-cols-13 gap-0.5 min-w-[600px]" id="betting-grid">
            <!-- 0 -->
            <div class="col-span-1 row-span-3 bg-green-700 border border-green-500 rounded-l-lg text-white font-bold text-sm flex items-center justify-center cursor-pointer hover:brightness-125 transition-all h-24" data-num="0">0</div>
            <!-- Numbers 1-36 in 3 rows -->
          </div>
          <div class="grid grid-cols-12 gap-0.5 mt-0.5 min-w-[560px] ml-[calc(100%/13+2px)]" id="number-grid"></div>
        </div>
      </div>
    </div>
  </section>
  </AuthGate>

  <script is:inline>
    var REDS = [1,3,5,7,9,12,14,16,18,19,21,23,25,27,30,32,34,36];
    var WHEEL_NUMS = [0,32,15,19,4,21,2,25,17,34,6,27,13,36,11,30,8,23,10,5,24,16,33,1,20,14,31,9,22,18,29,7,28,12,35,3,26];
    var balance = 1000, currentBet = 10, betType = 'rouge', spinning = false;
    var historyArr = [];

    function isRed(n) { return REDS.includes(n); }

    // Draw wheel
    var wCanvas = document.getElementById('roulette-wheel');
    var wCtx = wCanvas.getContext('2d');
    var wheelAngle = 0;

    function drawRouletteWheel(angle) {
      var cx=150, cy=150, r=140;
      var total = WHEEL_NUMS.length;
      var arc = (Math.PI*2)/total;
      wCtx.clearRect(0,0,300,300);

      // Outer ring
      wCtx.beginPath(); wCtx.arc(cx,cy,r+5,0,Math.PI*2);
      wCtx.fillStyle='#3d2411'; wCtx.fill();

      for (var i=0;i<total;i++) {
        var num = WHEEL_NUMS[i];
        var startA = angle + i*arc;
        wCtx.beginPath(); wCtx.moveTo(cx,cy); wCtx.arc(cx,cy,r,startA,startA+arc); wCtx.closePath();
        wCtx.fillStyle = num===0?'#15803d':isRed(num)?'#dc2626':'#1f2937';
        wCtx.fill();
        wCtx.strokeStyle='rgba(255,255,255,0.15)'; wCtx.lineWidth=1; wCtx.stroke();

        // Number text
        wCtx.save(); wCtx.translate(cx,cy); wCtx.rotate(startA+arc/2);
        wCtx.fillStyle='#fff'; wCtx.font='bold 10px Inter,sans-serif'; wCtx.textAlign='center';
        wCtx.fillText(num.toString(),r*0.78,3);
        wCtx.restore();
      }

      // Inner circle
      wCtx.beginPath(); wCtx.arc(cx,cy,40,0,Math.PI*2);
      wCtx.fillStyle='#1a1838'; wCtx.fill();
      wCtx.strokeStyle='#f5b83d'; wCtx.lineWidth=3; wCtx.stroke();
      wCtx.fillStyle='#f5b83d'; wCtx.font='bold 11px Inter,sans-serif'; wCtx.textAlign='center';
      wCtx.fillText('ROULETTE',cx,cy+4);
    }
    drawRouletteWheel(0);

    // Build number grid
    var gridEl = document.getElementById('number-grid');
    var rows = [[3,6,9,12,15,18,21,24,27,30,33,36],[2,5,8,11,14,17,20,23,26,29,32,35],[1,4,7,10,13,16,19,22,25,28,31,34]];
    rows.forEach(function(row) {
      row.forEach(function(num) {
        var color = isRed(num)?'bg-red-700 border-red-500':'bg-gray-800 border-gray-600';
        var el = document.createElement('div');
        el.className = color + ' border text-white font-bold text-xs flex items-center justify-center cursor-pointer hover:brightness-125 transition-all h-8 rounded-sm';
        el.textContent = num;
        el.dataset.num = num;
        gridEl.appendChild(el);
      });
    });

    // Chips
    document.querySelectorAll('.chip').forEach(function(c) {
      c.addEventListener('click',function() {
        if (spinning) return;
        currentBet = parseInt(c.dataset.bet);
        document.querySelectorAll('.chip').forEach(function(b){b.classList.remove('ring-2','ring-primary');});
        c.classList.add('ring-2','ring-primary');
        document.getElementById('current-bet-display').textContent = currentBet+'€';
      });
    });

    // Bet type
    document.querySelectorAll('.type-btn').forEach(function(b) {
      b.addEventListener('click',function() {
        betType = b.dataset.type;
        document.querySelectorAll('.type-btn').forEach(function(x){x.classList.remove('ring-2','ring-primary');});
        b.classList.add('ring-2','ring-primary');
      });
    });

    // Spin
    document.getElementById('btn-spin').addEventListener('click', function() {
      if (spinning || balance < currentBet) return;
      spinning = true;
      balance -= currentBet;
      document.getElementById('balance').textContent = balance+'€';
      document.getElementById('result').innerHTML = '';

      var winIndex = Math.floor(Math.random()*WHEEL_NUMS.length);
      var finalNum = WHEEL_NUMS[winIndex];
      var arc = (Math.PI*2)/WHEEL_NUMS.length;
      var targetAngle = -(winIndex*arc+arc/2) - Math.PI/2;
      var spins = 4+Math.random()*3;
      var finalAngle = targetAngle + spins*Math.PI*2;
      var startTime = null, duration = 4000;

      function animSpin(ts) {
        if (!startTime) startTime=ts;
        var p = Math.min((ts-startTime)/duration,1);
        var eased = 1-Math.pow(1-p,3);
        drawRouletteWheel(eased*finalAngle);
        if (p<1) { requestAnimationFrame(animSpin); }
        else { finishSpin(finalNum); }
      }
      requestAnimationFrame(animSpin);
    });

    function finishSpin(num) {
      spinning = false;
      var color = num===0?'vert':isRed(num)?'rouge':'noir';
      var parity = num===0?'zero':num%2===0?'pair':'impair';
      var half = num===0?'zero':num<=18?'1-18':'19-36';

      var won = false;
      if (betType==='rouge'&&color==='rouge') won=true;
      if (betType==='noir'&&color==='noir') won=true;
      if (betType==='pair'&&parity==='pair') won=true;
      if (betType==='impair'&&parity==='impair') won=true;
      if (betType==='1-18'&&half==='1-18') won=true;
      if (betType==='19-36'&&half==='19-36') won=true;

      var resEl = document.getElementById('result');
      if (won) {
        balance += currentBet*2;
        var mc=parseInt(localStorage.getItem('melchior_coins')||'0')+3;
        localStorage.setItem('melchior_coins',mc.toString());
        resEl.innerHTML='<div class="bg-gradient-to-r from-green-500 to-green-600 text-white font-extrabold text-lg px-6 py-2 rounded-2xl shadow-xl">'+num+' '+color.toUpperCase()+' — Gagné ! +'+currentBet+'€ <span class="text-sm">+3⭐</span></div>';
      } else {
        resEl.innerHTML='<div class="bg-gradient-to-r from-red-500 to-red-600 text-white font-extrabold text-lg px-6 py-2 rounded-2xl shadow-xl">'+num+' '+color.toUpperCase()+' — Perdu !</div>';
      }
      document.getElementById('balance').textContent=balance+'€';

      historyArr.unshift(num);
      if(historyArr.length>15) historyArr.pop();
      document.getElementById('history').innerHTML=historyArr.map(function(n){
        var c=n===0?'bg-green-600':isRed(n)?'bg-red-600':'bg-gray-700';
        return '<span class="'+c+' text-white text-[10px] font-bold w-7 h-7 rounded-full flex items-center justify-center shadow">'+n+'</span>';
      }).join('');
    }
  </script>
</Layout>
