---
import Layout from '../../layouts/Layout.astro';
import AuthGate from '../../components/AuthGate.astro';
---

<Layout title="Plinko | MelchiorBonus" description="Joue au Plinko virtuel sur MelchiorBonus.">
  <AuthGate>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <h1 class="text-2xl font-extrabold text-white mb-4 flex items-center gap-2">📍 Plinko</h1>

    <div class="flex flex-col lg:flex-row gap-4">
      <!-- LEFT: Controls -->
      <div class="lg:w-72 flex-shrink-0 bg-bg-card border border-bg-border rounded-2xl p-5 flex flex-col gap-4">
        <div>
          <p class="text-gray-500 text-[10px] uppercase tracking-wider mb-1">Solde</p>
          <p class="text-gold font-extrabold text-2xl" id="balance">1000€</p>
        </div>
        <div class="border-t border-bg-border"></div>
        <div>
          <p class="text-gray-500 text-[10px] uppercase tracking-wider mb-1">Mise</p>
          <p class="text-primary-light font-extrabold text-xl" id="current-bet-display">10€</p>
        </div>

        <div>
          <p class="text-gray-500 text-[10px] uppercase tracking-wider mb-2">Jetons</p>
          <div class="grid grid-cols-3 gap-2">
            <div data-bet="1" class="chip w-full aspect-square rounded-full font-bold text-xs text-white flex items-center justify-center cursor-pointer select-none hover:scale-110 transition-transform" style="background:radial-gradient(circle at 35% 35%,#9ca3af,#4b5563);box-shadow:0 3px 6px rgba(0,0,0,0.4);border:3px dashed rgba(255,255,255,0.3);">1</div>
            <div data-bet="5" class="chip w-full aspect-square rounded-full font-bold text-xs text-white flex items-center justify-center cursor-pointer select-none hover:scale-110 transition-transform" style="background:radial-gradient(circle at 35% 35%,#ef4444,#991b1b);box-shadow:0 3px 6px rgba(0,0,0,0.4);border:3px dashed rgba(255,255,255,0.3);">5</div>
            <div data-bet="10" class="chip w-full aspect-square rounded-full font-bold text-xs text-white flex items-center justify-center cursor-pointer select-none hover:scale-110 transition-transform ring-2 ring-primary" style="background:radial-gradient(circle at 35% 35%,#3b82f6,#1e3a8a);box-shadow:0 3px 6px rgba(0,0,0,0.4);border:3px dashed rgba(255,255,255,0.3);">10</div>
            <div data-bet="25" class="chip w-full aspect-square rounded-full font-bold text-xs text-white flex items-center justify-center cursor-pointer select-none hover:scale-110 transition-transform" style="background:radial-gradient(circle at 35% 35%,#22c55e,#15803d);box-shadow:0 3px 6px rgba(0,0,0,0.4);border:3px dashed rgba(255,255,255,0.3);">25</div>
            <div data-bet="50" class="chip w-full aspect-square rounded-full font-bold text-xs text-black flex items-center justify-center cursor-pointer select-none hover:scale-110 transition-transform" style="background:radial-gradient(circle at 35% 35%,#facc15,#a16207);box-shadow:0 3px 6px rgba(0,0,0,0.4);border:3px dashed rgba(255,255,255,0.3);">50</div>
            <div data-bet="100" class="chip w-full aspect-square rounded-full font-bold text-xs text-white flex items-center justify-center cursor-pointer select-none hover:scale-110 transition-transform" style="background:radial-gradient(circle at 35% 35%,#a855f7,#581c87);box-shadow:0 3px 6px rgba(0,0,0,0.4);border:3px dashed rgba(255,255,255,0.3);">100</div>
          </div>
        </div>
        <div class="border-t border-bg-border"></div>

        <!-- Risk Level -->
        <div>
          <p class="text-gray-500 text-[10px] uppercase tracking-wider mb-2">Risque</p>
          <div class="grid grid-cols-3 gap-2">
            <button data-risk="low" class="risk-btn bg-green-600/20 border border-green-500/30 text-green-400 font-bold py-2 rounded-lg text-xs">Faible</button>
            <button data-risk="medium" class="risk-btn bg-yellow-600/20 border border-yellow-500/30 text-yellow-400 font-bold py-2 rounded-lg text-xs ring-2 ring-primary">Moyen</button>
            <button data-risk="high" class="risk-btn bg-red-600/20 border border-red-500/30 text-red-400 font-bold py-2 rounded-lg text-xs">Élevé</button>
          </div>
        </div>

        <button id="btn-drop" class="bg-accent-green hover:bg-accent-green/80 text-white font-bold py-3 rounded-xl transition-all text-sm uppercase tracking-wider w-full">Lâcher la bille !</button>

        <div class="border-t border-bg-border pt-3">
          <div class="flex items-center justify-between text-sm">
            <span class="text-gray-500">MelchiorCoins</span>
            <span class="text-gold font-bold" id="mc-display">0⭐</span>
          </div>
        </div>

        <!-- History -->
        <div>
          <p class="text-gray-500 text-[10px] uppercase tracking-wider mb-2">Historique</p>
          <div id="plinko-history" class="flex items-center gap-1.5 flex-wrap"></div>
        </div>
      </div>

      <!-- RIGHT: Plinko Board -->
      <div class="flex-1">
        <div class="bg-bg-card border border-bg-border rounded-2xl p-4 flex justify-center">
          <canvas id="plinko-canvas" width="580" height="500" class="rounded-xl"></canvas>
        </div>
        <div id="result" class="text-center mt-4 min-h-[40px] flex items-center justify-center"></div>
      </div>
    </div>
  </section>
  </AuthGate>

  <script is:inline>
    var canvas = document.getElementById('plinko-canvas');
    var ctx = canvas.getContext('2d');
    var W = canvas.width, H = canvas.height;
    var ROWS = 12;
    var balance = 1000, currentBet = 10, dropping = false, riskLevel = 'medium';

    var multiplierSets = {
      low:    [1.5, 1.2, 1, 0.8, 0.5, 0.3, 0.3, 0.5, 0.8, 1, 1.2, 1.5, 1.5],
      medium: [5, 2, 1.5, 1, 0.5, 0.3, 0.3, 0.5, 1, 1.5, 2, 5, 5],
      high:   [25, 8, 3, 1.5, 0.5, 0.2, 0.2, 0.5, 1.5, 3, 8, 25, 25]
    };
    var colorSets = {
      low:    ['#22c55e','#22c55e','#3b82f6','#3b82f6','#6366f1','#9ca3af','#9ca3af','#6366f1','#3b82f6','#3b82f6','#22c55e','#22c55e','#22c55e'],
      medium: ['#ef4444','#f59e0b','#22c55e','#3b82f6','#6366f1','#9ca3af','#9ca3af','#6366f1','#3b82f6','#22c55e','#f59e0b','#ef4444','#ef4444'],
      high:   ['#ef4444','#ef4444','#f59e0b','#22c55e','#6366f1','#9ca3af','#9ca3af','#6366f1','#22c55e','#f59e0b','#ef4444','#ef4444','#ef4444']
    };
    var plinkoHistory = [];

    function getMultipliers() { return multiplierSets[riskLevel]; }
    function getColors() { return colorSets[riskLevel]; }

    function drawBoard(ballX, ballY, trail) {
      ctx.clearRect(0, 0, W, H);

      // Background gradient
      var bg = ctx.createLinearGradient(0,0,0,H);
      bg.addColorStop(0, '#1a1838');
      bg.addColorStop(1, '#0c0b1e');
      ctx.fillStyle = bg;
      ctx.fillRect(0, 0, W, H);

      // Pegs
      for (var row = 0; row < ROWS; row++) {
        var pegsInRow = row + 3;
        var spacing = W / (pegsInRow + 1);
        for (var col = 0; col < pegsInRow; col++) {
          var x = spacing * (col + 1);
          var y = 35 + row * 35;
          ctx.beginPath();
          ctx.arc(x, y, 5, 0, Math.PI * 2);
          var pegGrad = ctx.createRadialGradient(x-1,y-1,1,x,y,5);
          pegGrad.addColorStop(0, '#a78bfa');
          pegGrad.addColorStop(1, '#7c5bf5');
          ctx.fillStyle = pegGrad;
          ctx.fill();
          ctx.strokeStyle = 'rgba(255,255,255,0.1)';
          ctx.lineWidth = 1;
          ctx.stroke();
        }
      }

      // Buckets
      var multipliers = getMultipliers();
      var colors = getColors();
      var bucketW = W / multipliers.length;
      for (var i = 0; i < multipliers.length; i++) {
        // Bucket bg
        ctx.fillStyle = colors[i] + '33';
        ctx.fillRect(i * bucketW + 2, H - 45, bucketW - 4, 42);
        // Rounded top
        ctx.beginPath();
        ctx.moveTo(i*bucketW+2, H-45);
        ctx.lineTo(i*bucketW+bucketW-2, H-45);
        ctx.strokeStyle = colors[i] + '88';
        ctx.lineWidth = 3;
        ctx.stroke();
        // Text
        ctx.fillStyle = colors[i];
        ctx.font = 'bold 13px Inter, sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText(multipliers[i] + 'x', i * bucketW + bucketW / 2, H - 18);
      }

      // Trail
      if (trail) {
        for (var t = 0; t < trail.length; t++) {
          ctx.beginPath();
          ctx.arc(trail[t].x, trail[t].y, 3, 0, Math.PI*2);
          ctx.fillStyle = 'rgba(245,184,61,' + (0.1+t/trail.length*0.3) + ')';
          ctx.fill();
        }
      }

      // Ball
      if (ballX !== undefined && ballY !== undefined) {
        ctx.beginPath();
        ctx.arc(ballX, ballY, 9, 0, Math.PI * 2);
        var ballGrad = ctx.createRadialGradient(ballX-2,ballY-2,2,ballX,ballY,9);
        ballGrad.addColorStop(0, '#fde68a');
        ballGrad.addColorStop(1, '#f5b83d');
        ctx.fillStyle = ballGrad;
        ctx.fill();
        ctx.shadowColor = '#f5b83d';
        ctx.shadowBlur = 15;
        ctx.fill();
        ctx.shadowBlur = 0;
      }
    }

    drawBoard();

    // Chips
    document.querySelectorAll('.chip').forEach(function(c) {
      c.addEventListener('click', function() {
        if (dropping) return;
        currentBet = parseInt(c.dataset.bet);
        document.querySelectorAll('.chip').forEach(function(b){b.classList.remove('ring-2','ring-primary');});
        c.classList.add('ring-2','ring-primary');
        document.getElementById('current-bet-display').textContent = currentBet+'€';
      });
    });

    // Risk
    document.querySelectorAll('.risk-btn').forEach(function(b) {
      b.addEventListener('click', function() {
        riskLevel = b.dataset.risk;
        document.querySelectorAll('.risk-btn').forEach(function(x){x.classList.remove('ring-2','ring-primary');});
        b.classList.add('ring-2','ring-primary');
        drawBoard();
      });
    });

    // MC display
    function updateMC() {
      document.getElementById('mc-display').textContent = (localStorage.getItem('melchior_coins')||'0')+'⭐';
    }
    updateMC();

    // Drop
    document.getElementById('btn-drop').addEventListener('click', function() {
      if (dropping || balance < currentBet) return;
      dropping = true;
      balance -= currentBet;
      document.getElementById('balance').textContent = balance+'€';
      document.getElementById('result').innerHTML = '';

      var x = W/2 + (Math.random()-0.5)*30;
      var y = 10;
      var trail = [{x:x,y:y}];
      var path = [{x:x,y:y}];

      // Simulate
      for (var row=0; row<ROWS; row++) {
        var dir = Math.random()<0.5?-1:1;
        var pegsInRow = row+4;
        var spacing = W/(pegsInRow+1);
        x += dir*spacing/2 + (Math.random()-0.5)*8;
        x = Math.max(15, Math.min(W-15, x));
        y = 35+(row+1)*35;
        path.push({x:x,y:y});
      }
      path.push({x:x, y:H-50});

      var frame = 0;
      var trailPoints = [];
      function animate() {
        if (frame < path.length) {
          trailPoints.push(path[frame]);
          drawBoard(path[frame].x, path[frame].y, trailPoints);
          frame++;
          setTimeout(animate, 80);
        } else {
          // Result
          var multipliers = getMultipliers();
          var colors = getColors();
          var bucketW = W/multipliers.length;
          var bucket = Math.min(multipliers.length-1, Math.max(0, Math.floor(x/bucketW)));
          var multi = multipliers[bucket];
          var winnings = Math.floor(currentBet*multi);
          balance += winnings;
          document.getElementById('balance').textContent = balance+'€';

          var earned = multi>=3?5:multi>=1?2:0;
          if (earned>0) {
            var mc=parseInt(localStorage.getItem('melchior_coins')||'0')+earned;
            localStorage.setItem('melchior_coins',mc.toString());
            updateMC();
          }
          var coinText = earned>0?' <span class="text-gold text-sm">+'+earned+'⭐</span>':'';

          var resEl = document.getElementById('result');
          if (multi>=3) {
            resEl.innerHTML='<div class="bg-gradient-to-r from-green-500 to-green-600 text-white font-extrabold text-lg px-6 py-2 rounded-2xl shadow-xl animate-bounce">🎉 '+multi+'x — '+winnings+'€ !'+coinText+'</div>';
          } else if (multi>=1) {
            resEl.innerHTML='<div class="bg-gradient-to-r from-blue-500 to-blue-600 text-white font-extrabold text-lg px-6 py-2 rounded-2xl shadow-xl">'+multi+'x — '+winnings+'€'+coinText+'</div>';
          } else {
            resEl.innerHTML='<div class="bg-gradient-to-r from-gray-500 to-gray-600 text-white font-extrabold text-lg px-6 py-2 rounded-2xl shadow-xl">'+multi+'x — '+winnings+'€</div>';
          }

          // History
          plinkoHistory.unshift({multi:multi,color:colors[bucket]});
          if(plinkoHistory.length>12) plinkoHistory.pop();
          document.getElementById('plinko-history').innerHTML=plinkoHistory.map(function(h){
            return '<span class="text-[10px] font-bold px-2 py-1 rounded-full text-white" style="background:'+h.color+'">'+h.multi+'x</span>';
          }).join('');

          dropping = false;
        }
      }
      animate();
    });
  </script>
</Layout>
