---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Plinko Virtuel — Joue gratuitement | MelchiorBonus" description="Joue au Plinko virtuel gratuitement sur MelchiorBonus.">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-8">
      <h1 class="text-4xl font-extrabold text-white mb-2">📍 Plinko</h1>
      <p class="text-gray-400">Lâche la bille et regarde-la tomber !</p>
    </div>

    <div class="bg-bg-card border border-bg-border rounded-2xl p-8">
      <!-- Plinko Board -->
      <div class="flex justify-center mb-6">
        <canvas id="plinko-canvas" width="500" height="450" class="rounded-xl border border-bg-border bg-bg-surface"></canvas>
      </div>

      <!-- Result -->
      <div id="result" class="text-center text-2xl font-extrabold mb-4 min-h-[40px]"></div>

      <!-- Balance -->
      <div class="flex items-center justify-center gap-6 mb-6">
        <div class="bg-bg-surface border border-bg-border rounded-xl px-5 py-3 text-center">
          <p class="text-gray-500 text-xs">Solde virtuel</p>
          <p class="text-gold font-extrabold text-xl" id="balance">1000</p>
        </div>
        <div class="bg-bg-surface border border-bg-border rounded-xl px-5 py-3 text-center">
          <p class="text-gray-500 text-xs">Mise</p>
          <p class="text-primary-light font-extrabold text-xl" id="current-bet">10</p>
        </div>
      </div>

      <!-- Bet controls -->
      <div class="flex items-center justify-center gap-3 mb-6">
        <button data-bet="5" class="bet-btn bg-bg-surface border border-bg-border text-white font-bold px-4 py-2 rounded-lg hover:border-primary/30 transition-all">5€</button>
        <button data-bet="10" class="bet-btn bg-primary/20 border border-primary/30 text-primary font-bold px-4 py-2 rounded-lg">10€</button>
        <button data-bet="25" class="bet-btn bg-bg-surface border border-bg-border text-white font-bold px-4 py-2 rounded-lg hover:border-primary/30 transition-all">25€</button>
        <button data-bet="50" class="bet-btn bg-bg-surface border border-bg-border text-white font-bold px-4 py-2 rounded-lg hover:border-primary/30 transition-all">50€</button>
      </div>

      <!-- Drop -->
      <div class="text-center">
        <button id="btn-drop" class="bg-accent-green hover:bg-accent-green/80 text-white font-bold px-10 py-4 rounded-xl transition-all hover:shadow-lg hover:shadow-accent-green/20 text-lg">
          Lâcher la bille !
        </button>
      </div>
    </div>
  </section>

  <script>
    const canvas = document.getElementById('plinko-canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const W = canvas.width, H = canvas.height;
    const ROWS = 10;
    const multipliers = [10, 3, 1.5, 1, 0.5, 0.3, 0.5, 1, 1.5, 3, 10];
    const colors = ['#ef4444','#f97316','#eab308','#22c55e','#6366f1','#6366f1','#22c55e','#eab308','#f97316','#ef4444','#ef4444'];
    let balance = 1000, currentBet = 10, dropping = false;

    function drawBoard() {
      ctx.clearRect(0, 0, W, H);

      // Draw pegs
      for (let row = 0; row < ROWS; row++) {
        const pegsInRow = row + 3;
        const spacing = W / (pegsInRow + 1);
        for (let col = 0; col < pegsInRow; col++) {
          const x = spacing * (col + 1);
          const y = 30 + row * 38;
          ctx.beginPath();
          ctx.arc(x, y, 4, 0, Math.PI * 2);
          ctx.fillStyle = '#7c5bf5';
          ctx.fill();
        }
      }

      // Draw buckets
      const bucketW = W / multipliers.length;
      for (let i = 0; i < multipliers.length; i++) {
        ctx.fillStyle = colors[i] + '33';
        ctx.fillRect(i * bucketW, H - 40, bucketW, 40);
        ctx.strokeStyle = colors[i] + '66';
        ctx.strokeRect(i * bucketW, H - 40, bucketW, 40);
        ctx.fillStyle = colors[i];
        ctx.font = 'bold 13px Inter, sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText(multipliers[i] + 'x', i * bucketW + bucketW / 2, H - 16);
      }
    }

    function dropBall() {
      if (dropping || balance < currentBet) return;
      dropping = true;
      balance -= currentBet;
      document.getElementById('balance')!.textContent = balance.toString();
      document.getElementById('result')!.textContent = '';

      let x = W / 2 + (Math.random() - 0.5) * 20;
      let y = 10;
      let position = 0;

      // Simulate path
      const path: {x: number, y: number}[] = [{x, y}];
      for (let row = 0; row < ROWS; row++) {
        const dir = Math.random() < 0.5 ? -1 : 1;
        position += dir;
        const pegsInRow = row + 4;
        const spacing = W / (pegsInRow + 1);
        x += dir * spacing / 2 + (Math.random() - 0.5) * 5;
        x = Math.max(20, Math.min(W - 20, x));
        y = 30 + (row + 1) * 38;
        path.push({x, y});
      }
      path.push({x, y: H - 45});

      let frame = 0;
      function animate() {
        drawBoard();
        // Draw trail
        for (let i = 0; i <= frame && i < path.length; i++) {
          ctx.beginPath();
          ctx.arc(path[i].x, path[i].y, i === frame ? 8 : 3, 0, Math.PI * 2);
          ctx.fillStyle = i === frame ? '#f5b83d' : '#f5b83d44';
          ctx.fill();
          if (i === frame) {
            ctx.shadowColor = '#f5b83d';
            ctx.shadowBlur = 12;
            ctx.fill();
            ctx.shadowBlur = 0;
          }
        }

        frame++;
        if (frame < path.length) {
          requestAnimationFrame(animate);
        } else {
          // Determine bucket
          const bucketW = W / multipliers.length;
          const bucket = Math.min(multipliers.length - 1, Math.max(0, Math.floor(x / bucketW)));
          const multi = multipliers[bucket];
          const winnings = Math.floor(currentBet * multi);
          balance += winnings;
          document.getElementById('balance')!.textContent = balance.toString();

          const resultEl = document.getElementById('result')!;
          if (multi >= 3) {
            resultEl.innerHTML = `<span class="text-accent-green">🎉 ${multi}x — Tu gagnes ${winnings}€ !</span>`;
          } else if (multi >= 1) {
            resultEl.innerHTML = `<span class="text-gold">${multi}x — ${winnings}€</span>`;
          } else {
            resultEl.innerHTML = `<span class="text-accent-red">${multi}x — ${winnings}€</span>`;
          }
          dropping = false;
        }
      }
      animate();
    }

    document.querySelectorAll('.bet-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        if (dropping) return;
        currentBet = parseInt((btn as HTMLElement).dataset.bet!);
        document.querySelectorAll('.bet-btn').forEach(b => b.className = 'bet-btn bg-bg-surface border border-bg-border text-white font-bold px-4 py-2 rounded-lg hover:border-primary/30 transition-all');
        btn.className = 'bet-btn bg-primary/20 border border-primary/30 text-primary font-bold px-4 py-2 rounded-lg';
        document.getElementById('current-bet')!.textContent = currentBet.toString();
      });
    });

    document.getElementById('btn-drop')!.addEventListener('click', dropBall);
    drawBoard();
  </script>
</Layout>
