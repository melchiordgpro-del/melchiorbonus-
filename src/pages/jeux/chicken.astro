---
import Layout from '../../layouts/Layout.astro';
import AuthGate from '../../components/AuthGate.astro';
import UnderConstruction from '../../components/UnderConstruction.astro';
import { casinos } from '../../data/casinos';
---

<Layout title="Chicken Road | MelchiorBonus" description="Joue au Chicken Road sur MelchiorBonus. Fais avancer le poulet !">
  <AuthGate>
  <UnderConstruction>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <h1 class="text-2xl font-extrabold text-white mb-4 flex items-center gap-2">🐔 Chicken Road</h1>

    <div class="flex flex-col lg:flex-row gap-0 rounded-xl overflow-hidden border border-[#2a2d35]">
      <!-- LEFT: Controls -->
      <div class="lg:w-64 flex-shrink-0 bg-[#1a1d23] p-5 flex flex-col gap-4">
        <!-- Bet Amount -->
        <div>
          <p class="text-gray-400 text-xs mb-1.5">Mise</p>
          <div class="flex items-center bg-[#0e1015] border border-[#2a2d35] rounded-lg overflow-hidden">
            <input type="number" id="bet-input" value="10" min="1" class="flex-1 bg-transparent text-white font-bold text-sm px-3 py-2.5 outline-none w-20" />
            <span class="text-primary font-bold text-xs px-1">Ⓜ</span>
            <button id="bet-half" class="text-gray-500 hover:text-white font-bold text-xs px-2.5 py-2.5 border-l border-[#2a2d35] transition-colors cursor-pointer">½</button>
            <button id="bet-double" class="text-gray-500 hover:text-white font-bold text-xs px-2.5 py-2.5 border-l border-[#2a2d35] transition-colors cursor-pointer">2×</button>
          </div>
        </div>

        <!-- Difficulty -->
        <div>
          <p class="text-gray-400 text-xs mb-1.5">Difficulté</p>
          <div class="grid grid-cols-2 gap-1.5">
            <button data-diff="easy" class="diff-btn bg-green-600 text-white text-xs font-bold py-2 rounded-lg cursor-pointer transition-all border-2 border-green-400">Easy</button>
            <button data-diff="medium" class="diff-btn bg-[#0e1015] text-gray-400 text-xs font-bold py-2 rounded-lg cursor-pointer transition-all border-2 border-transparent hover:border-yellow-500/50">Medium</button>
            <button data-diff="hard" class="diff-btn bg-[#0e1015] text-gray-400 text-xs font-bold py-2 rounded-lg cursor-pointer transition-all border-2 border-transparent hover:border-orange-500/50">Hard</button>
            <button data-diff="hardcore" class="diff-btn bg-[#0e1015] text-gray-400 text-xs font-bold py-2 rounded-lg cursor-pointer transition-all border-2 border-transparent hover:border-red-500/50">Hardcore</button>
          </div>
          <p class="text-gray-600 text-[10px] mt-1.5" id="diff-info">25% de chance de bombe</p>
        </div>

        <!-- Balance -->
        <div class="bg-[#0e1015] border border-[#2a2d35] rounded-lg px-3 py-2.5 text-center">
          <p class="text-gray-500 text-[10px] uppercase">Solde</p>
          <p class="text-white font-extrabold text-lg" id="balance-display">0 Ⓜ</p>
        </div>

        <!-- GO / Cashout -->
        <button id="action-btn" class="bg-green-600 hover:bg-green-500 text-white font-extrabold py-3.5 rounded-xl transition-all text-sm cursor-pointer">
          GO 🐔
        </button>

        <!-- Advance button (during game) -->
        <button id="advance-btn" class="hidden bg-yellow-500 hover:bg-yellow-400 text-black font-extrabold py-3.5 rounded-xl transition-all text-sm cursor-pointer">
          ➡️ Avancer
        </button>

        <!-- Current multiplier info -->
        <div id="game-info" class="hidden">
          <div class="bg-[#0e1015] border border-[#2a2d35] rounded-lg p-3 text-center">
            <p class="text-gray-500 text-[10px] uppercase">Gain actuel</p>
            <p class="text-accent-green font-extrabold text-xl" id="current-win">0.00 Ⓜ</p>
            <p class="text-primary font-bold text-sm" id="current-multi">1.00×</p>
          </div>
          <div class="bg-[#0e1015] border border-[#2a2d35] rounded-lg p-2 mt-2 text-center">
            <p class="text-gray-500 text-[10px] uppercase">Prochaine case</p>
            <p class="text-yellow-400 font-extrabold" id="next-multi">1.32×</p>
            <p class="text-red-400 text-[10px]" id="bomb-chance">💣 25% de bombe</p>
          </div>
        </div>

        <!-- Play Real -->
        <div class="relative group mt-auto">
          <button class="w-full bg-accent-green/20 border border-accent-green/30 text-accent-green hover:bg-accent-green/30 font-bold py-2.5 rounded-xl transition-all text-xs cursor-pointer flex items-center justify-center gap-2">
            🎰 Jouer en argent réel
          </button>
          <div class="hidden group-hover:block absolute bottom-full left-0 w-full mb-2 bg-[#1a1d23] border border-[#2a2d35] rounded-xl overflow-hidden shadow-xl z-50">
            {casinos.map(c => (
              <a href={c.affiliateUrl} target="_blank" rel="noopener" class="flex items-center gap-2 px-3 py-2 hover:bg-[#2a2d35] text-white text-xs font-medium transition-colors">
                <span>{c.name}</span>
                <span class="ml-auto text-primary text-[10px]">{c.bonusAmount}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- RIGHT: Road -->
      <div class="flex-1 bg-[#0e1015] p-6 flex flex-col items-center justify-center min-h-[400px]">
        <!-- Road visualization -->
        <div class="w-full max-w-2xl">
          <!-- Road track -->
          <div class="relative">
            <!-- The road line -->
            <div class="flex items-center gap-0" id="road-track">
              <!-- Generated by JS -->
            </div>
          </div>
        </div>

        <!-- Message -->
        <p id="game-msg" class="text-center text-gray-500 text-sm mt-6">Choisis ta difficulté et clique GO !</p>
      </div>
    </div>

    <!-- History -->
    <div class="mt-4 bg-[#1a1d23] border border-[#2a2d35] rounded-xl p-4">
      <h3 class="text-white font-bold text-sm mb-3">Historique</h3>
      <div id="history" class="flex flex-wrap gap-2"></div>
    </div>
  </section>
  </UnderConstruction>
  </AuthGate>
</Layout>

<style>
  .road-cell {
    width: 64px;
    height: 64px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 11px;
    transition: all 0.3s ease;
    flex-shrink: 0;
    position: relative;
  }
  .road-cell.future {
    background: #2a2d35;
    border: 2px solid #3a3d45;
    color: #666;
  }
  .road-cell.current {
    background: #2a2d35;
    border: 2px dashed #eab308;
    color: #eab308;
    animation: pulse-border 1.5s infinite;
  }
  .road-cell.safe {
    background: #16a34a22;
    border: 2px solid #22c55e;
    color: #22c55e;
  }
  .road-cell.bomb {
    background: #dc262622;
    border: 2px solid #ef4444;
    color: #ef4444;
  }
  .road-cell.start {
    background: #7c5bf522;
    border: 2px solid #7c5bf5;
  }
  .chicken-on-road {
    position: absolute;
    top: -32px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 28px;
    transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    filter: drop-shadow(0 4px 8px rgba(0,0,0,.5));
    z-index: 10;
  }
  .chicken-dead {
    transform: translateX(-50%) rotate(90deg) !important;
    filter: drop-shadow(0 4px 8px rgba(0,0,0,.5)) grayscale(1) !important;
  }
  .road-connector {
    width: 20px;
    height: 3px;
    background: #2a2d35;
    flex-shrink: 0;
  }
  .road-connector.passed {
    background: #22c55e;
  }
  @keyframes pulse-border {
    0%, 100% { border-color: #eab308; box-shadow: 0 0 0 0 rgba(234, 179, 8, 0.3); }
    50% { border-color: #fbbf24; box-shadow: 0 0 15px 0 rgba(234, 179, 8, 0.2); }
  }
  @keyframes boom-shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-4px); }
    75% { transform: translateX(4px); }
  }
  /* Car animation */
  .car-container {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 50;
    pointer-events: none;
  }
  .car-sprite {
    font-size: 48px;
    filter: drop-shadow(0 4px 12px rgba(0,0,0,.6));
  }
  @keyframes car-drive-in {
    0% { transform: translateX(-300px); }
    40% { transform: translateX(0px); }
    50% { transform: translateX(0px); }
    100% { transform: translateX(600px); }
  }
  @keyframes car-honk {
    0%, 100% { transform: translateY(-50%) scale(1); }
    50% { transform: translateY(-50%) scale(1.05); }
  }
  /* Feathers flying */
  .feather {
    position: absolute;
    font-size: 16px;
    pointer-events: none;
    z-index: 60;
    opacity: 1;
  }
  @keyframes feather-fly-1 {
    0% { transform: translate(0, 0) rotate(0deg); opacity: 1; }
    100% { transform: translate(-60px, -80px) rotate(360deg); opacity: 0; }
  }
  @keyframes feather-fly-2 {
    0% { transform: translate(0, 0) rotate(0deg); opacity: 1; }
    100% { transform: translate(40px, -100px) rotate(-300deg); opacity: 0; }
  }
  @keyframes feather-fly-3 {
    0% { transform: translate(0, 0) rotate(0deg); opacity: 1; }
    100% { transform: translate(-30px, -60px) rotate(200deg); opacity: 0; }
  }
  @keyframes feather-fly-4 {
    0% { transform: translate(0, 0) rotate(0deg); opacity: 1; }
    100% { transform: translate(70px, -50px) rotate(-250deg); opacity: 0; }
  }
  @keyframes feather-fly-5 {
    0% { transform: translate(0, 0) rotate(0deg); opacity: 1; }
    100% { transform: translate(20px, -120px) rotate(400deg); opacity: 0; }
  }
  /* Splat mark */
  .splat {
    position: absolute;
    font-size: 32px;
    z-index: 5;
    animation: splat-appear 0.3s ease forwards;
  }
  @keyframes splat-appear {
    0% { transform: scale(0) rotate(0deg); opacity: 0; }
    60% { transform: scale(1.3) rotate(10deg); opacity: 1; }
    100% { transform: scale(1) rotate(0deg); opacity: 0.6; }
  }
  /* Tire marks */
  .tire-marks {
    position: absolute;
    bottom: -4px;
    left: -20px;
    right: -20px;
    height: 4px;
    background: repeating-linear-gradient(90deg, #333 0px, #333 8px, transparent 8px, transparent 12px);
    opacity: 0;
    z-index: 2;
    animation: tire-appear 0.3s ease 0.4s forwards;
  }
  @keyframes tire-appear {
    0% { opacity: 0; }
    100% { opacity: 0.5; }
  }
</style>

<script is:inline>
(function() {
  function getBalance() { return parseFloat(localStorage.getItem('melchior_coins') || '1000000'); }
  function setBalance(v) { localStorage.setItem('melchior_coins', v.toFixed(2)); updateBalance(); window.dispatchEvent(new Event('coins-updated')); }
  function updateBalance() { document.getElementById('balance-display').textContent = getBalance().toLocaleString('fr-FR', {maximumFractionDigits:0}) + ' Ⓜ'; }

  var DIFFS = {
    easy:     { bombChance: 0.20, label: '20% de chance de bombe', steps: 10 },
    medium:   { bombChance: 0.30, label: '30% de chance de bombe', steps: 10 },
    hard:     { bombChance: 0.40, label: '40% de chance de bombe', steps: 8 },
    hardcore: { bombChance: 0.50, label: '50% de chance de bombe', steps: 8 }
  };

  var difficulty = 'easy';
  var playing = false;
  var currentStep = 0; // 0 = start, 1+ = steps taken
  var currentBet = 0;
  var multiplier = 1.0;
  var road = []; // true = bomb, false = safe
  var totalSteps = 10;

  function playSound(type) {
    try {
      var ctx = new (window.AudioContext || window.webkitAudioContext)();
      var osc = ctx.createOscillator(); var gain = ctx.createGain();
      osc.connect(gain); gain.connect(ctx.destination); gain.gain.value = 0.12;
      if (type === 'step') {
        osc.frequency.value = 500 + currentStep * 50; osc.type = 'sine';
        gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.15);
        osc.start(); osc.stop(ctx.currentTime + 0.15);
      } else if (type === 'boom') {
        // Honk sound
        osc.frequency.value = 400; osc.type = 'square';
        gain.gain.value = 0.15;
        gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.3);
        osc.start(); osc.stop(ctx.currentTime + 0.3);
        // Crash sound after honk
        setTimeout(function() {
          try {
            var o2 = ctx.createOscillator(); var g2 = ctx.createGain();
            o2.connect(g2); g2.connect(ctx.destination);
            o2.frequency.value = 100; o2.type = 'sawtooth'; g2.gain.value = 0.2;
            g2.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.5);
            o2.start(); o2.stop(ctx.currentTime + 0.5);
          } catch(e2) {}
        }, 400);
      } else if (type === 'cashout') {
        osc.frequency.value = 700; osc.type = 'sine';
        gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.3);
        osc.start(); osc.stop(ctx.currentTime + 0.3);
        setTimeout(function() {
          var o2 = ctx.createOscillator(); var g2 = ctx.createGain();
          o2.connect(g2); g2.connect(ctx.destination);
          o2.frequency.value = 1100; o2.type = 'sine'; g2.gain.value = 0.08;
          g2.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.25);
          o2.start(); o2.stop(ctx.currentTime + 0.25);
        }, 120);
      }
    } catch(e) {}
  }

  function getMultiplierAtStep(step) {
    var d = DIFFS[difficulty];
    var safeChance = 1 - d.bombChance;
    var m = 1.0;
    for (var i = 0; i < step; i++) {
      m *= (1 / safeChance) * 0.97;
    }
    return Math.round(m * 100) / 100;
  }

  function buildRoad() {
    var track = document.getElementById('road-track');
    track.innerHTML = '';
    var d = DIFFS[difficulty];
    totalSteps = d.steps;

    // Generate road (bombs)
    road = [];
    for (var i = 0; i < totalSteps; i++) {
      road.push(Math.random() < d.bombChance);
    }

    // Start cell
    var startCell = document.createElement('div');
    startCell.className = 'road-cell start';
    startCell.id = 'cell-start';
    startCell.innerHTML = '<span style="font-size:24px">🐔</span>';
    startCell.style.position = 'relative';
    track.appendChild(startCell);

    // Road cells
    for (var i = 0; i < totalSteps; i++) {
      // Connector
      var conn = document.createElement('div');
      conn.className = 'road-connector';
      conn.id = 'conn-' + i;
      track.appendChild(conn);

      // Cell
      var cell = document.createElement('div');
      cell.className = 'road-cell future';
      cell.id = 'cell-' + i;
      cell.innerHTML = '<span>' + getMultiplierAtStep(i + 1).toFixed(2) + '×</span>';
      track.appendChild(cell);
    }

    // Scroll to start
    track.scrollLeft = 0;
  }

  function updateRoadDisplay() {
    // Update cell states
    for (var i = 0; i < totalSteps; i++) {
      var cell = document.getElementById('cell-' + i);
      var conn = document.getElementById('conn-' + i);
      if (i < currentStep) {
        cell.className = 'road-cell safe';
        cell.innerHTML = '<span>✓ ' + getMultiplierAtStep(i + 1).toFixed(2) + '×</span>';
        conn.className = 'road-connector passed';
      } else if (i === currentStep && playing) {
        cell.className = 'road-cell current';
        cell.innerHTML = '<span>❓ ' + getMultiplierAtStep(i + 1).toFixed(2) + '×</span>';
      } else {
        cell.className = 'road-cell future';
        cell.innerHTML = '<span>' + getMultiplierAtStep(i + 1).toFixed(2) + '×</span>';
      }
    }

    // Move chicken emoji
    // Remove chicken from all cells
    document.querySelectorAll('.chicken-sprite').forEach(function(c) { c.remove(); });

    var chickenTarget;
    if (currentStep === 0) {
      chickenTarget = document.getElementById('cell-start');
    } else {
      chickenTarget = document.getElementById('cell-' + (currentStep - 1));
    }
    if (chickenTarget) {
      var chick = document.createElement('div');
      chick.className = 'chicken-sprite';
      chick.style.position = 'absolute';
      chick.style.top = '-30px';
      chick.style.left = '50%';
      chick.style.transform = 'translateX(-50%)';
      chick.style.fontSize = '28px';
      chick.style.zIndex = '10';
      chick.style.filter = 'drop-shadow(0 4px 8px rgba(0,0,0,.5))';
      chick.style.transition = 'all 0.4s ease';
      chick.textContent = '🐔';
      chickenTarget.style.position = 'relative';
      chickenTarget.appendChild(chick);
    }

    // Scroll the current cell into view
    if (playing) {
      var target = document.getElementById('cell-' + currentStep);
      if (target) target.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
    }
  }

  function updateGameInfo() {
    var win = currentBet * multiplier;
    document.getElementById('current-win').textContent = win.toFixed(2) + ' Ⓜ';
    document.getElementById('current-multi').textContent = multiplier.toFixed(2) + '×';

    if (currentStep < totalSteps) {
      var nextM = getMultiplierAtStep(currentStep + 1);
      document.getElementById('next-multi').textContent = nextM.toFixed(2) + '×';
      document.getElementById('bomb-chance').textContent = '💣 ' + Math.round(DIFFS[difficulty].bombChance * 100) + '% de bombe';
    } else {
      document.getElementById('next-multi').textContent = 'MAX !';
      document.getElementById('bomb-chance').textContent = '🏆 Tu as tout traversé !';
    }
  }

  function startGame() {
    var bet = parseFloat(document.getElementById('bet-input').value) || 10;
    if (bet > getBalance()) { document.getElementById('game-msg').textContent = 'Solde insuffisant !'; return; }

    currentBet = bet;
    setBalance(getBalance() - bet);
    currentStep = 0;
    multiplier = 1.0;
    playing = true;

    buildRoad();
    updateRoadDisplay();

    document.getElementById('game-info').classList.remove('hidden');
    document.getElementById('advance-btn').classList.remove('hidden');
    document.getElementById('action-btn').textContent = '💰 Encaisser (' + currentBet.toFixed(2) + ' Ⓜ)';
    document.getElementById('action-btn').className = 'bg-yellow-500 hover:bg-yellow-400 text-black font-extrabold py-3.5 rounded-xl transition-all text-sm cursor-pointer';
    document.getElementById('game-msg').textContent = '🐔 Clique "Avancer" pour traverser la route !';
    document.getElementById('game-msg').style.color = '#eab308';

    document.querySelectorAll('.diff-btn').forEach(function(b) { b.style.opacity = '0.5'; b.style.pointerEvents = 'none'; });
    updateGameInfo();
  }

  function advance() {
    if (!playing || currentStep >= totalSteps) return;

    var stepIdx = currentStep;
    var isBomb = road[stepIdx];

    if (isBomb) {
      // CAR KILLS CHICKEN!
      playing = false;
      document.getElementById('advance-btn').classList.add('hidden');

      var cell = document.getElementById('cell-' + stepIdx);
      cell.className = 'road-cell bomb';
      cell.style.animation = 'boom-shake 0.3s ease 3';

      // Honk sound
      playSound('boom');

      // Pick random car
      var cars = ['🚗', '🚙', '🚕', '🏎️', '🚐', '🚛', '🚑'];
      var carEmoji = cars[Math.floor(Math.random() * cars.length)];

      // Create car element at the cell position
      var carDiv = document.createElement('div');
      carDiv.className = 'car-container';
      carDiv.style.left = '0';
      carDiv.style.top = '-20px';
      carDiv.innerHTML = '<div class="car-sprite" style="animation: car-drive-in 1.2s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;">' + carEmoji + '</div>';
      cell.style.position = 'relative';
      cell.appendChild(carDiv);

      // After car reaches chicken (at 40% = 480ms), show impact
      setTimeout(function() {
        // Hide chicken
        document.querySelectorAll('.chicken-sprite').forEach(function(c) {
          c.style.opacity = '0';
          c.style.transition = 'opacity 0.1s';
        });

        // Feathers explosion!
        var featherEmojis = ['🪶', '🪶', '🪶', '🪶', '🪶', '✨', '💫'];
        var featherAnims = ['feather-fly-1', 'feather-fly-2', 'feather-fly-3', 'feather-fly-4', 'feather-fly-5', 'feather-fly-1', 'feather-fly-2'];
        for (var f = 0; f < 7; f++) {
          var feather = document.createElement('div');
          feather.className = 'feather';
          feather.textContent = featherEmojis[f];
          feather.style.left = '50%';
          feather.style.top = '-20px';
          feather.style.animation = featherAnims[f] + ' 0.8s ease-out forwards';
          feather.style.animationDelay = (f * 0.05) + 's';
          cell.appendChild(feather);
        }

        // Tire marks on the cell
        var tire = document.createElement('div');
        tire.className = 'tire-marks';
        cell.appendChild(tire);

        // Show splat where chicken was
        setTimeout(function() {
          cell.innerHTML = '<span style="font-size:20px; opacity:0.5">💀</span>';
          cell.className = 'road-cell bomb';

          // Add tire marks back
          var tire2 = document.createElement('div');
          tire2.className = 'tire-marks';
          tire2.style.opacity = '0.4';
          tire2.style.animation = 'none';
          cell.appendChild(tire2);
        }, 600);

      }, 480);

      // Message after animation
      setTimeout(function() {
        document.getElementById('game-msg').textContent = '🚗💨 Le poulet s\'est fait écraser à l\'étape ' + (stepIdx + 1) + ' !';
        document.getElementById('game-msg').style.color = '#ef4444';
      }, 600);

      // Reveal remaining bombs after full animation
      setTimeout(function() {
        for (var i = stepIdx + 1; i < totalSteps; i++) {
          var c = document.getElementById('cell-' + i);
          if (road[i]) {
            c.className = 'road-cell bomb';
            c.style.opacity = '0.4';
            c.innerHTML = '<span style="font-size:18px">🚗</span>';
          }
        }
        resetBtn();
      }, 1500);

      addHistory(false, 0);
    } else {
      // Safe!
      currentStep++;
      multiplier = getMultiplierAtStep(currentStep);
      playSound('step');
      updateRoadDisplay();
      updateGameInfo();

      var win = currentBet * multiplier;
      document.getElementById('action-btn').textContent = '💰 Encaisser (' + win.toFixed(2) + ' Ⓜ)';
      document.getElementById('game-msg').textContent = '🐔 ' + multiplier.toFixed(2) + '× — Continue ou encaisse !';
      document.getElementById('game-msg').style.color = '#22c55e';

      // Reached the end
      if (currentStep >= totalSteps) {
        cashout();
      }
    }
  }

  function cashout() {
    if (!playing) return;
    var win = currentBet * multiplier;
    setBalance(getBalance() + win);
    playSound('cashout');
    playing = false;

    document.getElementById('game-msg').textContent = '🎉 Encaissé ! +' + win.toFixed(2) + ' Ⓜ (' + multiplier.toFixed(2) + '×)';
    document.getElementById('game-msg').style.color = '#22c55e';

    // Reveal remaining bombs
    for (var i = currentStep; i < totalSteps; i++) {
      var c = document.getElementById('cell-' + i);
      if (road[i]) {
        c.className = 'road-cell bomb';
        c.style.opacity = '0.5';
        c.innerHTML = '<span style="font-size:18px">💣</span>';
      }
    }

    addHistory(true, multiplier);
    resetBtn();
  }

  function resetBtn() {
    document.getElementById('action-btn').textContent = 'GO 🐔';
    document.getElementById('action-btn').className = 'bg-green-600 hover:bg-green-500 text-white font-extrabold py-3.5 rounded-xl transition-all text-sm cursor-pointer';
    document.getElementById('advance-btn').classList.add('hidden');
    document.getElementById('game-info').classList.add('hidden');
    document.querySelectorAll('.diff-btn').forEach(function(b) { b.style.opacity = '1'; b.style.pointerEvents = 'auto'; });
  }

  function addHistory(won, multi) {
    var el = document.createElement('span');
    if (won) {
      el.className = 'bg-green-600/20 text-green-400 border border-green-500/30 px-3 py-1.5 rounded-lg text-xs font-bold';
      el.textContent = '🐔 ' + multi.toFixed(2) + '×';
    } else {
      el.className = 'bg-red-600/20 text-red-400 border border-red-500/30 px-3 py-1.5 rounded-lg text-xs font-bold';
      el.textContent = '💥 Boom';
    }
    var hist = document.getElementById('history');
    hist.insertBefore(el, hist.firstChild);
    if (hist.children.length > 20) hist.removeChild(hist.lastChild);
  }

  // Events
  document.getElementById('action-btn').addEventListener('click', function() {
    if (playing) { cashout(); } else { startGame(); }
  });
  document.getElementById('advance-btn').addEventListener('click', advance);

  // Difficulty
  document.querySelectorAll('.diff-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (playing) return;
      difficulty = btn.dataset.diff;
      var colors = { easy: 'green', medium: 'yellow', hard: 'orange', hardcore: 'red' };
      document.querySelectorAll('.diff-btn').forEach(function(b) {
        b.className = 'diff-btn bg-[#0e1015] text-gray-400 text-xs font-bold py-2 rounded-lg cursor-pointer transition-all border-2 border-transparent';
      });
      btn.className = 'diff-btn bg-' + colors[difficulty] + '-600 text-white text-xs font-bold py-2 rounded-lg cursor-pointer transition-all border-2 border-' + colors[difficulty] + '-400';
      document.getElementById('diff-info').textContent = DIFFS[difficulty].label;
    });
  });

  // Bet controls
  document.getElementById('bet-half').addEventListener('click', function() {
    var inp = document.getElementById('bet-input');
    inp.value = Math.max(1, Math.floor(parseFloat(inp.value) / 2));
  });
  document.getElementById('bet-double').addEventListener('click', function() {
    var inp = document.getElementById('bet-input');
    inp.value = Math.min(getBalance(), parseFloat(inp.value) * 2);
  });

  updateBalance();
  window.addEventListener('coins-updated', updateBalance);
})();
</script>
