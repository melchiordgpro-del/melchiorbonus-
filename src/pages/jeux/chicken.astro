---
import Layout from '../../layouts/Layout.astro';
import AuthGate from '../../components/AuthGate.astro';
import { casinos } from '../../data/casinos';
---

<Layout title="Chicken Road | MelchiorBonus" description="Joue au Chicken Road sur MelchiorBonus. Fais avancer le poulet !">
  <AuthGate>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <h1 class="text-2xl font-extrabold text-white mb-4 flex items-center gap-2">🐔 Chicken Road</h1>

    <div class="flex flex-col lg:flex-row gap-0 rounded-xl overflow-hidden border border-[#2a2d35]">
      <!-- LEFT: Controls -->
      <div class="lg:w-64 flex-shrink-0 bg-[#1a1d23] p-5 flex flex-col gap-4">
        <!-- Bet Amount -->
        <div>
          <p class="text-gray-400 text-xs mb-1.5">Mise</p>
          <div class="flex items-center bg-[#0e1015] border border-[#2a2d35] rounded-lg overflow-hidden">
            <input type="number" id="bet-input" value="10" min="1" class="flex-1 bg-transparent text-white font-bold text-sm px-3 py-2.5 outline-none w-20" />
            <span class="text-primary font-bold text-xs px-1">Ⓜ</span>
            <button id="bet-half" class="text-gray-500 hover:text-white font-bold text-xs px-2.5 py-2.5 border-l border-[#2a2d35] transition-colors cursor-pointer">½</button>
            <button id="bet-double" class="text-gray-500 hover:text-white font-bold text-xs px-2.5 py-2.5 border-l border-[#2a2d35] transition-colors cursor-pointer">2×</button>
          </div>
        </div>

        <!-- Difficulty -->
        <div>
          <p class="text-gray-400 text-xs mb-1.5">Difficulté</p>
          <div class="grid grid-cols-2 gap-1.5">
            <button data-diff="easy" class="diff-btn bg-green-600 text-white text-xs font-bold py-2 rounded-lg cursor-pointer transition-all border-2 border-green-400">Easy</button>
            <button data-diff="medium" class="diff-btn bg-[#0e1015] text-gray-400 text-xs font-bold py-2 rounded-lg cursor-pointer transition-all border-2 border-transparent hover:border-yellow-500/50">Medium</button>
            <button data-diff="hard" class="diff-btn bg-[#0e1015] text-gray-400 text-xs font-bold py-2 rounded-lg cursor-pointer transition-all border-2 border-transparent hover:border-orange-500/50">Hard</button>
            <button data-diff="hardcore" class="diff-btn bg-[#0e1015] text-gray-400 text-xs font-bold py-2 rounded-lg cursor-pointer transition-all border-2 border-transparent hover:border-red-500/50">Hardcore</button>
          </div>
          <p class="text-gray-600 text-[10px] mt-1.5" id="diff-info">3 portes par colonne — 1 piège</p>
        </div>

        <!-- Balance -->
        <div class="bg-[#0e1015] border border-[#2a2d35] rounded-lg px-3 py-2.5 text-center">
          <p class="text-gray-500 text-[10px] uppercase">Solde</p>
          <p class="text-white font-extrabold text-lg" id="balance-display">0 Ⓜ</p>
        </div>

        <!-- GO / Cashout -->
        <button id="action-btn" class="bg-green-600 hover:bg-green-500 text-white font-extrabold py-3.5 rounded-xl transition-all text-sm cursor-pointer">
          GO 🐔
        </button>

        <!-- Current multiplier info -->
        <div id="game-info" class="hidden">
          <div class="bg-[#0e1015] border border-[#2a2d35] rounded-lg p-3 text-center">
            <p class="text-gray-500 text-[10px] uppercase">Gain actuel</p>
            <p class="text-accent-green font-extrabold text-xl" id="current-win">0.00 Ⓜ</p>
            <p class="text-primary font-bold text-sm" id="current-multi">1.00×</p>
          </div>
        </div>

        <!-- Play Real -->
        <div class="relative group mt-auto">
          <button class="w-full bg-accent-green/20 border border-accent-green/30 text-accent-green hover:bg-accent-green/30 font-bold py-2.5 rounded-xl transition-all text-xs cursor-pointer flex items-center justify-center gap-2">
            🎰 Jouer en argent réel
          </button>
          <div class="hidden group-hover:block absolute bottom-full left-0 w-full mb-2 bg-[#1a1d23] border border-[#2a2d35] rounded-xl overflow-hidden shadow-xl z-50">
            {casinos.map(c => (
              <a href={c.affiliateLink} target="_blank" rel="noopener" class="flex items-center gap-2 px-3 py-2 hover:bg-[#2a2d35] text-white text-xs font-medium transition-colors">
                <span>{c.name}</span>
                <span class="ml-auto text-primary text-[10px]">{c.bonus}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- RIGHT: Game Road -->
      <div class="flex-1 bg-[#0e1015] p-4 overflow-x-auto">
        <!-- Road -->
        <div class="relative min-h-[420px] flex items-end">
          <!-- Road surface -->
          <div class="absolute bottom-0 left-0 right-0 h-2 bg-[#2a2d35] rounded-full"></div>
          <div class="absolute bottom-8 left-0 right-0 flex items-end gap-1" id="road-container">
            <!-- Chicken start position -->
            <div class="flex flex-col items-center w-16 flex-shrink-0 relative" id="chicken-home">
              <div id="chicken-sprite" class="text-5xl transition-all duration-500 ease-out relative z-10" style="filter: drop-shadow(0 4px 8px rgba(0,0,0,.5))">🐔</div>
              <div class="w-12 h-12 bg-yellow-600/30 rounded-full mt-1 flex items-center justify-center">
                <span class="text-2xl">🪙</span>
              </div>
            </div>

            <!-- Columns will be generated by JS -->
          </div>
        </div>

        <!-- Multiplier row at bottom -->
        <div class="flex gap-1 mt-4 pl-16" id="multi-row"></div>

        <!-- Message -->
        <p id="game-msg" class="text-center text-gray-500 text-sm mt-4">Choisis ta difficulté et clique GO !</p>
      </div>
    </div>

    <!-- History -->
    <div class="mt-4 bg-[#1a1d23] border border-[#2a2d35] rounded-xl p-4">
      <h3 class="text-white font-bold text-sm mb-3">Historique</h3>
      <div id="history" class="flex flex-wrap gap-2"></div>
    </div>
  </section>
  </AuthGate>
</Layout>

<script is:inline>
(function() {
  function getBalance() { return parseFloat(localStorage.getItem('melchior_coins') || '1000000'); }
  function setBalance(v) { localStorage.setItem('melchior_coins', v.toFixed(2)); updateBalance(); window.dispatchEvent(new Event('coins-updated')); }
  function updateBalance() { document.getElementById('balance-display').textContent = getBalance().toLocaleString('fr-FR', {maximumFractionDigits:0}) + ' Ⓜ'; }

  var DIFFICULTIES = {
    easy:     { rows: 3, bombs: 1, label: '3 portes — 1 piège', colors: { safe: '#22c55e', btn: 'green' } },
    medium:   { rows: 3, bombs: 1, label: '3 portes — 1 piège (10 colonnes)', colors: { safe: '#eab308', btn: 'yellow' } },
    hard:     { rows: 4, bombs: 2, label: '4 portes — 2 pièges', colors: { safe: '#f97316', btn: 'orange' } },
    hardcore: { rows: 4, bombs: 3, label: '4 portes — 3 pièges', colors: { safe: '#ef4444', btn: 'red' } }
  };

  var COLUMNS_COUNT = { easy: 8, medium: 10, hard: 8, hardcore: 8 };

  var difficulty = 'easy';
  var playing = false;
  var currentCol = -1;
  var currentBet = 0;
  var multiplier = 1.0;
  var grid = []; // grid[col] = array of booleans, true = bomb
  var revealedCols = [];

  // Sounds
  function playSound(type) {
    try {
      var ctx = new (window.AudioContext || window.webkitAudioContext)();
      var osc = ctx.createOscillator(); var gain = ctx.createGain();
      osc.connect(gain); gain.connect(ctx.destination); gain.gain.value = 0.12;
      if (type === 'step') {
        osc.frequency.value = 500 + currentCol * 60;
        osc.type = 'sine';
        gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.15);
        osc.start(); osc.stop(ctx.currentTime + 0.15);
      } else if (type === 'boom') {
        osc.frequency.value = 120; osc.type = 'sawtooth';
        gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.6);
        osc.start(); osc.stop(ctx.currentTime + 0.6);
      } else if (type === 'cashout') {
        osc.frequency.value = 700; osc.type = 'sine';
        gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.3);
        osc.start(); osc.stop(ctx.currentTime + 0.3);
        setTimeout(function() {
          var o2 = ctx.createOscillator(); var g2 = ctx.createGain();
          o2.connect(g2); g2.connect(ctx.destination);
          o2.frequency.value = 1100; o2.type = 'sine'; g2.gain.value = 0.08;
          g2.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.25);
          o2.start(); o2.stop(ctx.currentTime + 0.25);
        }, 120);
      }
    } catch(e) {}
  }

  function getMultiplierForCol(col) {
    var d = DIFFICULTIES[difficulty];
    var safeChance = (d.rows - d.bombs) / d.rows;
    var multi = 1.0;
    for (var i = 0; i <= col; i++) {
      multi *= (1 / safeChance) * 0.97; // 3% house edge
    }
    return Math.round(multi * 100) / 100;
  }

  function buildRoad() {
    var container = document.getElementById('road-container');
    var multiRow = document.getElementById('multi-row');

    // Clear except chicken home
    var chickenHome = document.getElementById('chicken-home');
    container.innerHTML = '';
    container.appendChild(chickenHome);
    multiRow.innerHTML = '';

    var d = DIFFICULTIES[difficulty];
    var cols = COLUMNS_COUNT[difficulty];
    grid = [];
    revealedCols = [];

    for (var c = 0; c < cols; c++) {
      // Generate bombs for this column
      var colBombs = [];
      for (var r = 0; r < d.rows; r++) colBombs.push(false);
      var placed = 0;
      while (placed < d.bombs) {
        var ri = Math.floor(Math.random() * d.rows);
        if (!colBombs[ri]) { colBombs[ri] = true; placed++; }
      }
      grid.push(colBombs);
      revealedCols.push(false);

      // Build column UI
      var colDiv = document.createElement('div');
      colDiv.className = 'flex flex-col items-center gap-1.5 w-16 flex-shrink-0';
      colDiv.dataset.col = c;

      for (var r = 0; r < d.rows; r++) {
        var door = document.createElement('button');
        door.className = 'door w-14 h-14 rounded-full bg-[#2a2d35] border-2 border-[#3a3d45] flex items-center justify-center transition-all duration-300 cursor-pointer hover:border-[#5a5d65] hover:scale-105';
        door.dataset.col = c;
        door.dataset.row = r;
        door.innerHTML = '<span class="text-gray-600 text-lg">?</span>';
        door.addEventListener('click', handleDoorClick);
        colDiv.appendChild(door);
      }

      // Dashed road line
      var line = document.createElement('div');
      line.className = 'w-14 h-0.5 bg-[#2a2d35] mt-1';
      colDiv.appendChild(line);

      container.appendChild(colDiv);

      // Multiplier label
      var mLabel = document.createElement('div');
      mLabel.className = 'w-16 flex-shrink-0 text-center text-[10px] font-extrabold text-gray-500';
      mLabel.textContent = getMultiplierForCol(c) + '×';
      mLabel.id = 'multi-label-' + c;
      multiRow.appendChild(mLabel);
    }
  }

  function handleDoorClick(e) {
    if (!playing) return;
    var col = parseInt(e.currentTarget.dataset.col);
    var row = parseInt(e.currentTarget.dataset.row);

    // Must click next column only
    if (col !== currentCol + 1) return;

    var d = DIFFICULTIES[difficulty];
    var isBomb = grid[col][row];

    if (isBomb) {
      // BOOM
      playSound('boom');
      revealColumn(col, row);
      moveChicken(col, true);
      playing = false;
      document.getElementById('game-msg').textContent = '💥 BOOM ! Le poulet est tombé !';
      document.getElementById('game-msg').style.color = '#ef4444';
      addHistory(false, 0);

      // Reveal all remaining
      setTimeout(function() {
        for (var c = col + 1; c < grid.length; c++) {
          revealColumn(c, -1);
        }
      }, 400);

      resetBtn();
    } else {
      // Safe!
      currentCol = col;
      multiplier = getMultiplierForCol(col);
      playSound('step');
      revealColumn(col, row);
      moveChicken(col, false);

      var win = currentBet * multiplier;
      document.getElementById('current-win').textContent = win.toFixed(2) + ' Ⓜ';
      document.getElementById('current-multi').textContent = multiplier.toFixed(2) + '×';
      document.getElementById('action-btn').textContent = 'Encaisser ' + win.toFixed(2) + ' Ⓜ';
      document.getElementById('action-btn').className = 'bg-yellow-500 hover:bg-yellow-400 text-black font-extrabold py-3.5 rounded-xl transition-all text-sm cursor-pointer';

      // Highlight multiplier
      var ml = document.getElementById('multi-label-' + col);
      if (ml) {
        ml.style.color = '#22c55e';
        ml.style.fontSize = '12px';
      }

      document.getElementById('game-msg').textContent = '🐔 ' + multiplier.toFixed(2) + '× — Continue ou encaisse !';
      document.getElementById('game-msg').style.color = '#22c55e';

      // Check if reached the end
      if (col >= grid.length - 1) {
        cashout();
      }
    }
  }

  function revealColumn(col, clickedRow) {
    var d = DIFFICULTIES[difficulty];
    var doors = document.querySelectorAll('.door[data-col="' + col + '"]');
    doors.forEach(function(door) {
      var r = parseInt(door.dataset.row);
      door.style.cursor = 'default';
      door.classList.remove('hover:border-[#5a5d65]', 'hover:scale-105');

      if (grid[col][r]) {
        // Bomb
        if (r === clickedRow) {
          door.className = 'door w-14 h-14 rounded-full bg-red-600 border-2 border-red-400 flex items-center justify-center transition-all duration-300 scale-110';
          door.innerHTML = '<span class="text-2xl">💥</span>';
        } else {
          door.className = 'door w-14 h-14 rounded-full bg-red-600/20 border-2 border-red-500/30 flex items-center justify-center transition-all duration-300';
          door.innerHTML = '<span class="text-xl opacity-60">🔥</span>';
        }
      } else {
        // Safe
        if (r === clickedRow) {
          door.className = 'door w-14 h-14 rounded-full bg-green-600 border-2 border-green-400 flex items-center justify-center transition-all duration-300 scale-105';
          door.innerHTML = '<span class="text-xl font-extrabold text-white">' + getMultiplierForCol(col) + '×</span>';
        } else {
          door.className = 'door w-14 h-14 rounded-full bg-[#1a1d23] border-2 border-[#2a2d35] flex items-center justify-center transition-all duration-300';
          door.innerHTML = '<span class="text-lg opacity-40">✓</span>';
        }
      }
    });
    revealedCols[col] = true;
  }

  function moveChicken(col, dead) {
    var chicken = document.getElementById('chicken-sprite');
    // Calculate offset: each column is ~68px (w-16 + gap)
    var offset = (col + 1) * 68;
    chicken.style.transform = 'translateX(' + offset + 'px)';
    if (dead) {
      setTimeout(function() {
        chicken.style.transform = 'translateX(' + offset + 'px) rotate(90deg)';
        chicken.style.filter = 'drop-shadow(0 4px 8px rgba(0,0,0,.5)) grayscale(1)';
      }, 200);
    }
  }

  function startGame() {
    var bet = parseFloat(document.getElementById('bet-input').value) || 10;
    if (bet > getBalance()) { document.getElementById('game-msg').textContent = 'Solde insuffisant !'; return; }
    if (bet <= 0) return;

    currentBet = bet;
    setBalance(getBalance() - bet);
    currentCol = -1;
    multiplier = 1.0;
    playing = true;

    buildRoad();

    // Reset chicken
    var chicken = document.getElementById('chicken-sprite');
    chicken.style.transform = 'translateX(0)';
    chicken.style.filter = 'drop-shadow(0 4px 8px rgba(0,0,0,.5))';

    document.getElementById('game-info').classList.remove('hidden');
    document.getElementById('current-win').textContent = currentBet.toFixed(2) + ' Ⓜ';
    document.getElementById('current-multi').textContent = '1.00×';
    document.getElementById('game-msg').textContent = '🐔 Choisis une porte dans la première colonne !';
    document.getElementById('game-msg').style.color = '#9ca3af';

    document.getElementById('action-btn').textContent = 'Encaisser ' + currentBet.toFixed(2) + ' Ⓜ';
    document.getElementById('action-btn').className = 'bg-yellow-500 hover:bg-yellow-400 text-black font-extrabold py-3.5 rounded-xl transition-all text-sm cursor-pointer';

    // Disable difficulty buttons
    document.querySelectorAll('.diff-btn').forEach(function(b) { b.style.opacity = '0.5'; b.style.pointerEvents = 'none'; });
  }

  function cashout() {
    if (!playing) return;
    var win = currentBet * multiplier;
    if (currentCol < 0) win = currentBet; // no progress = refund
    setBalance(getBalance() + win);
    playSound('cashout');
    playing = false;

    document.getElementById('game-msg').textContent = '🎉 Encaissé ! +' + win.toFixed(2) + ' Ⓜ (' + multiplier.toFixed(2) + '×)';
    document.getElementById('game-msg').style.color = '#22c55e';

    // Reveal remaining
    for (var c = currentCol + 1; c < grid.length; c++) {
      revealColumn(c, -1);
    }

    addHistory(true, multiplier);
    resetBtn();
  }

  function resetBtn() {
    document.getElementById('action-btn').textContent = 'GO 🐔';
    document.getElementById('action-btn').className = 'bg-green-600 hover:bg-green-500 text-white font-extrabold py-3.5 rounded-xl transition-all text-sm cursor-pointer';
    document.querySelectorAll('.diff-btn').forEach(function(b) { b.style.opacity = '1'; b.style.pointerEvents = 'auto'; });
    document.getElementById('game-info').classList.add('hidden');
  }

  function addHistory(won, multi) {
    var el = document.createElement('span');
    if (won) {
      el.className = 'bg-green-600/20 text-green-400 border border-green-500/30 px-3 py-1.5 rounded-lg text-xs font-bold';
      el.textContent = '🐔 ' + multi.toFixed(2) + '×';
    } else {
      el.className = 'bg-red-600/20 text-red-400 border border-red-500/30 px-3 py-1.5 rounded-lg text-xs font-bold';
      el.textContent = '💥 Boom';
    }
    var hist = document.getElementById('history');
    hist.insertBefore(el, hist.firstChild);
    if (hist.children.length > 20) hist.removeChild(hist.lastChild);
  }

  // Action button
  document.getElementById('action-btn').addEventListener('click', function() {
    if (playing) { cashout(); } else { startGame(); }
  });

  // Difficulty
  document.querySelectorAll('.diff-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (playing) return;
      difficulty = btn.dataset.diff;
      var colors = { easy: 'green', medium: 'yellow', hard: 'orange', hardcore: 'red' };
      document.querySelectorAll('.diff-btn').forEach(function(b) {
        b.className = 'diff-btn bg-[#0e1015] text-gray-400 text-xs font-bold py-2 rounded-lg cursor-pointer transition-all border-2 border-transparent';
      });
      btn.className = 'diff-btn bg-' + colors[difficulty] + '-600 text-white text-xs font-bold py-2 rounded-lg cursor-pointer transition-all border-2 border-' + colors[difficulty] + '-400';
      document.getElementById('diff-info').textContent = DIFFICULTIES[difficulty].label;
      buildRoad();
    });
  });

  // Bet controls
  document.getElementById('bet-half').addEventListener('click', function() {
    var inp = document.getElementById('bet-input');
    inp.value = Math.max(1, Math.floor(parseFloat(inp.value) / 2));
  });
  document.getElementById('bet-double').addEventListener('click', function() {
    var inp = document.getElementById('bet-input');
    inp.value = Math.min(getBalance(), parseFloat(inp.value) * 2);
  });

  updateBalance();
  buildRoad();
  window.addEventListener('coins-updated', updateBalance);
})();
</script>
