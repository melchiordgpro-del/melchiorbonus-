---
import LandingLayout from '../layouts/LandingLayout.astro';
import CasinoCard from '../components/CasinoCard.astro';
import { casinos, discordUrl } from '../data/casinos';

const topCasinos = casinos.slice(0, 5);
---

<LandingLayout title="MelchiorBonus — Bonus Exclusifs Casino en Ligne 2026">
  <!-- Scrolling Offers Banner -->
  <div class="overflow-hidden bg-primary/5 border-b border-bg-border py-2">
    <div class="marquee-track flex items-center gap-8 whitespace-nowrap">
      {[...topCasinos, ...topCasinos].map((c) => (
        <a href={c.affiliateUrl} target="_blank" rel="nofollow noopener" class="inline-flex items-center gap-2 text-sm font-bold text-gray-400 hover:text-white transition-colors flex-shrink-0">
          <span class="text-accent-green">🎁</span>
          <span>{c.name}</span>
          <span class="text-primary-light">—</span>
          <span class="text-accent-green">{c.bonusDescription.match(/(\d+€)\s*(offert|gratuit)/i) ? c.bonusDescription.match(/(\d+€)\s*(offert|gratuit)/i)[1] + ' Offerts' : c.bonusAmount.replace(/\*/g, '')}</span>
        </a>
      ))}
    </div>
  </div>

  <style>
    .marquee-track {
      animation: marquee 25s linear infinite;
    }
    .marquee-track:hover {
      animation-play-state: paused;
    }
    @keyframes marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
  </style>

  <!-- Melchior Profile -->
  <div class="text-center pt-8 pb-4">
    <div class="mt-4 flex flex-col items-center gap-3">
      <img src="/melchior-avatar.jpg" alt="Melchior" class="w-28 h-28 rounded-full border-3 border-primary/50 shadow-xl shadow-primary/30 pulse-glow" />
      <h1 class="text-4xl sm:text-5xl font-extrabold">
        <span class="gradient-text">Melchior</span>
      </h1>
      <p class="text-gray-400 text-sm max-w-md mx-auto">Comparatif casino, bonus exclusifs & giveaways. Rejoins la communauté !</p>
      <div class="flex items-center gap-4">
        <a href="https://www.youtube.com/@MelchiorBet" target="_blank" rel="noopener" class="text-gray-500 hover:text-[#FF0000] transition-colors" title="YouTube">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
        <a href="https://www.instagram.com/melchiordg_/" target="_blank" rel="noopener" class="text-gray-500 hover:text-[#E4405F] transition-colors" title="Instagram">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
        </a>
        <a href="https://x.com/Melchiorencore" target="_blank" rel="noopener" class="text-gray-500 hover:text-white transition-colors" title="Twitter / X">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href={discordUrl} target="_blank" rel="noopener" class="text-gray-500 hover:text-[#5865F2] transition-colors" title="Discord">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Casino Offers -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
    <!-- Discord Giveaway Banner -->
    <a href={discordUrl} target="_blank" rel="noopener" class="group block bg-gradient-to-r from-[#5865F2]/20 via-[#5865F2]/10 to-[#5865F2]/20 border border-[#5865F2]/30 rounded-2xl p-5 mb-8 hover:border-[#5865F2]/50 transition-all">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-[#5865F2]/20 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-[#5865F2]" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
          </div>
          <div>
            <p class="text-white font-bold text-lg group-hover:text-[#5865F2] transition-colors">🎉 Giveaway en cours sur Discord !</p>
            <p class="text-gray-400 text-sm">Participe au giveaway du jour et gagne des bonus gratuits.</p>
          </div>
        </div>
        <span class="btn-glow bg-[#5865F2] hover:bg-[#4752C4] text-white font-bold px-6 py-3 rounded-xl transition-all flex-shrink-0 text-sm">
          Participer →
        </span>
      </div>
    </a>

    <!-- Casino Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {topCasinos.map((casino, i) => (
        <CasinoCard casino={casino} rank={i + 1} />
      ))}

      <!-- Discord Ticket Card -->
      <a href={discordUrl} target="_blank" rel="noopener" class="group relative bg-[#5865F2]/10 border-2 border-[#5865F2]/30 rounded-2xl overflow-hidden hover:border-[#5865F2]/60 transition-all duration-300 hover:shadow-xl hover:shadow-[#5865F2]/15 flex flex-col items-center justify-center p-8 text-center card-hover">
        <div class="w-16 h-16 bg-[#5865F2]/20 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <svg class="w-9 h-9 text-[#5865F2]" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
        </div>
        <h3 class="text-[#5865F2] font-extrabold text-lg mb-2 group-hover:text-white transition-colors">Récupère tes bonus offerts</h3>
        <p class="text-gray-400 text-sm mb-4">Une fois ton dépôt effectué, ouvre un ticket sur Discord pour récupérer tes bonus exclusifs !</p>
        <span class="btn-glow bg-[#5865F2] hover:bg-[#4752C4] text-white font-extrabold text-sm px-6 py-3 rounded-xl transition-all uppercase tracking-wider">
          Ouvrir un ticket →
        </span>
      </a>
    </div>
  </section>

  <!-- Bonus Simulator -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4 pb-8">
    <div class="bg-bg-card border border-bg-border rounded-2xl p-4 sm:p-5">
      <div class="flex flex-wrap items-center justify-between gap-3 mb-3">
        <h2 class="text-lg font-extrabold text-white">💰 Simulateur de Bonus</h2>
        <div class="flex items-center gap-2">
          <span class="text-gray-400 text-xs">Dépôt :</span>
          <span class="text-accent-green font-extrabold text-lg" id="sim-deposit-display">100€</span>
        </div>
      </div>

      <!-- Slider -->
      <div class="mb-3">
        <input type="range" id="sim-slider" min="25" max="1500" step="25" value="100" class="w-full h-1.5 rounded-full appearance-none cursor-pointer" style="background:linear-gradient(to right, #22c55e 6.7%, #2a2d35 6.7%);accent-color:#22c55e;" />
        <div class="flex justify-between text-[9px] text-gray-600 mt-0.5">
          <span>25€</span><span>500€</span><span>1000€</span><span>1500€</span>
        </div>
      </div>

      <!-- Casino Selector -->
      <div class="flex flex-wrap items-center gap-1.5 mb-3">
        <span id="sim-casino-pills" class="contents"></span>
        <select id="sim-add-select" class="bg-[#1a1d23] border border-[#2a2d35] text-gray-400 text-[11px] rounded-lg px-2 py-1.5 appearance-none cursor-pointer focus:border-primary focus:outline-none">
          <option value="">+ Comparer</option>
        </select>
      </div>

      <!-- Results Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3" id="sim-results">
      </div>

      <p class="text-gray-600 text-[9px] text-center mt-2">* Les bonus offerts sont ajoutés via Discord après dépôt. Montants indicatifs.</p>
    </div>
  </section>

  <script is:inline>
  (function() {
    var casinos = [
      {
        name: 'Hugo Bets',
        logo: '🔥',
        offert: 25,
        minDepositOffert: 25,
        deposits: [
          { pct: 100, max: 300, fs: 50 },
          { pct: 100, max: 350, fs: 50 },
          { pct: 100, max: 350, fs: 50 }
        ],
        maxDeposit: 1000,
        wager: 'FREE',
        note: 'Réparti sur 3 dépôts'
      },
      {
        name: 'Grandz Bet',
        logo: '🎰',
        offert: 25,
        minDepositOffert: 20,
        deposits: [
          { pct: 150, max: 1500, fs: 0 }
        ],
        maxDeposit: 1000,
        wager: 'x40',
        note: 'Option Débutant 1 — Dépôt min. 20€'
      },
      {
        name: 'Betify',
        logo: '⚡',
        offert: 30,
        minDepositOffert: 30,
        deposits: [
          { pct: 100, max: 1000, fs: 0 }
        ],
        maxDeposit: 1000,
        wager: 'x35',
        note: '1er dépôt uniquement',
        freeSpins: [
          { minDeposit: 50, spins: 100, maxWin: 500 },
          { minDeposit: 100, spins: 250, maxWin: 1000 }
        ]
      },
      {
        name: 'ShinyWilds',
        logo: '✨',
        offert: 25,
        minDepositOffert: 25,
        deposits: [
          { pct: 100, max: 150, fs: 0 }
        ],
        maxDeposit: 150,
        wager: 'x40',
        note: '1er dépôt uniquement'
      },
      {
        name: 'Vibe Bet',
        logo: '🎯',
        offert: 25,
        minDepositOffert: 20,
        deposits: [
          { pct: 150, max: 500, fs: 100, fsGame: 'Le King (Hacksaw)', wager: 'x35' },
          { pct: 100, max: 300, fs: 100, fsGame: 'Le Cowboy (Hacksaw)', wager: 'x30' },
          { pct: 100, max: 300, fs: 100, fsGame: 'Sun Princess (Hacksaw)', wager: 'x25' }
        ],
        maxDeposit: 1100,
        wager: 'x35/x30/x25',
        note: 'Réparti sur 3 dépôts — Wager dégressif'
      }
    ];

    var slider = document.getElementById('sim-slider');
    var display = document.getElementById('sim-deposit-display');
    var results = document.getElementById('sim-results');
    var pillsContainer = document.getElementById('sim-casino-pills');
    var addSelect = document.getElementById('sim-add-select');

    // Track which casinos are shown (start with just Hugo Bets)
    var activeCasinos = [0];

    function renderPills() {
      var html = '';
      activeCasinos.forEach(function(idx) {
        var c = casinos[idx];
        html += '<span class="inline-flex items-center gap-1.5 bg-[#1a1d23] border border-[#2a2d35] text-white text-xs font-bold px-3 py-1.5 rounded-full">';
        html += '<span>' + c.logo + '</span>';
        html += '<span>' + c.name + '</span>';
        if (activeCasinos.length > 1) {
          html += '<button data-remove="' + idx + '" class="text-gray-500 hover:text-red-400 ml-1 text-sm leading-none" style="cursor:pointer">×</button>';
        }
        html += '</span>';
      });
      pillsContainer.innerHTML = html;

      // Bind remove buttons
      pillsContainer.querySelectorAll('[data-remove]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var removeIdx = parseInt(this.dataset.remove);
          activeCasinos = activeCasinos.filter(function(i) { return i !== removeIdx; });
          renderPills();
          updateAddSelect();
          calc(parseInt(slider.value));
        });
      });
    }

    function updateAddSelect() {
      var html = '<option value="">+ Ajouter un casino à comparer</option>';
      casinos.forEach(function(c, i) {
        if (activeCasinos.indexOf(i) === -1) {
          html += '<option value="' + i + '">' + c.logo + ' ' + c.name + '</option>';
        }
      });
      addSelect.innerHTML = html;
    }

    addSelect.addEventListener('change', function() {
      var val = this.value;
      if (val === '') return;
      var idx = parseInt(val);
      if (activeCasinos.indexOf(idx) === -1) {
        activeCasinos.push(idx);
        renderPills();
        updateAddSelect();
        calc(parseInt(slider.value));
      }
      this.value = '';
    });

    renderPills();
    updateAddSelect();

    function calc(deposit) {
      display.textContent = deposit + '€';
      var pct = ((deposit - 25) / (1500 - 25)) * 100;
      slider.style.background = 'linear-gradient(to right, #22c55e ' + pct + '%, #2a2d35 ' + pct + '%)';

      var html = '';
      activeCasinos.forEach(function(idx) {
        var c = casinos[idx];
        var totalBonus = 0;
        var totalFS = 0;
        var details = [];
        var remaining = deposit;

        var effectiveDeposit = Math.min(deposit, c.maxDeposit);
        c.deposits.forEach(function(d, i) {
          var depAmount = c.deposits.length > 1 ? Math.min(remaining, d.max) : effectiveDeposit;
          var bonus = Math.min(depAmount * d.pct / 100, d.max);
          totalBonus += bonus;
          totalFS += d.fs;
          if (c.deposits.length > 1) {
            var detail = 'Dépôt ' + (i+1) + ': +' + Math.round(bonus) + '€';
            if (d.fs) detail += ' + ' + d.fs + ' FS';
            if (d.fsGame) detail += ' (' + d.fsGame + ')';
            if (d.wager) detail += ' — Wager ' + d.wager;
            details.push(detail);
            remaining -= depAmount;
          }
        });

        var offertEligible = deposit >= (c.minDepositOffert || 25);
        var offertAmount = offertEligible ? c.offert : 0;
        var total = deposit + totalBonus + offertAmount;
        var wagerColor = c.wager === 'FREE' ? '#22c55e' : '#eab308';
        var wagerText = c.wager === 'FREE' ? '✅ Wager FREE' : '⚡ Wager ' + c.wager;
        var bonusPct = c.deposits[0].pct + '%';

        html += '<div class="bg-[#0e1015] border border-[#2a2d35] rounded-xl p-3 hover:border-primary/40 transition-all">';
        html += '<div class="flex items-center gap-2 mb-2">';
        html += '<span class="text-xl">' + c.logo + '</span>';
        html += '<span class="text-white font-extrabold text-sm">' + c.name + '</span>';
        html += '<span style="font-size:9px;font-weight:700;margin-left:auto;display:flex;gap:4px;align-items:center;">';
        html += '<span style="color:#a78bfa;padding:2px 6px;border-radius:4px;background:#a78bfa15;border:1px solid #a78bfa30;">Bonus ' + bonusPct + '</span>';
        html += '<span style="color:' + wagerColor + ';padding:2px 6px;border-radius:4px;background:' + wagerColor + '15;border:1px solid ' + wagerColor + '30;">' + wagerText + '</span>';
        html += '</span>';
        html += '</div>';
        html += '<div class="flex items-center justify-between mb-2 px-2 py-1.5 rounded-lg ' + (deposit > c.maxDeposit ? 'bg-red-500/10 border border-red-500/20' : 'bg-[#1a1d23] border border-[#2a2d35]') + '">';
        html += '<span class="text-gray-500 text-[10px]">Dépôt max bonus</span>';
        html += '<span class="font-extrabold text-xs ' + (deposit > c.maxDeposit ? 'text-red-400' : 'text-white') + '">' + c.maxDeposit + '€</span>';
        html += '</div>';
        if (deposit > c.maxDeposit) {
          html += '<p class="text-red-400 text-[10px] text-center mb-2">⚠️ Ton dépôt dépasse le max — le bonus sera plafonné à ' + c.maxDeposit + '€</p>';
        }

        html += '<div class="text-center mb-2">';
        html += '<p class="text-accent-green font-black text-2xl">' + Math.round(total) + '€</p>';
        html += '<p class="text-gray-500 text-[9px]">Total sur ton compte</p>';
        html += '</div>';

        html += '<div class="space-y-1.5 text-xs">';
        html += '<div class="flex justify-between"><span class="text-gray-500">Ton dépôt</span><span class="text-white font-bold">' + deposit + '€</span></div>';
        html += '<div class="flex justify-between"><span class="text-gray-500">Bonus</span><span class="text-gold font-bold">+' + Math.round(totalBonus) + '€</span></div>';
        if (totalFS > 0) {
          html += '<div class="flex justify-between"><span class="text-gray-500">Free Spins</span><span class="text-gold font-bold">+' + totalFS + ' FS</span></div>';
        }
        html += '</div>';
        html += '<div class="mt-2 pt-2 border-t border-dashed border-[#2a2d35]">';
        if (offertEligible) {
          html += '<div class="flex justify-between text-xs"><span class="text-[#5865F2]">🎁 Offert via Discord (hors bonus)</span><span class="text-[#5865F2] font-bold">+' + c.offert + '€</span></div>';
        } else {
          html += '<div class="flex justify-between text-xs"><span class="text-gray-600">🎁 Offert via Discord</span><span class="text-gray-600 font-bold line-through">+' + c.offert + '€</span></div>';
          html += '<p class="text-red-400 text-[10px] mt-1">⚠️ Dépôt min. ' + c.minDepositOffert + '€ requis pour débloquer les ' + c.offert + '€ offerts</p>';
        }
        html += '</div>';

        if (details.length > 0) {
          html += '<div class="mt-3 pt-3 border-t border-[#2a2d35]">';
          html += '<p class="text-gray-500 text-[10px] font-bold uppercase mb-1">📋 ' + c.note + '</p>';
          details.forEach(function(d) {
            html += '<p class="text-gray-400 text-[10px]">' + d + '</p>';
          });
          html += '</div>';
        } else {
          html += '<div class="mt-3 pt-3 border-t border-[#2a2d35]">';
          html += '<p class="text-gray-500 text-[10px]">📋 ' + c.note + '</p>';
          html += '</div>';
        }

        // Free Spins bonus (Betify code MELCHIORFS)
        if (c.freeSpins) {
          html += '<div class="mt-2 pt-2 border-t border-[#2a2d35]">';
          html += '<p class="text-primary text-[10px] font-bold uppercase mb-1">🎰 Free Spins (code MELCHIORFS)</p>';
          var gotSpins = false;
          for (var fi = c.freeSpins.length - 1; fi >= 0; fi--) {
            var fs = c.freeSpins[fi];
            if (deposit >= fs.minDeposit) {
              html += '<p class="text-accent-green text-xs font-bold">✅ ' + fs.spins + ' Free Spins sur Mental NoLimit</p>';
              html += '<p class="text-gray-500 text-[10px]">Max win : ' + fs.maxWin + '€</p>';
              gotSpins = true;
              break;
            }
          }
          if (!gotSpins) {
            html += '<p class="text-gray-500 text-[10px]">Dépose min. 50€ pour débloquer les Free Spins</p>';
          }
          c.freeSpins.forEach(function(fs) {
            html += '<p class="text-gray-600 text-[9px]">' + (deposit >= fs.minDeposit ? '✓' : '○') + ' Dépôt ' + fs.minDeposit + '€ → ' + fs.spins + ' spins (max win ' + fs.maxWin + '€)</p>';
          });
          html += '</div>';
        }

        html += '</div>';
      });

      results.innerHTML = html;

      // Adjust grid based on number of active casinos
      if (activeCasinos.length === 1) {
        results.className = 'grid grid-cols-1 max-w-md mx-auto gap-4';
      } else if (activeCasinos.length === 2) {
        results.className = 'grid grid-cols-1 sm:grid-cols-2 max-w-2xl mx-auto gap-4';
      } else {
        results.className = 'grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4';
      }
    }

    slider.addEventListener('input', function() { calc(parseInt(this.value)); });
    calc(100);
  })();
  </script>

</LandingLayout>
