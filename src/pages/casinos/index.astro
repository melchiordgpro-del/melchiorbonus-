---
import Layout from '../../layouts/Layout.astro';
import CasinoCard from '../../components/CasinoCard.astro';
import { casinos } from '../../data/casinos';
---

<Layout title="Top Casinos en Ligne 2026 — Classement Complet | MelchiorBonus" description="Classement complet des meilleurs casinos en ligne en 2026. Comparez les bonus, les jeux et les conditions de retrait.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-4">
        Top Casinos <span class="text-primary-light">2026</span>
      </h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Notre classement complet des casinos en ligne les plus fiables, mis à jour chaque semaine.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {casinos.map((casino, i) => (
        <CasinoCard casino={casino} rank={i + 1} />
      ))}
    </div>
  </section>
</Layout>
