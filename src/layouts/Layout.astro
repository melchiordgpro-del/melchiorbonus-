---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Comparatif des meilleurs casinos en ligne 2026. Bonus exclusifs, avis détaillés et classements mis à jour." } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <title>{title}</title>
</head>
<body class="min-h-screen flex flex-col">
  <!-- Top gradient accent line -->
  <div class="h-0.5 bg-gradient-to-r from-primary via-accent-green to-primary w-full fixed top-0 z-[60]"></div>

  <!-- Header -->
  <header class="sticky top-0.5 z-50 bg-bg/90 backdrop-blur-xl border-b border-bg-border">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2 text-xl font-extrabold">
          <span class="text-primary text-2xl">♠</span>
          <span class="text-white">Melchior<span class="text-primary">Bonus</span></span>
        </a>

        <div class="hidden md:flex items-center gap-8">
          <a href="/" class:list={["text-sm font-medium hover:text-primary", currentPath === "/" ? "text-primary" : "text-gray-400"]}>
            Accueil
          </a>
          <a href="/casinos" class:list={["text-sm font-medium hover:text-primary", currentPath.startsWith("/casinos") ? "text-primary" : "text-gray-400"]}>
            Top Casinos
          </a>
          <a href="https://discord.com/invite/mK6anBbYdM" target="_blank" rel="noopener" class="text-sm font-medium text-gold hover:text-gold/80 flex items-center gap-1.5 animate-pulse">
            🎁 Giveaway
          </a>
          <a href="/bonus" class:list={["text-sm font-medium hover:text-primary", currentPath === "/bonus" ? "text-primary" : "text-gray-400"]}>
            Bonus
          </a>
          <a href="/guide" class:list={["text-sm font-medium hover:text-primary", currentPath === "/guide" ? "text-primary" : "text-gray-400"]}>
            Guide
          </a>
          <a href="/boutique" class="text-sm font-medium text-gray-500 flex items-center gap-1.5">
            ⭐ Boutique <span class="text-[9px]">🚧</span>
          </a>
          <a href="/bonus-hunt" class:list={["text-sm font-medium hover:text-primary flex items-center gap-1.5", currentPath === "/bonus-hunt" ? "text-primary" : "text-gray-400"]}>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 5h2v14H4zM18 5h2v14h-2zM8 3h8v4H8zM8 17h8v4H8zM9 7h6v10H9z" /></svg>
            Bonus Hunt
          </a>
          <div class="relative group">
            <button class:list={["text-sm font-medium hover:text-primary flex items-center gap-1.5 cursor-pointer", currentPath.startsWith("/jeux") ? "text-primary" : "text-gray-400"]}>
              🎮 Jeux
              <svg class="w-3 h-3 group-hover:rotate-180 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="absolute top-full left-0 mt-2 w-48 bg-bg-card border border-bg-border rounded-xl shadow-2xl shadow-black/40 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 py-2">
              <a href="/jeux/slots" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-500 hover:bg-bg-surface transition-colors">
                <span>🎰</span> Slots <span class="ml-auto text-[9px]">🚧</span>
              </a>
              <a href="/jeux/blackjack" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-500 hover:bg-bg-surface transition-colors">
                <span>🃏</span> Blackjack <span class="ml-auto text-[9px]">🚧</span>
              </a>
              <a href="/jeux/blackjack-tableau" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-400 hover:text-white hover:bg-bg-surface transition-colors">
                <span>📊</span> Tableau BJ
              </a>
              <a href="/jeux/roulette" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-400 hover:text-white hover:bg-bg-surface transition-colors">
                <span>🎡</span> Roulette
              </a>
              <a href="/jeux/plinko" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-400 hover:text-white hover:bg-bg-surface transition-colors">
                <span>📍</span> Plinko
              </a>
              <a href="/jeux/mines" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-400 hover:text-white hover:bg-bg-surface transition-colors">
                <span>💣</span> Mines
              </a>
              <a href="/jeux/chicken" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-500 hover:bg-bg-surface transition-colors">
                <span>🐔</span> Chicken <span class="ml-auto text-[9px]">🚧</span>
              </a>
              <a href="/jeux/hilo" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-500 hover:bg-bg-surface transition-colors">
                <span>📈</span> HiLo <span class="ml-auto text-[9px]">🚧</span>
              </a>
              <div class="border-t border-bg-border my-1 mx-3"></div>
              <a href="/jeux/blackjack-extension" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-400 hover:text-white hover:bg-bg-surface transition-colors">
                <span>🧠</span> Quiz Blackjack
              </a>
              <a href="/extension" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-400 hover:text-white hover:bg-bg-surface transition-colors">
                <span>🔌</span> Extension Chrome
              </a>
            </div>
          </div>
        </div>

        <div class="hidden sm:flex items-center gap-4">
          <a href="https://discord.com/invite/mK6anBbYdM" target="_blank" rel="noopener" class="text-gray-400 hover:text-[#5865F2] transition-colors" title="Discord MelchiorCorp">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
          </a>
          <!-- Logged out state -->
          <div id="header-logged-out" class="flex items-center gap-4">
            <a href="/login" class="text-gray-400 hover:text-white text-sm font-medium transition-colors">
              Connexion
            </a>
            <a href="/inscription" class="bg-primary hover:bg-primary-light text-white font-bold text-sm px-5 py-2.5 rounded-lg transition-all duration-200 hover:shadow-lg hover:shadow-primary/20">
              Inscription
            </a>
          </div>
          <!-- Logged in state -->
          <div id="header-logged-in" class="hidden relative group">
            <button class="flex items-center gap-2 bg-bg-card border border-bg-border hover:border-primary/30 text-white font-medium text-sm px-4 py-2 rounded-lg transition-all cursor-pointer">
              <div class="w-7 h-7 bg-primary/20 rounded-full flex items-center justify-center">
                <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0" /></svg>
              </div>
              <span id="header-username">Utilisateur</span>
              <svg class="w-3 h-3 text-gray-500 group-hover:rotate-180 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="absolute right-0 top-full mt-2 w-48 bg-bg-card border border-bg-border rounded-xl shadow-2xl shadow-black/40 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 py-2">
              <div class="px-4 py-2 border-b border-bg-border">
                <p id="header-user-email" class="text-gray-500 text-xs truncate"></p>
              </div>
              <a href="/bonus-hunt" class="flex items-center gap-2 px-4 py-2.5 text-sm text-gray-400 hover:text-white hover:bg-bg-surface transition-colors">
                🎰 Bonus Hunt
              </a>
              <a href="/jeux/slots" class="flex items-center gap-2 px-4 py-2.5 text-sm text-gray-400 hover:text-white hover:bg-bg-surface transition-colors">
                🎮 Mes Jeux
              </a>
              <button id="btn-logout" class="w-full text-left flex items-center gap-2 px-4 py-2.5 text-sm text-accent-red hover:bg-bg-surface transition-colors">
                🚪 Déconnexion
              </button>
            </div>
          </div>
        </div>

        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="md:hidden text-gray-400 hover:text-white p-2" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-bg-border mt-2 pt-4">
        <div class="flex flex-col gap-3">
          <a href="/" class="text-sm font-medium text-gray-400 hover:text-primary px-2 py-1">Accueil</a>
          <a href="/casinos" class="text-sm font-medium text-gray-400 hover:text-primary px-2 py-1">Top Casinos</a>
          <a href="/bonus" class="text-sm font-medium text-gray-400 hover:text-primary px-2 py-1">Bonus</a>
          <a href="/guide" class="text-sm font-medium text-gray-400 hover:text-primary px-2 py-1">Guide</a>
          <a href="/bonus-hunt" class="text-sm font-medium text-gray-400 hover:text-primary px-2 py-1">🎰 Bonus Hunt</a>
          <a href="/jeux/blackjack" class="text-sm font-medium text-gray-400 hover:text-primary px-2 py-1">🃏 Blackjack</a>
          <a href="/jeux/roulette" class="text-sm font-medium text-gray-400 hover:text-primary px-2 py-1">🎡 Roulette</a>
          <a href="/jeux/plinko" class="text-sm font-medium text-gray-400 hover:text-primary px-2 py-1">📍 Plinko</a>
          <a href="/jeux/mines" class="text-sm font-medium text-gray-400 hover:text-primary px-2 py-1">💣 Mines</a>
          <a href="/jeux/chicken" class="text-sm font-medium text-gray-400 hover:text-primary px-2 py-1">🐔 Chicken</a>
          <a href="/jeux/hilo" class="text-sm font-medium text-gray-400 hover:text-primary px-2 py-1">📈 HiLo</a>
          <a href="/jeux/blackjack-extension" class="text-sm font-medium text-gray-400 hover:text-primary px-2 py-1">🧠 Quiz Blackjack</a>
          <a href="/login" class="text-sm font-medium text-gray-400 hover:text-primary px-2 py-1">Connexion</a>
        </div>
      </div>
    </nav>
  </header>

  <!-- Main content -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-bg-card border-t border-bg-border mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <div class="md:col-span-1">
          <a href="/" class="flex items-center gap-2 text-xl font-extrabold mb-4">
            <span class="text-primary text-2xl">♠</span>
            <span class="text-white">Melchior<span class="text-primary">Bonus</span></span>
          </a>
          <p class="text-gray-500 text-sm leading-relaxed">
            Votre guide expert pour trouver les meilleurs casinos en ligne. Avis impartiaux et bonus exclusifs.
          </p>
        </div>

        <div>
          <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Navigation</h4>
          <ul class="space-y-2">
            <li><a href="/" class="text-gray-500 hover:text-primary text-sm">Accueil</a></li>
            <li><a href="/casinos" class="text-gray-500 hover:text-primary text-sm">Top Casinos</a></li>
            <li><a href="/bonus" class="text-gray-500 hover:text-primary text-sm">Bonus</a></li>
            <li><a href="/guide" class="text-gray-500 hover:text-primary text-sm">Guide</a></li>
          </ul>
        </div>

        <div>
          <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Informations</h4>
          <ul class="space-y-2">
            <li><a href="/mentions-legales" class="text-gray-500 hover:text-primary text-sm">Mentions légales</a></li>
            <li><a href="/confidentialite" class="text-gray-500 hover:text-primary text-sm">Politique de confidentialité</a></li>
            <li><a href="/jeu-responsable" class="text-gray-500 hover:text-primary text-sm">Jeu responsable</a></li>
            <li><a href="/contact" class="text-gray-500 hover:text-primary text-sm">Contact</a></li>
          </ul>
        </div>

        <div>
          <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Jeu Responsable</h4>
          <p class="text-gray-500 text-sm leading-relaxed mb-3">
            Le jeu comporte des risques. Jouez de manière responsable. 18+ uniquement.
          </p>
          <div class="flex items-center gap-3 text-2xl">
            <span title="18+">🔞</span>
          </div>
          <a href="https://discord.com/invite/mK6anBbYdM" target="_blank" rel="noopener" class="inline-flex items-center gap-2 mt-4 bg-[#5865F2]/10 border border-[#5865F2]/20 text-[#5865F2] text-sm font-medium px-4 py-2 rounded-lg hover:bg-[#5865F2]/20 transition-all">
            Discord MelchiorCorp
          </a>
        </div>
      </div>

      <div class="border-t border-bg-border mt-8 pt-8 text-center">
        <p class="text-gray-600 text-xs">
          &copy; 2026 MelchiorBonus. Tous droits réservés. Ce site contient des liens d'affiliation.
          Les jeux d'argent sont interdits aux mineurs. Jouez responsablement.
        </p>
        <a href="/admin" class="text-gray-700 text-[10px] mt-2 inline-block hover:text-gray-500 transition-colors">Staff</a>
      </div>
    </div>
  </footer>

  <script is:inline>
    // Mobile menu
    var btn = document.getElementById('mobile-menu-btn');
    var menu = document.getElementById('mobile-menu');
    if (btn && menu) btn.addEventListener('click', function() { menu.classList.toggle('hidden'); });

    // Auth state in header
    var isLoggedIn = localStorage.getItem('melchior_logged_in') === 'true';
    var loggedOut = document.getElementById('header-logged-out');
    var loggedIn = document.getElementById('header-logged-in');

    if (isLoggedIn && loggedOut && loggedIn) {
      loggedOut.classList.add('hidden');
      loggedIn.classList.remove('hidden');
      var name = localStorage.getItem('melchior_user_name') || 'Utilisateur';
      var email = localStorage.getItem('melchior_user_email') || '';
      document.getElementById('header-username').textContent = name;
      document.getElementById('header-user-email').textContent = email;
    }

    // Logout
    var logoutBtn = document.getElementById('btn-logout');
    if (logoutBtn) {
      logoutBtn.addEventListener('click', function() {
        localStorage.removeItem('melchior_logged_in');
        localStorage.removeItem('melchior_user_name');
        localStorage.removeItem('melchior_user_email');
        localStorage.removeItem('melchior_login_method');
        window.location.href = '/';
      });
    }
  </script>

  <!-- Scroll fade-in observer -->
  <script is:inline>
    (function() {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

      document.querySelectorAll('.fade-in').forEach(function(el) {
        observer.observe(el);
      });
    })();
  </script>
</body>
</html>
